				<span class="text-text-muted">·</span>
				<span class="text-text-muted">{totalCompanies} companies scanned</span>
			</div>

			<h1 class="heading-xl">
				<span class="text-text">Billion-dollar startups are</span><br/>
				<span class="text-red">invisible to AI.</span>
			</h1>

			<p class="text-text-secondary text-lg mt-6 leading-relaxed max-w-2xl mx-auto">
				We scanned {totalCompanies} of the world's most well-funded startups across {industries.length} industries using <code class="!text-sm">aeorank-cli</code>. The results are brutal. OpenAI scores 16. Figma scores 30. The industry average is <strong class="text-accent">{globalAvg}/100</strong>.
			</p>

			<!-- Scrolling logo bar -->
			<div class="flex flex-wrap justify-center gap-4 mt-10 max-w-3xl mx-auto">
				{topLogos.map((co) => (
					<div class="flex items-center gap-2 rounded-lg bg-bg-card border border-border px-3 py-2">
						<img
							src={`https://www.google.com/s2/favicons?domain=${co.url}&sz=32`}
							alt={co.name}
							width="20"
							height="20"
							class="rounded-sm"
							loading="lazy"
						/>
						<span class="text-xs text-text-muted">{co.name}</span>
						<span class={`text-xs font-bold ${gradeColor(co.grade)}`}>{co.score}</span>
					</div>
				))}
			</div>

			<div class="flex flex-wrap justify-center gap-3 mt-10">
				<a href="https://github.com/apps/aeorank" class="btn-primary !px-6 !py-3 text-base">Check Your Score Free</a>
				<a href="#industry-fintech" class="btn-secondary !px-6 !py-3 text-base">See All Results</a>
			</div>
		</div>
	</section>

	<!-- Industry overview cards -->
	<section class="px-6 py-12 border-t border-border">
		<div class="mx-auto max-w-6xl">
			<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
				{industries.map((ind) => (
					<a href={`#industry-${ind.name.toLowerCase().replace(/[\s\/]/g, '-')}`} class="card p-5 text-center hover:border-accent/30 transition-all">
						<span class="text-3xl">{ind.emoji}</span>
						<p class="text-xs font-semibold mt-3 text-text-muted">{ind.name}</p>
						<p class="text-3xl font-bold mt-2">
							<span class={ind.avg >= 50 ? 'text-[#FFD700]' : 'text-accent'}>{ind.avg}</span>
							<span class="text-text-muted text-sm">/100</span>
						</p>
						<p class="text-[10px] text-text-muted mt-1 uppercase tracking-wider">avg score</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Industry detail sections -->
	<section class="px-6 py-12">
		<div class="mx-auto max-w-5xl space-y-20">
			{industries.map((ind) => (
				<div id={`industry-${ind.name.toLowerCase().replace(/[\s\/]/g, '-')}`} class="scroll-mt-20">
					<!-- Industry header -->
					<div class="flex items-center justify-between mb-8">
						<div class="flex items-center gap-4">
							<span class="text-4xl">{ind.emoji}</span>
							<div>
								<h2 class="heading-md">{ind.name}</h2>
								<p class="text-sm text-text-muted mt-1">
									Industry average: <span class={`font-bold ${ind.avg >= 50 ? 'text-[#FFD700]' : 'text-accent'}`}>{ind.avg}/100</span>
									<span class="mx-2 text-border">|</span>
									{ind.companies.filter(c => c.score >= 60).length} passing · {ind.companies.filter(c => c.score < 40).length} failing
								</p>
							</div>
						</div>
					</div>

					<!-- Company rows with logos -->
					<div class="space-y-2">
						{ind.companies.map((co, idx) => (
							<div class="flex items-center gap-3 py-3 px-4 rounded-xl bg-bg-card border border-border hover:border-border-strong transition-all group">
								<span class="text-text-muted text-xs font-mono w-5 text-right shrink-0">{idx + 1}</span>
								<img
									src={`https://www.google.com/s2/favicons?domain=${co.url}&sz=32`}
									alt={`${co.name} logo`}
									width="24"
									height="24"
									class="rounded-md shrink-0"
									loading="lazy"
								/>
								<div class="min-w-[100px] sm:min-w-[160px]">
									<span class="font-semibold text-sm">{co.name}</span>
									<span class="text-xs text-text-muted ml-2 hidden sm:inline">{co.url}</span>
								</div>
								<div class="flex-1 mx-2 hidden sm:block">
									<div class="h-2.5 rounded-full bg-white/5 overflow-hidden">
										<div class={`h-full rounded-full ${barColor(co.score)} transition-all`} style={`width: ${barWidth(co.score)}`}></div>
									</div>
								</div>
								<span class="text-base font-bold tabular-nums w-8 text-right">{co.score}</span>
								<span class={`text-xs font-bold px-2 py-0.5 rounded-md border ${gradeBg(co.grade)} ${gradeColor(co.grade)} w-8 text-center`}>{co.grade}</span>
							</div>
						))}
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- CTA -->
	<section class="px-6 py-20 border-t border-border">
		<div class="mx-auto max-w-2xl text-center">
			<div class="card p-12 border-accent/20">
				<h2 class="heading-lg">Where does <em>your</em> site rank?</h2>
				<p class="text-text-secondary mt-4 text-lg">These companies raised billions and hired hundreds of engineers. Their average AEO score is {globalAvg}/100. You might score higher — or much lower. Find out in 30 seconds.</p>
				<div class="flex flex-wrap justify-center gap-3 mt-8">
					<a href="https://github.com/apps/aeorank" class="btn-primary !px-8 !py-3.5 text-base">Scan My Site Free</a>
				</div>
				<p class="text-text-muted text-xs mt-4">Free forever · No credit card · Results in 30 seconds</p>

				<div class="mt-8 pt-6 border-t border-border">
					<p class="text-xs text-text-muted">Or scan from terminal:</p>
					<code class="text-sm mt-2 inline-block">npx aeorank-cli scan https://your-site.com</code>
				</div>
			</div>
		</div>
	</section>

	<!-- Methodology + Disclaimer -->
	<section class="px-6 py-12 border-t border-border">
		<div class="mx-auto max-w-3xl">
			<h3 class="heading-sm mb-4">Methodology</h3>
			<p class="text-sm text-text-muted leading-relaxed">
				All scores were generated on April 9, 2026 using <code class="!text-xs">aeorank-cli scan</code> with default settings (up to 10 pages per site, deterministic scoring, no LLM calls). AEOrank evaluates 36 criteria across 5 pillars: Answer Readiness, Content Structure, Trust & Authority, Technical Foundation, and AI Discovery. Scores range from 0–100. Higher is better.
			</p>
			<p class="text-sm text-text-muted leading-relaxed mt-3">
				Scores are a point-in-time snapshot and may change as companies update their sites. Companies can improve their scores by running <code class="!text-xs">aeorank-cli scan</code> and implementing the recommended changes.
			</p>

			<div class="mt-8 p-5 rounded-xl bg-bg-card border border-border">
				<h4 class="text-xs font-semibold text-text-muted uppercase tracking-wider mb-3">Trademark Disclaimer</h4>
				<p class="text-xs text-text-muted leading-relaxed">
					All company names, logos, and trademarks referenced on this page are the property of their respective owners. AEOrank is not affiliated with, endorsed by, or sponsored by any of the companies listed. Company logos shown are favicons retrieved from publicly accessible domains for identification purposes only. The inclusion of any company on this scoreboard does not imply any relationship, partnership, or endorsement. This analysis is provided for informational and educational purposes under fair use.
				</p>
			</div>

			<p class="text-center text-text-muted text-xs mt-8">
				Built with <a href="https://aeorank.dev" class="text-accent hover:underline">AEOrank</a> · Open source · MIT licensed
			</p>
		</div>
	</section>
</Base>
