function gradeColor(grade: string): string {
	if (grade === "A" || grade === "A+") return "text-green";
	if (grade === "B") return "text-green";
	if (grade === "C") return "text-[#FFD700]";
	if (grade === "D") return "text-accent";
	return "text-red";
}

function gradeBg(grade: string): string {
	if (grade === "A" || grade === "A+") return "bg-green/10 border-green/20";
	if (grade === "B") return "bg-green/10 border-green/20";
	if (grade === "C") return "bg-[#FFD700]/10 border-[#FFD700]/20";
	if (grade === "D") return "bg-accent/10 border-accent/20";
	return "bg-red/10 border-red/20";
}

function barWidth(score: number): string {
	return `${Math.max(score, 3)}%`;
}

function barColor(score: number): string {
	if (score >= 80) return "bg-green";
	if (score >= 60) return "bg-[#FFD700]";
	if (score >= 40) return "bg-accent";
	return "bg-red";
}

const totalCompanies = industries.reduce((sum, i) => sum + i.companies.length, 0);
const globalAvg = Math.round(industries.reduce((sum, i) => sum + i.avg, 0) / industries.length);
const allCompanies = industries.flatMap(i => i.companies);
const topLogos = allCompanies.sort((a, b) => b.score - a.score).slice(0, 20);
---

<Base
	title="AEO Industry Scoreboard — AI Visibility Scores for 100 Top Startups | AEOrank"
	description="We scanned 100 top-funded startups across 10 industries for AI visibility. Stripe scores 57. OpenAI scores 16. Figma scores 30. How does your site compare?"
>
	<!-- Hero -->
	<section class="px-6 pt-20 pb-12 md:pt-28 md:pb-16">
		<div class="mx-auto max-w-4xl text-center">
			<div class="inline-flex items-center gap-2 rounded-full bg-red/10 border border-red/20 px-4 py-1.5 text-sm mb-8">
