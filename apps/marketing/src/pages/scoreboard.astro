const totalCompanies = industries.reduce((sum, i) => sum + i.companies.length, 0);
const globalAvg = Math.round(industries.reduce((sum, i) => sum + i.avg, 0) / industries.length);
const passing  = industries.flatMap(i => i.companies).filter(c => c.score >= 60).length;
const failing  = industries.flatMap(i => i.companies).filter(c => c.score < 40).length;
const gradeClass = (g: string) => g === "A" || g === "A+" ? "lb__grade--a" : g === "B" ? "lb__grade--b" : g === "C" ? "lb__grade--c" : g === "D" ? "lb__grade--d" : "lb__grade--f";
const slug = (s: string) => s.toLowerCase().replace(/[\s\/]+/g, '-');
---

<Base
	title="AEO Industry Scoreboard — 100 funded startups, scored"
	description="We scan 100 top-funded startups weekly for AI visibility. See who ChatGPT, Perplexity, and Claude can actually read."
	route="/ inspector / scoreboard"
>
	<!-- Page hero -->
	<section class="section section-first">
		<div class="wrap rail">
			<span class="rail-tick" style="top:0"></span>
			<span class="rail-coord" style="top:0">BOARD</span>

			<p class="t-label">// the scoreboard</p>
			<h1 class="t-display mt-3">
				100 funded startups.<br/>
				<span class="font-serif">One brutal number.</span>
			</h1>
			<p class="t-lead mt-5 max-w-[60ch]">
				We run <code>aeorank-cli scan</code> against {totalCompanies} of the most well-funded startups every week. OpenAI scores 16. Figma scores 30. The industry average is {globalAvg}/100. The data below is the entire spreadsheet.
			</p>

			<!-- Top stat strip -->
			<div class="sb-stats mt-8" data-reveal>
				<div class="sb-stats__cell">
					<span class="t-label">companies</span>
					<p class="sb-stats__num font-mono">{totalCompanies}</p>
				</div>
				<div class="sb-stats__cell">
					<span class="t-label">industries</span>
					<p class="sb-stats__num font-mono">{industries.length}</p>
				</div>
				<div class="sb-stats__cell">
					<span class="t-label">mean score</span>
					<p class="sb-stats__num font-mono">{globalAvg}<span class="ink-3 text-[14px]">/100</span></p>
				</div>
				<div class="sb-stats__cell">
					<span class="t-label">passing (≥60)</span>
					<p class="sb-stats__num font-mono sig-ok">{passing}</p>
				</div>
				<div class="sb-stats__cell">
					<span class="t-label">failing (&lt;40)</span>
					<p class="sb-stats__num font-mono sig-fail">{failing}</p>
				</div>
			</div>

			<div class="flex gap-2 mt-6 flex-wrap">
				<a href="https://app.aeorank.dev/sign-up" class="btn btn-ink btn-lg">Scan my site&nbsp;→</a>
				<a href="#industries" class="btn btn-outline btn-lg">Browse by industry</a>
			</div>
		</div>
	</section>

	<!-- Industry index -->
	<section id="industries" class="section">
		<div class="wrap rail">
			<span class="rail-tick" style="top:0"></span>
			<span class="rail-coord" style="top:0">IDX</span>

			<div class="section-head">
				<div>
					<p class="t-label">// industry index</p>
					<h2 class="t-h1 mt-2">Sorted by weekly mean.</h2>
				</div>
				<div class="section-meta">
					<span>{industries.length}&nbsp;<b>sectors</b></span>
					<span>updated&nbsp;<b>hourly</b></span>
				</div>
			</div>

			<div class="sb-index">
				{industries.slice().sort((a, b) => b.avg - a.avg).map((ind, i) => (
					<a href={`#sector-${slug(ind.name)}`} class="sb-index__cell">
						<span class="font-mono text-[10.5px] ink-3">{String(i + 1).padStart(2, "0")}</span>
						<span class="ink">{ind.name}</span>
						<span class="sb-index__num font-mono">{ind.avg}<span class="ink-3 text-[11px]">/100</span></span>
						<span class="sb-index__bar"><span class="sb-index__bar-fill" style={`width: ${ind.avg}%`}></span></span>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- One table per industry -->
	{industries.map(ind => (
		<section id={`sector-${slug(ind.name)}`} class="section">
			<div class="wrap rail">
				<span class="rail-tick" style="top:0"></span>
				<span class="rail-coord" style="top:0">{ind.name.slice(0,3).toUpperCase()}</span>

				<div class="section-head">
					<div>
						<p class="t-label">// sector</p>
						<h2 class="t-h1 mt-2">{ind.name}</h2>
						<p class="t-body mt-2">
							Mean: <span class="font-mono ink">{ind.avg}/100</span> · {ind.companies.filter(c => c.score >= 60).length} passing · {ind.companies.filter(c => c.score < 40).length} failing
						</p>
					</div>
					<div class="section-meta">
						<span>{ind.companies.length}&nbsp;<b>sites</b></span>
					</div>
				</div>

				<div class="lb">
					<table class="lb__table">
						<thead>
							<tr>
								<th class="lb__th lb__th--rank">#</th>
								<th class="lb__th">company</th>
								<th class="lb__th">domain</th>
								<th class="lb__th lb__th--num">score</th>
								<th class="lb__th lb__th--grade">grade</th>
								<th class="lb__th lb__th--bar">bar</th>
							</tr>
						</thead>
						<tbody>
							{ind.companies.slice().sort((a, b) => b.score - a.score).map((co, i) => (
								<tr class="lb__tr">
									<td class="lb__td lb__td--rank font-mono">{String(i + 1).padStart(2, "0")}</td>
									<td class="lb__td lb__td--name">
										<span class="sb-row__logo" aria-hidden="true">
											<img src={`https://www.google.com/s2/favicons?domain=${co.url}&sz=32`} alt="" width="16" height="16" loading="lazy" />
										</span>
										<span class="ink">{co.name}</span>
									</td>
									<td class="lb__td">
										<span class="font-mono text-[11px] ink-3">{co.url}</span>
									</td>
									<td class="lb__td lb__td--num font-mono">
										<span class="ink" style="font-size:15px; font-weight:600">{co.score}</span>
										<span class="ink-3 text-[10.5px]">/100</span>
									</td>
									<td class="lb__td lb__td--grade">
										<span class={`lb__grade ${gradeClass(co.grade)}`}>{co.grade}</span>
									</td>
									<td class="lb__td lb__td--bar">
										<span class="lb__bar"><span class="lb__bar-fill" style={`width: ${Math.max(co.score, 3)}%`}></span></span>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>
		</section>
	))}

	<!-- CTA -->
	<section class="section">
		<div class="wrap rail">
			<span class="rail-tick" style="top:0"></span>
			<span class="rail-coord" style="top:0">YOU</span>

			<div class="sb-cta cropped">
				<span class="cr-tl" aria-hidden="true"></span>
				<span class="cr-br" aria-hidden="true"></span>

				<p class="t-label">// your turn</p>
				<h2 class="t-h1 mt-3">
					Where does <span class="font-serif">your</span> site rank?
				</h2>
				<p class="t-body mt-3 max-w-[54ch]">
					These companies raised billions. Their mean AEO score is {globalAvg}/100. You might be higher. You might be lower. Either way, it takes ~30 seconds to find out.
				</p>
				<div class="flex gap-2 mt-6 flex-wrap">
					<a href="https://app.aeorank.dev/sign-up" class="btn btn-ink btn-lg">Scan my site free</a>
					<a href="https://github.com/vinpatel/aeorank" class="btn btn-outline btn-lg" target="_blank" rel="noopener">Or self-host it</a>
				</div>
				<code class="mt-4 inline-block">npx aeorank-cli scan https://your-site.com</code>
			</div>

			<!-- Methodology -->
			<section class="sb-meth mt-8">
				<h3 class="t-h3">Methodology</h3>
				<p class="t-body mt-2">
					All scores generated on 2026-04-09 using <code>aeorank-cli scan</code> with default settings (up to 10 pages per site, deterministic, no LLM calls). AEOrank evaluates 36 criteria across 5 pillars. Higher is better. Scores are point-in-time and can change as sites update.
				</p>
				<h3 class="t-h3 mt-5">Trademarks</h3>
				<p class="t-body mt-2">
					Company names, logos, and trademarks are property of their respective owners. AEOrank is not affiliated with or endorsed by any listed company. Favicons are retrieved from public domains for identification only.
				</p>
			</section>
		</div>
	</section>
</Base>

<!-- Leaderboard table styles re-used + small additions -->
<style is:global>
	.lb {
		background: var(--color-page);
		border: 1px solid var(--color-ink);
		border-radius: 4px;
		overflow: hidden;
	}
	.lb__table { width: 100%; border-collapse: collapse; font-size: 13px; }
	.lb__th {
		text-align: left; font-family: var(--font-mono); font-weight: 500; font-size: 10.5px;
		color: var(--color-ink-3); letter-spacing: 0.06em; text-transform: uppercase;
		padding: 9px 16px; border-bottom: 1px solid var(--color-rule); background: var(--color-paper);
	}
	.lb__th--rank { width: 42px; }
	.lb__th--num { text-align: right; }
	.lb__th--grade { width: 78px; }
	.lb__th--bar { width: 32%; }
	.lb__tr:nth-child(odd) { background: #FBFAF6; }
	.lb__tr:hover { background: #F3F0E8; }
	.lb__td { padding: 10px 16px; border-bottom: 1px solid var(--color-rule); vertical-align: middle; }
	.lb__td--rank { color: var(--color-ink-3); font-size: 12px; }
	.lb__td--name { display: flex; align-items: center; gap: 8px; font-weight: 500; }
	.lb__td--num { text-align: right; white-space: nowrap; }
	.lb__grade {
		display: inline-flex; align-items: center; justify-content: center;
		width: 30px; height: 22px;
		font-family: var(--font-serif); font-style: italic; font-size: 18px; line-height: 1;
	}
	.lb__grade--a  { color: var(--color-ok); }
	.lb__grade--b  { color: var(--color-ink); }
	.lb__grade--c  { color: var(--color-warn); }
	.lb__grade--d  { color: var(--color-warn); }
	.lb__grade--f  { color: var(--color-fail); }
	.lb__bar {
		display: block; height: 6px;
		background: var(--color-paper-2);
		border: 1px solid var(--color-rule);
		border-radius: 1px; position: relative; overflow: hidden;
	}
	.lb__bar-fill {
		display: block; height: 100%;
		background: linear-gradient(90deg, var(--color-fail) 0%, var(--color-warn) 50%, var(--color-ok) 100%);
	}
</style>

<style>
	.sb-stats {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		border: 1px solid var(--color-rule);
		border-radius: 4px;
		background: var(--color-page);
		max-width: 720px;
	}
	.sb-stats__cell {
		padding: 14px 16px;
		border-right: 1px solid var(--color-rule);
	}
	.sb-stats__cell:last-child { border-right: none; }
	.sb-stats__num {
		font-size: 22px; font-weight: 620; letter-spacing: -0.02em; margin-top: 2px;
	}

	.sb-index {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 0;
		border: 1px solid var(--color-rule);
		border-radius: 4px;
		background: var(--color-page);
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
	}
	.sb-index__cell {
		display: grid;
		grid-template-columns: 32px 1fr auto 120px;
		gap: 12px;
		align-items: center;
		padding: 12px 16px;
		border-right: 1px solid var(--color-rule);
		border-bottom: 1px solid var(--color-rule);
		color: var(--color-ink);
		text-decoration: none;
		font-size: 13px;
	}
	.sb-index__cell:nth-child(2n) { border-right: none; }
	.sb-index__cell:hover { background: var(--color-paper-2); }
	.sb-index__num { font-size: 14px; font-weight: 600; letter-spacing: -0.02em; }
	.sb-index__bar {
		display: block; height: 4px;
		background: var(--color-paper-2);
		border: 1px solid var(--color-rule);
		border-radius: 1px; overflow: hidden; position: relative;
	}
	.sb-index__bar-fill {
		display: block; height: 100%;
		background: linear-gradient(90deg, var(--color-fail) 0%, var(--color-warn) 50%, var(--color-ok) 100%);
	}

	.sb-row__logo {
		width: 20px; height: 20px;
		border-radius: 3px;
		background: var(--color-paper-2);
		border: 1px solid var(--color-rule);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		flex-shrink: 0;
	}

