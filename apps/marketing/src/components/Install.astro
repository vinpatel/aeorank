---
// Install block — three tabs with real code and real diffs

const tabs = [
	{
		id: "npx",
		label: "npx",
		title: "Scan from your terminal",
		blurb: "Zero install. Zero account. Zero API key. Colored output with per-criterion scores and the 9 fix files written locally. No upload, no vendor call.",
		time: "~30s per scan",
		code: `# one-off audit on any site
$ npx aeorank-cli scan https://your-site.com

✔ 36 checks in 0.9s
  score: 31/100 · grade F
  failing: 9 · partial: 11 · passing: 16

✔ wrote dist/llms.txt
✔ wrote dist/ai.txt
✔ wrote dist/schema.json
✔ wrote dist/robots.patch
… (+ 5 more)

→ open report.html in your browser`,
		diff: null,
	},
	{
		id: "app",
		label: "GitHub App",
		title: "Install, then forget",
		blurb: "One click. Zero YAML. Every pull request gets a Check Run with the delta, the failing criteria, and a diff of the regenerated files. Block merges on AEO regressions — the way you already block on lint and tests.",
		time: "~1 click · ~0 config",
		code: `# Flow
1.  Install AEOrank on your repo
     github.com/apps/aeorank

2.  Open any PR
     → Check Run appears automatically

3.  Check summary example:
     ━━━━━━━━━━━━━━━━━━━━━━━━
     AEORANK · PR #419
     ━━━━━━━━━━━━━━━━━━━━━━━━
     score 67 → 72 (+5)  grade C → B
     ✔ llms.txt restored
     ✔ speakable markup added
     ✗ author.schema still missing`,
		diff: null,
	},
	{
		id: "action",
		label: "GitHub Action",
		title: "Full pipeline control",
		blurb: "Pin a version, set a fail-below threshold, commit the generated files back to your repo. AEO as code — the same way tests and coverage already work. No monitoring tool on the market does this.",
		time: "~8 lines of YAML",
		code: `# .github/workflows/aeorank.yml
name: aeorank
on: [pull_request, push]

jobs:
  score:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: vinpatel/aeorank-action@v1
        with:
          url: https://\${{ github.event.pull_request.head.ref }}.preview.example.com
          fail-below: 70
          output: ./dist/aeo`,
		diff: `# what this adds to your repo
+ .github/workflows/aeorank.yml
+ dist/aeo/llms.txt
+ dist/aeo/ai.txt
+ dist/aeo/schema.json
+ dist/aeo/robots.patch
+ dist/aeo/report.html`,
	},
];
---

<section id="install" class="section">
	<div class="wrap rail">
		<span class="rail-tick" style="top:0"></span>
		<span class="rail-coord" style="top:0">INSTALL</span>

		<div class="section-head">
			<div>
				<p class="t-label">// three ways in</p>
				<h2 class="t-h1 mt-2">Pick the surface that fits your team.</h2>
				<p class="t-body mt-3 max-w-[58ch]">
					Same scoring engine under all three. Same 36 checks. Same 9 generated files. Pick the surface closest to where you already ship — AEOrank is the only AEO tool that treats CI as a first-class target instead of an afterthought.
				</p>
			</div>
			<div class="section-meta">
				<span>3&nbsp;<b>surfaces</b></span>
				<span>1&nbsp;<b>scorer</b></span>
				<span>0&nbsp;<b>SaaS required</b></span>
			</div>
		</div>

		<div class="install cropped" data-reveal>
			<span class="cr-tl" aria-hidden="true"></span>
			<span class="cr-br" aria-hidden="true"></span>

			<!-- Tab headers -->
			<div class="install__tabs" role="tablist">
				{tabs.map((t, i) => (
					<button
						type="button"
						class={`install__tab ${i === 0 ? "is-active" : ""}`}
						data-tab={t.id}
						role="tab"
						aria-selected={i === 0 ? "true" : "false"}
						aria-controls={`install-panel-${t.id}`}
						id={`install-tab-${t.id}`}
					>
						<span class="install__tab-num font-mono">0{i + 1}</span>
						<span class="install__tab-label">{t.label}</span>
					</button>
				))}
				<div class="install__tab-rail" aria-hidden="true"></div>
			</div>

			<!-- Panels -->
			{tabs.map((t, i) => (
				<div
					class={`install__panel ${i === 0 ? "is-visible" : ""}`}
					data-panel={t.id}
					id={`install-panel-${t.id}`}
					role="tabpanel"
					aria-labelledby={`install-tab-${t.id}`}
				>
					<div class="install__panel-hd">
						<h3 class="t-h2">{t.title}</h3>
						<p class="t-body mt-2 max-w-[58ch]">{t.blurb}</p>
						<div class="install__panel-meta">
							<span class="t-label">latency</span>
							<span class="font-mono text-[11px] ink-2">{t.time}</span>
						</div>
					</div>

					<div class="install__panel-body">
						<pre class="codeblock codeblock-dark install__code">{t.code}</pre>
						{t.diff && (
							<pre class="codeblock install__diff">{t.diff}</pre>
						)}
					</div>
				</div>
			))}
		</div>

		<!-- Quick framework strip -->
		<div class="install-fw mt-8" data-reveal>
			<header class="install-fw__hd">
				<span class="t-label">// framework plugins</span>
				<span class="font-mono text-[10.5px] ink-3 ml-auto">drop-in, MIT, one line of config</span>
			</header>
			<div class="install-fw__grid">
				{["next.js", "astro", "nuxt", "sveltekit", "remix", "eleventy", "hugo", "gatsby", "rails", "django", "hono", "fastify", "wordpress"].map(name => (
					<div class="install-fw__cell">
						<span class="font-mono text-[12px] ink">{name}</span>
						<span class="font-mono text-[10.5px] sig-ok">✓</span>
					</div>
				))}
			</div>
		</div>
	</div>
</section>

<style>
	.install {
		background: var(--color-page);
		border: 1px solid var(--color-ink);
		border-radius: 4px;
		overflow: hidden;
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
	}

	.install__tabs {
		position: relative;
		display: flex;
		border-bottom: 1px solid var(--color-rule);
		background: var(--color-paper-2);
	}
	.install__tab {
		flex: 1;
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 14px 18px;
		background: transparent;
		border: none;
		border-right: 1px solid var(--color-rule);
		cursor: pointer;
		color: var(--color-ink-3);
		text-align: left;
		transition: color 140ms ease, background 140ms ease;
	}
	.install__tab:last-child { border-right: none; }
	.install__tab-num {
		font-size: 11px;
		color: var(--color-ink-3);
		letter-spacing: 0.04em;
	}
	.install__tab-label {
		font-family: var(--font-sans);
		font-size: 14px;
		font-weight: 540;
	}
	.install__tab:hover { color: var(--color-ink); background: rgba(17,17,17,0.03); }
	.install__tab.is-active {
		color: var(--color-ink);
		background: var(--color-page);
		box-shadow: inset 0 -2px 0 var(--color-mark);
	}
	.install__tab.is-active .install__tab-num { color: var(--color-mark-ink); }

	.install__panel { display: none; }
	.install__panel.is-visible { display: grid; }
	.install__panel {
		grid-template-columns: 320px 1fr;
		gap: 0;
	}
	.install__panel-hd {
		padding: 22px 22px 24px;
		border-right: 1px solid var(--color-rule);
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.install__panel-meta {
		display: flex;
		align-items: baseline;
		gap: 10px;
		border-top: 1px dashed var(--color-rule-2);
		padding-top: 12px;
		margin-top: auto;
	}
	.install__panel-body {
		padding: 18px 20px 22px;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.install__code, .install__diff { font-size: 12.5px; line-height: 1.65; margin: 0; }

	/* Framework strip */
	.install-fw {
		border: 1px solid var(--color-rule);
		border-radius: 4px;
		background: var(--color-page);
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
	}
	.install-fw__hd {
		display: flex;
		align-items: center;
		padding: 12px 16px;
		border-bottom: 1px solid var(--color-rule);
		background: var(--color-paper-2);
	}
	.install-fw__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
	}
	.install-fw__cell {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 12px 16px;
		border-right: 1px dashed var(--color-rule);
		border-bottom: 1px dashed var(--color-rule);
	}
	.install-fw__cell:nth-child(n):last-child { border-bottom: none; }

	@media (max-width: 880px) {
		.install__panel.is-visible { grid-template-columns: 1fr; }
		.install__panel-hd { border-right: none; border-bottom: 1px solid var(--color-rule); }
	}
</style>

<script>
	const tabs = document.querySelectorAll<HTMLButtonElement>('.install__tab');
	const panels = document.querySelectorAll<HTMLElement>('.install__panel');
	tabs.forEach(tab => {
		tab.addEventListener('click', () => {
			const id = tab.dataset.tab;
			tabs.forEach(t => {
				const active = t === tab;
				t.classList.toggle('is-active', active);
				t.setAttribute('aria-selected', active ? 'true' : 'false');
			});
			panels.forEach(p => p.classList.toggle('is-visible', p.dataset.panel === id));
		});
	});
</script>
