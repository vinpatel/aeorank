---
const steps = [
	{
		number: "01",
		title: "Scan",
		description: "Point AEOrank at any URL. It crawls up to 50 pages, analyzes structure, schema markup, and AI readiness signals.",
		detail: "Under 30 seconds. Zero config.",
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>`,
	},
	{
		number: "02",
		title: "Score",
		description: "Get an AEO score from 0 to 100 across 12 weighted dimensions. See exactly what's strong, what's weak, and what to fix first.",
		detail: "Grades from A+ to F.",
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
	},
	{
		number: "03",
		title: "Generate",
		description: "Get 8 files tailored to your site — llms.txt, schema.json, robots directives, FAQ markup, and more. Deploy them and watch your AI visibility climb.",
		detail: "All 8 files, ready to deploy.",
		icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
	},
];
---

<section id="how-it-works" class="section-spacing border-t border-border px-6">
	<div class="mx-auto max-w-5xl">
		<h2 class="heading-lg">How It Works</h2>
		<p class="body-lg mt-4 text-text-muted max-w-2xl">
			One command. Three steps. Eight deployment-ready files.
		</p>

		<div class="mt-10 rounded-xl bg-bg-dark border border-border-light px-6 py-4 inline-flex items-center gap-3">
			<span class="inline-flex items-center justify-center w-6 h-6 rounded bg-accent-warm/10">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="2" stroke-linecap="round"><path d="M4 17l6-6-6-6M12 19h8"/></svg>
			</span>
			<code class="font-mono text-base text-text">npx aeorank-cli scan https://your-site.com</code>
		</div>

		<div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-10">
			{
				steps.map((step) => (
					<div class="relative rounded-xl border border-border-light bg-bg p-7 card-hover">
						<div class="mb-5 inline-flex items-center justify-center w-14 h-14 rounded-xl bg-accent-warm-light">
							<Fragment set:html={step.icon} />
						</div>
						<span class="absolute top-6 right-6 text-5xl font-extrabold text-border-light leading-none font-display">{step.number}</span>
						<h3 class="heading-md">{step.title}</h3>
						<p class="mt-3 body-md text-text-muted">{step.description}</p>
						<p class="mt-3 text-sm font-semibold text-accent-warm">{step.detail}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
