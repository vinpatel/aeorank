---
---
<section id="how-it-works" class="px-6 py-20 md:py-28 border-t border-[rgba(255,255,255,0.06)]">
	<div class="mx-auto max-w-5xl">
		<p class="text-[#E8590C] text-xs font-bold uppercase tracking-[0.12em] text-center">Get started in 30 seconds</p>
		<h2 class="text-3xl md:text-4xl font-bold text-white text-center mt-3 tracking-tight leading-tight">
			Get your AI visibility score<br class="hidden md:block" /> in 30 seconds
		</h2>
		<p class="text-[#A1A1AA] text-base md:text-lg text-center max-w-2xl mx-auto mt-4 leading-relaxed">
			Pick the workflow that fits you. All three produce the same 36-criteria score.
		</p>

		<div class="grid md:grid-cols-3 gap-5 mt-14">

			<!-- GitHub App -->
			<div class="hiw-card animate-on-scroll flex flex-col" style="--accent: #E8590C; --accent-rgb: 232,89,12;">
				<div class="hiw-card__top-border" style="background: linear-gradient(90deg, #E8590C, rgba(232,89,12,0.3));"></div>
				<div class="flex flex-col flex-1 p-7 pt-6">
					<!-- Step + icon row -->
					<div class="flex items-center justify-between mb-5">
						<div class="hiw-icon" style="background: rgba(232,89,12,0.1); color: #E8590C; border-color: rgba(232,89,12,0.22);">
							<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
								<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
							</svg>
						</div>
						<span class="hiw-step" style="color: #E8590C; background: rgba(232,89,12,0.1); border-color: rgba(232,89,12,0.2);">01</span>
					</div>

					<h3 class="text-white font-semibold text-[1.0625rem] mb-2">GitHub App</h3>
					<p class="text-[#A1A1AA] text-sm leading-relaxed mb-5">
						One-click install. Every PR gets a Check Run with your AEO score. No YAML. No config.
					</p>

					<div class="hiw-pill mb-6" style="color: #E8590C; background: rgba(232,89,12,0.08); border-color: rgba(232,89,12,0.18);">
						<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
						Zero config &middot; One-click install
					</div>

					<div class="mt-auto">
						<a href="https://github.com/apps/aeorank" class="hiw-btn hiw-btn--primary" style="--btn-color: #E8590C; --btn-rgb: 232,89,12;">
							Install GitHub App
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>
				</div>
			</div>

			<!-- CLI -->
			<div class="hiw-card animate-on-scroll flex flex-col" style="--accent: #06B6D4; --accent-rgb: 6,182,212;">
				<div class="hiw-card__top-border" style="background: linear-gradient(90deg, #06B6D4, rgba(6,182,212,0.3));"></div>
				<div class="flex flex-col flex-1 p-7 pt-6">
					<!-- Step + icon row -->
					<div class="flex items-center justify-between mb-5">
						<div class="hiw-icon" style="background: rgba(6,182,212,0.1); color: #06B6D4; border-color: rgba(6,182,212,0.22);">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
								<path d="M4 17l6-5-6-5"/>
								<path d="M12 19h8"/>
							</svg>
						</div>
						<span class="hiw-step" style="color: #06B6D4; background: rgba(6,182,212,0.1); border-color: rgba(6,182,212,0.2);">02</span>
					</div>

					<h3 class="text-white font-semibold text-[1.0625rem] mb-2">CLI</h3>
					<p class="text-[#A1A1AA] text-sm leading-relaxed mb-5">
						Scan any URL from your terminal. Instant score with colored output and per-criterion recommendations.
					</p>

					<!-- Terminal code block -->
					<div class="hiw-terminal mb-6">
						<div class="hiw-terminal__bar">
							<span class="hiw-dot" style="background:#FF5F57;"></span>
							<span class="hiw-dot" style="background:#FFBD2E;"></span>
							<span class="hiw-dot" style="background:#28C840;"></span>
							<span class="hiw-terminal__label">terminal</span>
						</div>
						<div class="hiw-terminal__body">
							<span class="hiw-term-prompt">$</span>
							<span class="hiw-term-cmd"> npx aeorank-cli scan</span>
							<span class="hiw-term-url"> https://your-site.com</span>
						</div>
					</div>

					<div class="mt-auto">
						<a href="https://docs.aeorank.dev/getting-started" class="hiw-btn hiw-btn--ghost" style="--btn-color: #06B6D4; --btn-rgb: 6,182,212;">
							Read the Docs
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>
				</div>
			</div>

			<!-- GitHub Action -->
			<div class="hiw-card animate-on-scroll flex flex-col" style="--accent: #6366F1; --accent-rgb: 99,102,241;">
				<div class="hiw-card__top-border" style="background: linear-gradient(90deg, #6366F1, rgba(99,102,241,0.3));"></div>
				<div class="flex flex-col flex-1 p-7 pt-6">
					<!-- Step + icon row -->
					<div class="flex items-center justify-between mb-5">
						<div class="hiw-icon" style="background: rgba(99,102,241,0.1); color: #818CF8; border-color: rgba(99,102,241,0.22);">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
								<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/>
								<path d="M12 6v6l4 2"/>
							</svg>
						</div>
						<span class="hiw-step" style="color: #818CF8; background: rgba(99,102,241,0.1); border-color: rgba(99,102,241,0.2);">03</span>
					</div>

					<h3 class="text-white font-semibold text-[1.0625rem] mb-2">GitHub Action</h3>
					<p class="text-[#A1A1AA] text-sm leading-relaxed mb-4">
						CI pipeline control. Set fail-below thresholds. Block PRs that drop your AEO score.
					</p>

					<!-- YAML code block -->
					<div class="hiw-terminal mb-6">
						<div class="hiw-terminal__bar">
							<span class="hiw-dot" style="background:#FF5F57;"></span>
							<span class="hiw-dot" style="background:#FFBD2E;"></span>
							<span class="hiw-dot" style="background:#28C840;"></span>
							<span class="hiw-terminal__label">aeorank.yml</span>
						</div>
						<div class="hiw-terminal__body hiw-terminal__body--yaml">
							<div><span class="y-key">- uses:</span> <span class="y-val">vinpatel/aeorank-action@v1</span></div>
							<div class="pl-4"><span class="y-key">with:</span></div>
							<div class="pl-8"><span class="y-dim">url:</span> <span class="y-str">https://your-site.com</span></div>
							<div class="pl-8"><span class="y-dim">fail-below:</span> <span class="y-num">70</span></div>
						</div>
					</div>

					<div class="mt-auto">
						<a href="https://github.com/marketplace/actions/aeorank-aeo-scanner" class="hiw-btn hiw-btn--ghost" style="--btn-color: #818CF8; --btn-rgb: 99,102,241;">
							View on Marketplace
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</a>
					</div>
				</div>
			</div>

		</div>
	</div>
</section>

<style>
	/* Card shell */
	.hiw-card {
		position: relative;
		border-radius: 14px;
		border: 1px solid rgba(255,255,255,0.07);
		background: rgba(255,255,255,0.03);
		overflow: hidden;
		transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
	}
	.hiw-card:hover {
		transform: translateY(-4px);
		border-color: rgba(var(--accent-rgb), 0.28);
		box-shadow:
			0 20px 48px rgba(0,0,0,0.4),
			0 0 0 1px rgba(var(--accent-rgb), 0.12),
			0 0 60px -10px rgba(var(--accent-rgb), 0.2);
	}

	/* 3px colored top border */
	.hiw-card__top-border {
		height: 3px;
		width: 100%;
		flex-shrink: 0;
	}

	/* Subtle ambient glow sweep on hover */
	.hiw-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 120px;
		background: radial-gradient(ellipse at 50% 0%, rgba(var(--accent-rgb), 0.08) 0%, transparent 70%);
		opacity: 0;
		transition: opacity 0.3s ease;
		pointer-events: none;
	}
	.hiw-card:hover::before { opacity: 1; }

	/* Step badge */
	.hiw-step {
		font-size: 0.6875rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		padding: 0.2rem 0.55rem;
		border-radius: 6px;
		border: 1px solid;
	}

	/* Icon container */
	.hiw-icon {
		width: 40px;
		height: 40px;
		border-radius: 10px;
		border: 1px solid;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		transition: box-shadow 0.22s ease;
	}
	.hiw-card:hover .hiw-icon {
		box-shadow: 0 0 16px rgba(var(--accent-rgb), 0.3);
	}

	/* Tag pill */
	.hiw-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.6875rem;
		font-weight: 600;
		padding: 0.25rem 0.65rem;
		border-radius: 9999px;
		border: 1px solid;
	}

	/* Buttons */
	.hiw-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		width: 100%;
		padding: 0.625rem 1rem;
		border-radius: 9px;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.18s ease;
	}
	.hiw-btn--primary {
		background: var(--btn-color);
		color: white;
		border: 1px solid transparent;
	}
	.hiw-btn--primary:hover {
		opacity: 0.88;
		box-shadow: 0 4px 16px rgba(var(--btn-rgb), 0.4);
	}
	.hiw-btn--ghost {
		background: rgba(var(--btn-rgb), 0.08);
		color: var(--btn-color);
		border: 1px solid rgba(var(--btn-rgb), 0.2);
	}
	.hiw-btn--ghost:hover {
		background: rgba(var(--btn-rgb), 0.14);
		border-color: rgba(var(--btn-rgb), 0.35);
	}

	/* Terminal / code blocks */
	.hiw-terminal {
		background: #06060E;
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 9px;
		overflow: hidden;
		flex-grow: 1;
	}
	.hiw-terminal__bar {
		display: flex;
		align-items: center;
		gap: 5px;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid rgba(255,255,255,0.06);
		background: rgba(255,255,255,0.025);
	}
	.hiw-dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		opacity: 0.75;
	}
	.hiw-terminal__label {
		font-size: 0.6875rem;
		color: #4B4B57;
		font-family: var(--font-mono, 'Fira Code', monospace);
		margin-left: 4px;
	}
	.hiw-terminal__body {
		padding: 0.75rem 1rem;
		font-family: var(--font-mono, 'Fira Code', monospace);
		font-size: 0.8125rem;
		line-height: 1.5;
	}
	.hiw-terminal__body--yaml {
		font-size: 0.75rem;
		line-height: 1.85;
	}
	.hiw-term-prompt { color: #4B4B57; }
	.hiw-term-cmd    { color: #E8590C; font-weight: 600; }
	.hiw-term-url    { color: #A1A1AA; }

	/* YAML syntax */
	.y-key { color: #818CF8; }
	.y-val  { color: #34D399; }
	.y-dim  { color: #6B6B76; }
	.y-str  { color: #FCD34D; }
	.y-num  { color: #FB923C; }
</style>
