---
---
<section id="how-it-works" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-5xl">
		<p class="eyebrow text-center">Get started in 30 seconds</p>
		<h2 class="heading-lg text-center mt-3">Three ways to use AEOrank</h2>
		<p class="body-lg text-center max-w-2xl mx-auto mt-4">Pick the one that fits your workflow. All three produce the same 36-criteria score.</p>

		<div class="grid md:grid-cols-3 gap-6 mt-14">
			<!-- GitHub App -->
			<div class="card p-8 flex flex-col">
				<div class="flex items-center gap-3 mb-5">
					<div class="w-10 h-10 rounded-lg bg-accent-muted flex items-center justify-center">
						<svg width="20" height="20" viewBox="0 0 16 16" fill="#E8590C"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
					</div>
					<h3 class="heading-sm">GitHub App</h3>
				</div>
				<p class="text-text-secondary text-sm leading-relaxed mb-6">One-click install. Every PR gets a Check Run with your AEO score. No YAML. No config.</p>
				<div class="mt-auto">
					<a href="https://github.com/apps/aeorank" class="btn-primary w-full justify-center !text-sm">Install App Free →</a>
				</div>
			</div>

			<!-- CLI -->
			<div class="card p-8 flex flex-col">
				<div class="flex items-center gap-3 mb-5">
					<div class="w-10 h-10 rounded-lg bg-accent-muted flex items-center justify-center">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="2" stroke-linecap="round"><path d="M4 17l6-5-6-5"/><path d="M12 19h8"/></svg>
					</div>
					<h3 class="heading-sm">CLI</h3>
				</div>
				<p class="text-text-secondary text-sm leading-relaxed mb-4">Scan any URL from your terminal. Instant score with colored output and recommendations.</p>
				<div class="rounded-lg bg-[#0A0A0C] border border-border px-4 py-3 font-mono text-sm text-text-muted mb-6">
					<span class="text-text-muted">$</span> <span class="text-accent">npx aeorank-cli scan</span> <span class="text-text">https://your-site.com</span>
				</div>
				<div class="mt-auto">
					<a href="https://docs.aeorank.dev/getting-started" class="btn-secondary w-full justify-center !text-sm">Read the docs →</a>
				</div>
			</div>

			<!-- GitHub Action -->
			<div class="card p-8 flex flex-col">
				<div class="flex items-center gap-3 mb-5">
					<div class="w-10 h-10 rounded-lg bg-accent-muted flex items-center justify-center">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
					</div>
					<h3 class="heading-sm">GitHub Action</h3>
				</div>
				<p class="text-text-secondary text-sm leading-relaxed mb-4">CI pipeline control. Set fail-below thresholds. Block PRs that drop your AEO score.</p>
				<div class="rounded-lg bg-[#0A0A0C] border border-border px-4 py-3 font-mono text-xs text-text-muted mb-6 leading-relaxed">
					<span class="text-green">- uses:</span> vinpatel/aeorank-action@v1<br/>
					&nbsp;&nbsp;<span class="text-green">with:</span><br/>
					&nbsp;&nbsp;&nbsp;&nbsp;<span class="text-text-muted">url:</span> <span class="text-text">https://your-site.com</span>
				</div>
				<div class="mt-auto">
					<a href="https://github.com/marketplace/actions/aeorank-aeo-scanner" class="btn-secondary w-full justify-center !text-sm">View on Marketplace →</a>
				</div>
			</div>
		</div>
	</div>
</section>
