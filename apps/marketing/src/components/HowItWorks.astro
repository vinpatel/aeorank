---
const steps = [
	{
		number: "01",
		title: "Scan",
		description: "Point AEOrank at any URL. It crawls up to 50 pages, analyzes structure, schema markup, and AI readiness signals.",
		detail: "Under 30 seconds. Zero config.",
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>`,
	},
	{
		number: "02",
		title: "Score",
		description: "Get an AEO score from 0 to 100 across 12 weighted dimensions. See exactly what's strong, what's weak, and what to fix first.",
		detail: "Grades from A+ to F.",
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
	},
	{
		number: "03",
		title: "Generate",
		description: "Get 8 files tailored to your site — llms.txt, schema.json, robots directives, FAQ markup, and more. Deploy them and watch your AI visibility climb.",
		detail: "All 8 files, ready to deploy.",
		icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
	},
];
---

<section id="how-it-works" class="relative py-28 px-6 overflow-hidden">
	<!-- Subtle background radial glow -->
	<div class="absolute inset-0 pointer-events-none" aria-hidden="true">
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] rounded-full bg-accent-warm/[0.03] blur-[120px]"></div>
	</div>

	<div class="relative mx-auto max-w-5xl">
		<!-- Section header -->
		<div class="text-center">
			<span class="inline-block text-xs font-semibold tracking-[0.2em] uppercase text-accent-warm mb-4">How It Works</span>
			<h2 class="text-4xl font-bold tracking-tight text-text sm:text-5xl">
				One command. Three steps.
			</h2>
			<p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto leading-relaxed">
				Eight deployment-ready files that make your site visible to every AI engine.
			</p>
		</div>

		<!-- CLI command box -->
		<div class="mt-12 flex justify-center">
			<div class="group relative rounded-2xl border border-border/60 bg-bg-card/80 backdrop-blur-sm px-8 py-5 inline-flex items-center gap-4 transition-all duration-300 hover:border-accent-warm/30 hover:shadow-[0_0_30px_-10px_rgba(232,89,12,0.15)]">
				<div class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent-warm/10 border border-accent-warm/20">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="2" stroke-linecap="round"><path d="M4 17l6-6-6-6M12 19h8"/></svg>
				</div>
				<code class="font-mono text-base text-text/90 select-all">npx aeorank-cli scan https://your-site.com</code>
				<div class="absolute inset-0 rounded-2xl bg-accent-warm/[0.02] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
			</div>
		</div>

		<!-- Steps grid with connecting line -->
		<div class="relative mt-20">
			<!-- Connecting line (desktop only) -->
			<div class="hidden md:block absolute top-[4.5rem] left-[16.666%] right-[16.666%] h-px" aria-hidden="true">
				<div class="h-full w-full bg-gradient-to-r from-transparent via-accent-warm/25 to-transparent"></div>
				<!-- Animated dots on the line -->
				<div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-accent-warm/40"></div>
				<div class="absolute top-1/2 left-1/2 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-accent-warm/40"></div>
				<div class="absolute top-1/2 left-3/4 -translate-y-1/2 w-1.5 h-1.5 rounded-full bg-accent-warm/40"></div>
			</div>

			<div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
				{
					steps.map((step, i) => (
						<div class="group relative">
							<!-- Card -->
							<div class="relative rounded-2xl border border-border/50 bg-bg-card/60 backdrop-blur-sm p-8 h-full transition-all duration-500 hover:border-accent-warm/20 hover:bg-bg-card/90 hover:shadow-[0_8px_40px_-12px_rgba(232,89,12,0.1)]">
								<!-- Glassmorphism top highlight -->
								<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/[0.06] to-transparent rounded-t-2xl"></div>

								<!-- Step number with gradient glow -->
								<div class="relative mb-6">
									<span class="text-[5rem] font-extrabold leading-none tracking-tighter bg-gradient-to-b from-border/80 to-border/20 bg-clip-text text-transparent select-none transition-all duration-500 group-hover:from-accent-warm/40 group-hover:to-accent-warm/10">{step.number}</span>
									<!-- Glow behind number on hover -->
									<div class="absolute -top-2 -left-2 w-24 h-24 rounded-full bg-accent-warm/[0.05] blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
								</div>

								<!-- Icon in glowing circle -->
								<div class="relative inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-accent-warm/10 border border-accent-warm/15 mb-5 transition-all duration-300 group-hover:bg-accent-warm/15 group-hover:border-accent-warm/25 group-hover:shadow-[0_0_20px_-4px_rgba(232,89,12,0.2)]">
									<Fragment set:html={step.icon} />
								</div>

								<!-- Content -->
								<h3 class="text-xl font-bold text-text tracking-tight">{step.title}</h3>
								<p class="mt-3 text-[0.938rem] leading-relaxed text-text-muted">{step.description}</p>
								<p class="mt-4 text-sm font-semibold text-accent-warm tracking-wide">{step.detail}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
