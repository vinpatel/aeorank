---
---

<section id="get-started" class="section-spacing border-t border-border px-6 relative overflow-hidden">
	<div class="blob bg-accent-warm w-[400px] h-[400px] -bottom-[200px] right-[10%] absolute"></div>

	<div class="mx-auto max-w-3xl text-center relative">
		<h2 class="heading-lg">Ready to See Your Score?</h2>
		<p class="body-lg mt-4 text-text-muted">
			One command. 30 seconds. No account required.
		</p>
		<div class="mx-auto mt-10 max-w-xl rounded-xl bg-[#1a1a1a] p-5 flex items-center justify-center gap-3 shadow-lg">
			<span class="inline-flex items-center justify-center w-6 h-6 rounded bg-accent-warm/20">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="2" stroke-linecap="round"><path d="M4 17l6-6-6-6M12 19h8"/></svg>
			</span>
			<code class="font-mono text-base text-[#FAF9F7]">npx aeorank-cli scan https://your-site.com</code>
		</div>
		<div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
			<a href="https://app.aeorank.dev/sign-up" class="btn-primary">
				Read the Quick Start Guide
				<svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="ml-2"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
			</a>
			<a href="https://github.com/vinpatel/aeorank" class="btn-secondary">
				View on GitHub
			</a>
			<a href="https://app.aeorank.dev" class="text-sm font-medium text-text-muted transition-colors hover:text-accent-warm">Open Dashboard →</a>
		</div>
		<p class="mt-6 text-sm text-text-muted">
			Free. Open source. MIT licensed.
		</p>
	</div>
</section>
