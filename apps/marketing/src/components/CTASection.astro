<section id="get-started" class="section-spacing border-t border-border px-6">
	<div class="mx-auto max-w-3xl text-center">
		<h2 class="heading-lg">Ready to See Your Score?</h2>
		<p class="body-lg mt-4 text-text-muted">
			One command. 30 seconds. No account required.
		</p>
		<div class="mx-auto mt-10 max-w-xl rounded-lg bg-accent p-5 flex items-center justify-center">
			<code class="font-mono text-base text-bg">$ npx aeorank scan https://your-site.com</code>
		</div>
		<div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
			<a href="https://docs.aeorank.dev/getting-started/" class="btn-primary">
				Read the Quick Start Guide
			</a>
			<a href="https://github.com/aeorank/aeorank" class="btn-secondary">
				View on GitHub
			</a>
			<a href="https://app.aeorank.dev" class="text-sm font-medium text-text-muted transition-colors hover:text-text">Open Dashboard →</a>
		</div>
		<p class="mt-6 text-sm text-text-muted">
			Free. Open source. MIT licensed.
		</p>
	</div>
</section>
