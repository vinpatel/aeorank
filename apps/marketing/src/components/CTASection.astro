<section id="get-started" class="border-t border-border px-6 py-24">
	<div class="mx-auto max-w-6xl text-center">
		<h2 class="text-4xl font-bold md:text-5xl">Ready to See Your Score?</h2>
		<p class="mt-4 text-lg text-text-muted">
			One command. 30 seconds. No account required.
		</p>
		<div class="mx-auto mt-8 max-w-lg rounded-sm bg-accent p-4">
			<code class="font-mono text-bg">npx aeorank scan https://your-site.com</code>
		</div>
		<a
			href="https://docs.aeorank.dev/getting-started/"
			class="mt-8 inline-block bg-accent px-6 py-3 text-base font-medium text-bg rounded-sm"
		>
			Read the Quick Start Guide
		</a>
		<p class="mt-4 text-sm text-text-muted">
			Free. Open source. No account required.
		</p>
	</div>
</section>
