---
---
<section id="competitors" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-5xl">
		<p class="eyebrow text-center">Why switch</p>
		<h2 class="heading-lg text-center mt-3">They charge $129/mo to <em>watch</em>.<br/>We fix it for free.</h2>
		<p class="body-lg text-center max-w-2xl mx-auto mt-4">Every AEO tool on the market is a monitoring dashboard for marketers. AEOrank is the only tool that scores, diagnoses, <em>and generates the fix</em> — in your terminal, your CI, your framework.</p>

		<div class="overflow-x-auto mt-14">
			<table class="w-full text-sm border-separate border-spacing-0">
				<thead>
					<tr>
						<!-- empty label cell -->
						<th class="text-left py-5 px-5 w-[210px] rounded-tl-xl bg-[rgba(255,255,255,0.02)] border-t border-l border-border"></th>

						<!-- AEOrank — highlighted -->
						<th class="py-5 px-4 text-center min-w-[130px] bg-[rgba(232,89,12,0.08)] border-t border-l border-r border-[rgba(232,89,12,0.25)] relative">
							<!-- top glow bar -->
							<div class="absolute top-0 left-0 right-0 h-[2px] rounded-t-xl bg-gradient-to-r from-transparent via-accent to-transparent"></div>
							<span class="text-accent font-bold text-base tracking-tight">AEOrank</span><br/>
							<span class="inline-block mt-1.5 text-xs font-semibold text-green bg-green/10 border border-green/20 rounded-full px-2.5 py-0.5">From $0/mo</span>
						</th>

						<!-- competitors -->
						<th class="py-5 px-4 text-center text-text-muted min-w-[110px] bg-[rgba(255,255,255,0.02)] border-t border-l border-border">
							<span class="font-medium text-[0.8125rem]">Otterly.ai</span><br/>
							<span class="text-xs opacity-60 mt-0.5 inline-block">$29–99/mo</span>
						</th>
						<th class="py-5 px-4 text-center text-text-muted min-w-[110px] bg-[rgba(255,255,255,0.02)] border-t border-l border-border">
							<span class="font-medium text-[0.8125rem]">Scrunch AI</span><br/>
							<span class="text-xs opacity-60 mt-0.5 inline-block">$100–500/mo</span>
						</th>
						<th class="py-5 px-4 text-center text-text-muted min-w-[110px] bg-[rgba(255,255,255,0.02)] border-t border-l border-border">
							<span class="font-medium text-[0.8125rem]">Ahrefs</span><br/>
							<span class="text-xs opacity-60 mt-0.5 inline-block">$99+/mo</span>
						</th>
						<th class="py-5 px-4 text-center text-text-muted min-w-[110px] bg-[rgba(255,255,255,0.02)] border-t border-l border-r border-border rounded-tr-xl">
							<span class="font-medium text-[0.8125rem]">Semrush</span><br/>
							<span class="text-xs opacity-60 mt-0.5 inline-block">$129+/mo</span>
						</th>
					</tr>
				</thead>
				<tbody>
					{[
						{ label: "Generates AI files",       aeo: "9 files",  others: [false, false, false, false] },
						{ label: "Open source",              aeo: "MIT",      others: [false, false, false, false] },
						{ label: "CLI + CI pipeline",        aeo: "✓ Both",   others: [false, false, false, false] },
						{ label: "Framework plugins",        aeo: "13",       others: ["0", "0", "0", "0"]       },
						{ label: "Scoring criteria",         aeo: "36",       others: ["25", "—", "—", "—"]      },
						{ label: "Deterministic scoring",    aeo: "✓",        others: ["—", "—", "—", "—"]       },
						{ label: "GitHub App + Action",      aeo: "✓ Both",   others: [false, false, false, false] },
						{ label: "Self-hostable",            aeo: "✓",        others: [false, false, false, false] },
					].map((row, i) => (
						<tr class:list={[i % 2 === 0 ? "bg-[rgba(255,255,255,0.015)]" : "bg-transparent"]}>
							<td class:list={["py-4 px-5 font-medium text-text border-b border-l border-border text-[0.875rem]", i === 7 && "rounded-bl-xl"]}>{row.label}</td>

							<!-- AEOrank cell -->
							<td class="py-4 px-4 text-center bg-[rgba(232,89,12,0.06)] border-b border-l border-r border-[rgba(232,89,12,0.18)]">
								<span class="inline-flex items-center justify-center gap-1.5 text-green font-semibold text-sm">
									<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green/15 text-green text-[10px] font-bold">✓</span>
									{row.aeo}
								</span>
							</td>

							{row.others.map((val, j) => (
								<td class:list={[
									"py-4 px-4 text-center border-b border-l border-border text-sm",
									j === 3 && "border-r",
									i === 7 && j === 3 && "rounded-br-xl"
								]}>
									{val === false ? (
										<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-white/[0.04] text-[#71717A] text-[11px]">✗</span>
									) : (
										<span class="text-text-muted">{val}</span>
									)}
								</td>
							))}
						</tr>
					))}
				</tbody>
			</table>
		</div>

		<!-- winner callout -->
		<div class="mt-8 flex items-center justify-center gap-3">
			<div class="h-px flex-1 max-w-[120px] bg-gradient-to-r from-transparent to-border"></div>
			<p class="text-text-muted text-sm text-center">Monitoring tools tell you <em>what happened</em>. AEOrank tells you <em>what to do</em> — and does it for you.</p>
			<div class="h-px flex-1 max-w-[120px] bg-gradient-to-l from-transparent to-border"></div>
		</div>
	</div>
</section>

<style>
	/* Keep accent column visually connected top-to-bottom */
	thead tr th:nth-child(2) {
		box-shadow: 0 -1px 0 0 rgba(232,89,12,0.25);
	}
</style>
