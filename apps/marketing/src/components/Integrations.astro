---
---
<section id="competitors" class="px-6 py-20 md:py-28 border-t border-border scroll-mt-20">
	<div class="mx-auto max-w-5xl">
		<p class="eyebrow text-center">Why switch</p>
		<h2 class="heading-lg text-center mt-3">Profound raised $58M to <em>monitor</em>.<br/>We built the tool that <em class="gradient-text-accent not-italic">fixes it</em>.</h2>
		<p class="body-lg text-center max-w-2xl mx-auto mt-4">Every AEO tool on the market is a monitoring dashboard. They tell you what's wrong — for $99–$399/mo. AEOrank scores, diagnoses, and generates the actual fix files. Starting at $0.</p>

		<!-- Comparison table -->
		<div class="overflow-x-auto mt-14 rounded-2xl border border-border">
			<table class="w-full text-sm border-separate border-spacing-0">
				<thead>
					<tr>
						<th class="text-left py-5 px-5 w-[200px] bg-[rgba(255,255,255,0.02)] border-b border-border rounded-tl-2xl"></th>

						<!-- AEOrank — highlighted -->
						<th class="py-5 px-4 text-center min-w-[130px] bg-[rgba(232,89,12,0.07)] border-b border-l border-[rgba(232,89,12,0.2)] relative">
							<div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
							<span class="text-accent font-bold text-[0.9375rem] tracking-tight">AEOrank</span><br/>
							<span class="inline-block mt-1.5 text-[11px] font-semibold text-green bg-green/10 border border-green/20 rounded-full px-2.5 py-0.5">From $0/mo</span>
						</th>

						<!-- Profound -->
						<th class="py-5 px-4 text-center text-text-muted min-w-[115px] bg-[rgba(255,255,255,0.02)] border-b border-l border-border">
							<span class="font-semibold text-[0.8125rem] text-text-secondary">Profound</span><br/>
							<span class="text-[11px] opacity-55 mt-0.5 inline-block">$99–399/mo</span>
						</th>

						<th class="py-5 px-4 text-center text-text-muted min-w-[105px] bg-[rgba(255,255,255,0.02)] border-b border-l border-border">
							<span class="font-semibold text-[0.8125rem] text-text-secondary">Otterly.ai</span><br/>
							<span class="text-[11px] opacity-55 mt-0.5 inline-block">$29–99/mo</span>
						</th>

						<th class="py-5 px-4 text-center text-text-muted min-w-[105px] bg-[rgba(255,255,255,0.02)] border-b border-l border-border">
							<span class="font-semibold text-[0.8125rem] text-text-secondary">Scrunch AI</span><br/>
							<span class="text-[11px] opacity-55 mt-0.5 inline-block">$100–500/mo</span>
						</th>

						<th class="py-5 px-4 text-center text-text-muted min-w-[105px] bg-[rgba(255,255,255,0.02)] border-b border-l border-border rounded-tr-2xl">
							<span class="font-semibold text-[0.8125rem] text-text-secondary">Semrush</span><br/>
							<span class="text-[11px] opacity-55 mt-0.5 inline-block">$129+/mo</span>
						</th>
					</tr>
				</thead>
				<tbody>
					{[
						{ label: "Generates AI fix files",    aeo: "9 files",  others: [false, false, false, false] },
						{ label: "Open source / self-host",   aeo: "MIT",      others: [false, false, false, false] },
						{ label: "CLI + CI pipeline",         aeo: "✓ Both",   others: [false, false, false, false] },
						{ label: "Framework plugins",         aeo: "13",       others: ["0", "0", "0", "0"]       },
						{ label: "Scoring criteria",          aeo: "36",       others: ["—", "25", "—", "—"]      },
						{ label: "Deterministic (no LLM)",    aeo: "✓",        others: [false, "—", "—", "—"]     },
						{ label: "GitHub App + Action",       aeo: "✓ Both",   others: [false, false, false, false] },
						{ label: "Prompt volume data",        aeo: false,      others: ["✓", false, false, false] },
						{ label: "AI content generation",     aeo: false,      others: ["✓", false, false, false] },
						{ label: "Free tier available",       aeo: "✓",        others: [false, false, false, false] },
						{ label: "Entry price",               aeo: "$0",       others: ["$99", "$29", "$100", "$129"] },
						{ label: "Full features price",       aeo: "$29/mo",   others: ["$399/mo", "$99/mo", "$500/mo", "$129/mo"] },
					].map((row, i) => (
						<tr class:list={["table-row", i % 2 === 0 ? "bg-[rgba(255,255,255,0.012)]" : "bg-transparent"]}>
							<td class:list={[
								"py-3.5 px-5 font-medium text-text-secondary border-b border-border text-[0.8125rem]",
								i === 11 ? "border-b-0 rounded-bl-2xl" : ""
							]}>{row.label}</td>

							<!-- AEOrank cell -->
							<td class:list={[
								"py-3.5 px-4 text-center bg-[rgba(232,89,12,0.05)] border-l border-[rgba(232,89,12,0.15)]",
								i === 11 ? "border-b-0" : "border-b border-b-[rgba(232,89,12,0.1)]"
							]}>
								{row.aeo === false ? (
									<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-white/[0.04] text-[#52525B] text-[11px]">✗</span>
								) : (
									<span class="inline-flex items-center justify-center gap-1.5 text-green font-semibold text-[0.8125rem]">
										<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green/15 text-green text-[10px] font-bold flex-shrink-0">✓</span>
										{row.aeo}
									</span>
								)}
							</td>

							{row.others.map((val, j) => (
								<td class:list={[
									"py-3.5 px-4 text-center border-l border-border text-[0.8125rem]",
									i === 11 ? (j === 3 ? "border-b-0 rounded-br-2xl" : "border-b-0") : "border-b border-border",
								]}>
									{val === false ? (
										<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-white/[0.04] text-[#52525B] text-[11px]">✗</span>
									) : val === "✓" ? (
										<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green/12 text-green text-[10px] font-bold">✓</span>
									) : (
										<span class="text-text-muted">{val}</span>
									)}
								</td>
							))}
						</tr>
					))}
				</tbody>
			</table>
		</div>

		<!-- Honest positioning -->
		<div class="mt-10 max-w-2xl mx-auto">
			<div class="rounded-xl border border-border bg-white/[0.02] p-6 space-y-4">
				<div class="flex items-start gap-3">
					<div class="w-1 self-stretch rounded-full bg-[#6366F1]/40 flex-shrink-0 mt-0.5"></div>
					<div>
						<p class="text-[0.8125rem] text-text-secondary leading-relaxed">
							<strong class="text-text font-semibold">What Profound does better:</strong> Prompt volume data (how many people ask AI about your category) and AI content generation. If you need demand signals and auto-generated articles, Profound is excellent — at $399/mo.
						</p>
					</div>
				</div>
				<div class="flex items-start gap-3">
					<div class="w-1 self-stretch rounded-full bg-accent/40 flex-shrink-0 mt-0.5"></div>
					<div>
						<p class="text-[0.8125rem] text-text-secondary leading-relaxed">
							<strong class="text-text font-semibold">What AEOrank does that nobody else does:</strong> Generates the 9 actual files AI engines look for (llms.txt, ai.txt, schema.json, etc.), runs in your CI pipeline, has 13 framework plugins, and is open source. Profound monitors. AEOrank fixes. Both are useful. We're just 14&times; cheaper.
						</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
