		<!-- IDE-style code snippet -->
		<div class="mt-14 max-w-lg mx-auto rounded-xl overflow-hidden border border-border shadow-2xl shadow-black/60 animate-on-scroll">
			<!-- Title bar -->
			<div class="flex items-center gap-2 px-4 py-3 bg-[#131316] border-b border-white/[0.06]">
				<span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
				<span class="w-3 h-3 rounded-full bg-[#FFBD2E]"></span>
				<span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
				<div class="flex-1 flex justify-center">
					<span class="text-xs text-text-muted font-mono bg-white/[0.04] border border-white/[0.07] rounded px-3 py-0.5">next.config.ts</span>
				</div>
			</div>
			<!-- Code body -->
			<div class="bg-[#0A0A0D] font-mono text-sm leading-7 overflow-x-auto">
				<table class="w-full border-collapse">
					<tbody>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs align-top pt-5 tabular-nums">1</td>
							<td class="pr-5 pt-5"><span class="text-[#7DD3FC]">import</span> <span class="text-text">{'{ withAeorank }'}</span> <span class="text-[#7DD3FC]">from</span> <span class="text-[#86EFAC]">"@aeorank/next"</span><span class="text-[#9898A6]">;</span></td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">2</td>
							<td class="pr-5">&nbsp;</td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">3</td>
							<td class="pr-5"><span class="text-[#7DD3FC]">export default</span> <span class="text-[#FDE68A]">withAeorank</span><span class="text-[#9898A6]">({'('}{'{'}</span></td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">4</td>
							<td class="pr-5 pl-6"><span class="text-[#F9A8D4]">siteName</span><span class="text-[#9898A6]">: </span><span class="text-[#86EFAC]">"My Site"</span><span class="text-[#9898A6]">,</span></td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">5</td>
							<td class="pr-5 pl-6"><span class="text-[#F9A8D4]">siteUrl</span><span class="text-[#9898A6]">: </span><span class="text-[#86EFAC]">"https://example.com"</span><span class="text-[#9898A6]">,</span></td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">6</td>
							<td class="pr-5 pl-6"><span class="text-[#F9A8D4]">description</span><span class="text-[#9898A6]">: </span><span class="text-[#86EFAC]">"What my site does."</span><span class="text-[#9898A6]">,</span></td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">7</td>
							<td class="pr-5"><span class="text-[#9898A6]">{'}'}{')'};</span></td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs tabular-nums">8</td>
							<td class="pr-5">&nbsp;</td>
						</tr>
						<tr>
							<td class="select-none text-right pr-4 pl-4 text-[#3F3F46] w-8 text-xs pb-5 tabular-nums">9</td>
							<td class="pr-5 pb-5"><span class="text-[#4B5563] italic">{'// → All 9 AEO files served at your site root'}</span></td>
						</tr>
					</tbody>
				</table>
			</div>
			<!-- Status bar -->
			<div class="flex items-center justify-between px-4 py-2 bg-[#E8590C] text-white text-[11px] font-mono">
				<span class="opacity-80">TypeScript · next.config.ts</span>
				<span class="flex items-center gap-1.5 font-semibold">
					<span class="inline-block w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
					9 files generated
				</span>
			</div>
		</div>

		<!-- Supporting stats -->
		<div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
			<div class="flex items-center gap-2 text-sm text-text-muted">
				<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green/15 text-green text-[10px] font-bold">✓</span>
				3 lines of config
			</div>
			<div class="w-px h-4 bg-border hidden sm:block"></div>
			<div class="flex items-center gap-2 text-sm text-text-muted">
				<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green/15 text-green text-[10px] font-bold">✓</span>
				9 files generated
			</div>
			<div class="w-px h-4 bg-border hidden sm:block"></div>
			<div class="flex items-center gap-2 text-sm text-text-muted">
				<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green/15 text-green text-[10px] font-bold">✓</span>
				Every AI engine covered
			</div>
		</div>
	</div>
</section>

<style>
	.framework-card {
		display: inline-flex;
		align-items: center;
		gap: 0.625rem;
		padding: 0.6875rem 1.125rem;
		background: rgba(255,255,255,0.03);
		border: 1px solid rgba(255,255,255,0.07);
		border-radius: 10px;
		color: var(--color-text-muted);
		transition: all 0.2s ease;
		text-decoration: none;
		position: relative;
		overflow: hidden;
	}

	.framework-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(145deg, rgba(255,255,255,0.04) 0%, transparent 60%);
		pointer-events: none;
	}

	.framework-card:hover {
		color: var(--color-text);
		background: rgba(255,255,255,0.06);
		border-color: rgba(255,255,255,0.14);
		transform: translateY(-2px);
		box-shadow: 0 4px 20px rgba(0,0,0,0.3);
	}

	.framework-card__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 22px;
		height: 22px;
		color: inherit;
		transition: color 0.2s ease;
	}

	.framework-card__name {
		font-size: 0.8125rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		white-space: nowrap;
	}
</style>
