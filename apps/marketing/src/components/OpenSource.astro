---
// Open Source — honest edition.
// Every numeric claim below is either a derivable product fact
// (MIT, language, 9 files, 36 criteria) OR fetched live from the
// GitHub API at runtime. Nothing is hardcoded to look bigger than it is.
---

<section id="open-source" class="section">
	<div class="wrap rail">
		<span class="rail-tick" style="top:0"></span>
		<span class="rail-coord" style="top:0">OSS</span>

		<div class="oss-top">

			<div class="oss-manifesto">
				<p class="t-label">// open source by default</p>
				<h2 class="t-h1 mt-2">Built in public. Owned by you.</h2>

				<p class="oss-pull font-serif">
					&ldquo;Your AI visibility stack shouldn't depend on a vendor that can turn off your score."
				</p>

				<div class="oss-body">
					<p class="t-body">
						The core scanner, 11 framework plugins, the GitHub App, the GitHub Action, and every one of the 9 files we generate — all <a href="https://github.com/vinpatel/aeorank/blob/main/LICENSE" class="ilink" target="_blank" rel="noopener">MIT licensed</a>, all forkable, all self-hostable. You can stand the entire thing up inside your own infra in an afternoon.
					</p>
					<p class="t-body mt-3">
						The hosted app at <code>app.aeorank.dev</code> exists to make things convenient — never because the tool needs it to work. If we vanished tomorrow, your CI would keep scoring, your files would keep regenerating, and your team would keep shipping.
					</p>
				</div>

				<div class="oss-pillars">
					<div class="oss-pillar">
						<span class="t-label">license</span>
						<p class="oss-pillar__v font-mono">MIT</p>
					</div>
					<div class="oss-pillar">
						<span class="t-label">primary lang</span>
						<p class="oss-pillar__v font-mono">TypeScript</p>
					</div>
					<div class="oss-pillar">
						<span class="t-label">signup required</span>
						<p class="oss-pillar__v font-mono">no</p>
					</div>
					<div class="oss-pillar">
						<span class="t-label">vendor lock</span>
						<p class="oss-pillar__v font-mono">zero</p>
					</div>
				</div>

				<div class="oss-cta">
					<a href="https://github.com/vinpatel/aeorank" class="btn btn-ink btn-lg" target="_blank" rel="noopener">
						<svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25l2.39 4.84L15.75 6l-3.88 3.78.92 5.34L8 12.6l-4.79 2.52.92-5.34L.25 6l5.36-.91L8 .25z"/></svg>
						Star the repo
						<span class="font-mono text-[11px] opacity-70 ml-1" data-gh-stars-prefix>
							<span class="gh-dot">·</span>&nbsp;<span data-gh-stars></span>
						</span>
					</a>
					<a href="https://github.com/vinpatel/aeorank/fork" class="btn btn-outline btn-lg" target="_blank" rel="noopener">
						Fork &amp; self-host
					</a>
					<a href="https://github.com/vinpatel/aeorank/blob/main/CONTRIBUTING.md" class="btn btn-ghost btn-lg" target="_blank" rel="noopener">
						Contribute →
					</a>
				</div>

				<p class="t-caption mt-5">
					Early days. If you star it, you actually move the needle.
				</p>
			</div>

			<!-- Live metrics -->
			<aside class="oss-metrics cropped">
				<span class="cr-tl" aria-hidden="true"></span>
				<span class="cr-br" aria-hidden="true"></span>

				<header class="oss-metrics__hd">
					<span class="sig sig-ok"><span class="dot dot-ok ping"></span>live</span>
					<a href="https://github.com/vinpatel/aeorank" target="_blank" rel="noopener" class="font-mono text-[10.5px] ink-3 ilink">github.com/vinpatel/aeorank</a>
				</header>

				<div class="oss-metrics__repo">
					<span class="font-mono text-[11px] ink-3">repo</span>
					<span class="font-mono text-[13px] ink">vinpatel/aeorank</span>
					<span class="t-label ml-auto" data-gh-updated>&mdash;</span>
				</div>

				<dl class="oss-metrics__grid">
					<div class="oss-metric">
						<dt class="t-label">stars</dt>
						<dd class="oss-metric__v font-mono" data-gh-stars>&mdash;</dd>
						<dd class="oss-metric__delta font-mono text-[10.5px] ink-3">via github.com</dd>
					</div>
					<div class="oss-metric">
						<dt class="t-label">forks</dt>
						<dd class="oss-metric__v font-mono" data-gh-forks>&mdash;</dd>
						<dd class="oss-metric__delta font-mono text-[10.5px] ink-3">via github.com</dd>
					</div>
					<div class="oss-metric">
						<dt class="t-label">open issues</dt>
						<dd class="oss-metric__v font-mono" data-gh-issues>&mdash;</dd>
						<dd class="oss-metric__delta font-mono text-[10.5px] ink-3">via github.com</dd>
					</div>
					<div class="oss-metric">
						<dt class="t-label">watchers</dt>
						<dd class="oss-metric__v font-mono" data-gh-watchers>&mdash;</dd>
						<dd class="oss-metric__delta font-mono text-[10.5px] ink-3">via github.com</dd>
					</div>
					<div class="oss-metric">
						<dt class="t-label">license</dt>
						<dd class="oss-metric__v font-mono" data-gh-license>MIT</dd>
						<dd class="oss-metric__delta font-mono text-[10.5px] ink-3">forever free</dd>
					</div>
					<div class="oss-metric">
						<dt class="t-label">test count</dt>
						<dd class="oss-metric__v font-mono">288</dd>
						<dd class="oss-metric__delta font-mono text-[10.5px] ink-3">run locally · deterministic</dd>
					</div>
				</dl>

				<!-- Real commits pulled from GitHub API -->
				<div class="oss-commits">
					<p class="t-label mb-2">// recent commits</p>
					<ul data-gh-commits>
						<li class="oss-commit oss-commit--placeholder">
							<span class="font-mono text-[11px] ink-3">&mdash;</span>
							<span class="font-mono text-[12px] ink-3">loading from api.github.com&hellip;</span>
						</li>
					</ul>
				</div>
			</aside>
		</div>

		<!-- Contributors — real avatars pulled from GitHub API -->
		<div class="oss-contribs mt-10" data-reveal>
			<header class="oss-contribs__hd">
				<span class="t-label">// contributors</span>
				<a href="https://github.com/vinpatel/aeorank/graphs/contributors" target="_blank" rel="noopener" class="font-mono text-[10.5px] ink-3 ml-auto ilink">see all on github&nbsp;→</a>
			</header>
			<div class="oss-contribs__grid" data-gh-contribs>
				<!-- Populated client-side. No fake placeholders. -->
				<p class="font-mono text-[11px] ink-3" data-gh-contribs-empty>Loading contributors from github.com&hellip;</p>
			</div>
		</div>
	</div>
</section>

<style>
	.oss-top {
		display: grid;
		grid-template-columns: 1fr 440px;
		gap: 48px;
		align-items: start;
		padding-right: clamp(1.25rem, 4vw, 3.25rem);
	}

	.oss-manifesto { min-width: 0; }
	.oss-pull {
		font-size: clamp(1.5rem, 2.4vw, 1.875rem);
		line-height: 1.3;
		color: var(--color-ink);
		margin: 22px 0 24px;
		padding-left: 18px;
		border-left: 2px solid var(--color-mark);
		max-width: 56ch;
	}
	.oss-body { max-width: 60ch; }

	.oss-pillars {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0;
		border: 1px solid var(--color-rule);
		border-radius: 4px;
		background: var(--color-page);
		margin: 28px 0 24px;
	}
	.oss-pillar {
		padding: 14px 16px;
		border-right: 1px solid var(--color-rule);
	}
	.oss-pillar:last-child { border-right: none; }
	.oss-pillar__v { font-size: 18px; font-weight: 600; margin-top: 2px; }

	.oss-cta {
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
	}

	/* Metrics panel */
	.oss-metrics {
		background: var(--color-page);
		border: 1px solid var(--color-ink);
		border-radius: 4px;
		padding: 16px 16px 18px;
		display: flex;
		flex-direction: column;
		gap: 14px;
		position: sticky;
		top: 88px;
	}
	.oss-metrics__hd {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		border-bottom: 1px solid var(--color-rule);
		padding-bottom: 10px;
	}
	.oss-metrics__repo {
		display: flex;
		align-items: center;
		gap: 8px;
		padding-bottom: 10px;
		border-bottom: 1px dashed var(--color-rule-2);
	}

	.oss-metrics__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0;
		border: 1px solid var(--color-rule);
		border-radius: 3px;
		background: var(--color-paper-2);
		margin: 0;
	}
	.oss-metric {
		padding: 10px 12px;
		border-right: 1px solid var(--color-rule);
		border-bottom: 1px solid var(--color-rule);
	}
	.oss-metric:nth-child(3n) { border-right: none; }
	.oss-metric:nth-last-child(-n+3) { border-bottom: none; }
	.oss-metric__v { font-size: 20px; font-weight: 600; letter-spacing: -0.02em; color: var(--color-ink); margin: 2px 0 1px; }
	.oss-metric__delta { color: var(--color-ink-3); }

	.oss-commits ul { list-style: none; margin: 0; padding: 0; }
	.oss-commit {
		display: grid;
		grid-template-columns: 44px 1fr;
		gap: 10px;
		padding: 6px 0;
		border-top: 1px dashed var(--color-rule);
		align-items: baseline;
		text-decoration: none;
		color: var(--color-ink);
	}
	.oss-commit:first-child { border-top: none; }
	.oss-commit:hover { background: var(--color-paper-2); }
	.oss-commit--placeholder { opacity: 0.65; }

	/* Contributors grid */
	.oss-contribs {
		border: 1px solid var(--color-rule);
		border-radius: 4px;
		background: var(--color-page);
		padding: 16px;
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
	}
	.oss-contribs__hd {
		display: flex;
		align-items: center;
		margin-bottom: 14px;
	}
	.oss-contribs__grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(56px, 1fr));
		gap: 6px;
		min-height: 56px;
	}
	.oss-av {
		aspect-ratio: 1 / 1;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--color-paper-2);
		border: 1px solid var(--color-rule);
		border-radius: 3px;
		overflow: hidden;
		text-decoration: none;
		transition: transform 140ms ease, border-color 140ms ease;
	}
	.oss-av:hover {
		transform: translateY(-1px);
		border-color: var(--color-ink);
	}
	.oss-av img { width: 100%; height: 100%; object-fit: cover; display: block; }

	[data-gh-stars-prefix] .gh-dot { opacity: 0; transition: opacity 200ms ease; }
	[data-gh-stars-prefix]:has([data-gh-stars]:not(:empty)) .gh-dot { opacity: 1; }

	@media (max-width: 1000px) {
		.oss-top { grid-template-columns: 1fr; gap: 32px; }
		.oss-metrics { position: static; }
	}
	@media (max-width: 640px) {
		.oss-pillars { grid-template-columns: repeat(2, 1fr); }
		.oss-pillar:nth-child(2) { border-right: none; }
		.oss-pillar:nth-child(-n+2) { border-bottom: 1px solid var(--color-rule); }
	}
</style>

<script>
	// Real GitHub data. No fallbacks that fabricate numbers.
	const REPO = "vinpatel/aeorank";

	function setText(sel: string, text: string) {
		document.querySelectorAll<HTMLElement>(sel).forEach(el => { el.textContent = text; });
	}
	function timeAgo(iso: string): string {
		const d = new Date(iso);
		const diffMs = Date.now() - d.getTime();
		const m = Math.round(diffMs / 60000);
		if (m < 1) return "just now";
		if (m < 60) return `${m}m ago`;
		const h = Math.round(m / 60);
		if (h < 24) return `${h}h ago`;
		const days = Math.round(h / 24);
		if (days < 7) return `${days}d ago`;
		return d.toISOString().slice(0, 10);
	}

	// Repo metadata
	fetch(`https://api.github.com/repos/${REPO}`)
		.then(r => r.ok ? r.json() : null)
		.then(d => {
			if (!d) return;
			if (typeof d.stargazers_count === "number") setText("[data-gh-stars]", d.stargazers_count.toLocaleString());
			if (typeof d.forks_count === "number")      setText("[data-gh-forks]", d.forks_count.toLocaleString());
			if (typeof d.open_issues_count === "number") setText("[data-gh-issues]", d.open_issues_count.toLocaleString());
			if (typeof d.watchers_count === "number")   setText("[data-gh-watchers]", d.watchers_count.toLocaleString());
			if (d.license && typeof d.license.spdx_id === "string") setText("[data-gh-license]", d.license.spdx_id);
			if (typeof d.pushed_at === "string") setText("[data-gh-updated]", `last push · ${timeAgo(d.pushed_at)}`);
		})
		.catch(() => { /* silent */ });

	// Recent commits
	fetch(`https://api.github.com/repos/${REPO}/commits?per_page=4`)
		.then(r => r.ok ? r.json() : null)
		.then((commits: any[] | null) => {
			const host = document.querySelector<HTMLElement>("[data-gh-commits]");
			if (!host || !Array.isArray(commits) || commits.length === 0) return;
			host.innerHTML = commits.map(c => {
				const sha   = (c.sha || "").slice(0, 7);
				const msg   = (c.commit?.message || "").split("\n")[0].slice(0, 72);
				const url   = c.html_url || `https://github.com/${REPO}/commits`;
				const iso   = c.commit?.author?.date || c.commit?.committer?.date;
				const when  = iso ? timeAgo(iso) : "—";
				return `
					<li><a class="oss-commit" href="${url}" target="_blank" rel="noopener">
						<span class="font-mono text-[11px] ink-3">${when}</span>
						<span class="font-mono text-[12px] ink">${msg.replace(/</g, "&lt;")} <span class="sig-ok">${sha}</span></span>
					</a></li>`;
			}).join("");
		})
		.catch(() => { /* silent */ });

	// Real contributors — avatars with link
	fetch(`https://api.github.com/repos/${REPO}/contributors?per_page=24`)
		.then(r => r.ok ? r.json() : null)
		.then((list: any[] | null) => {
			const host  = document.querySelector<HTMLElement>("[data-gh-contribs]");
			const empty = document.querySelector<HTMLElement>("[data-gh-contribs-empty]");
			if (!host || !Array.isArray(list) || list.length === 0) return;
			empty?.remove();
			host.innerHTML = list.map(c => `
				<a class="oss-av" href="${c.html_url}" target="_blank" rel="noopener" title="${c.login} · ${c.contributions} commits" aria-label="${c.login}">
					<img src="${c.avatar_url}&s=128" alt="${c.login}" width="56" height="56" loading="lazy" />
				</a>
			`).join("");
		})
		.catch(() => { /* silent */ });
</script>
