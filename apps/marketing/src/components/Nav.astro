---
// Nav — V1 layout structure, adapted to the v2 light canvas.
// No scanbar, no mono route crumb, no overloaded link list.
import AeorankMark from "./AeorankMark.astro";
---

<nav id="site-nav" class="nav" aria-label="Primary">
	<div class="nav__inner">

		<!-- Wordmark -->
		<a href="/" class="nav__brand" aria-label="AEOrank home">
			<AeorankMark size={26} />
			<span class="nav__word">AEOrank</span>
		</a>

		<!-- Desktop links -->
		<div class="nav__links">
			<a href="#anatomy" class="nav__link" data-section="anatomy">How It Works</a>
			<a href="#files" class="nav__link" data-section="files">Features</a>
			<a href="#pricing" class="nav__link" data-section="pricing">Pricing</a>
			<a href="/scoreboard" class="nav__link">Scoreboard</a>
			<a href="https://docs.aeorank.dev" class="nav__link" target="_blank" rel="noopener">Docs</a>
		</div>

		<!-- Right actions -->
		<div class="nav__actions">
			<a
				href="https://github.com/vinpatel/aeorank"
				class="nav__star"
				target="_blank"
				rel="noopener"
				aria-label="Star AEOrank on GitHub"
			>
				<svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
				</svg>
				<span class="nav__star-label">Star</span>
				<span class="nav__star-count" data-gh-stars aria-live="polite"></span>
			</a>
			<a href="https://app.aeorank.dev/sign-in" class="nav__link nav__link--subtle">Sign In</a>
			<a href="https://app.aeorank.dev/sign-up" class="nav__cta">
				Get AEO Score
				<svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M2 6h8M6.5 2.5L10 6l-3.5 3.5"/>
				</svg>
			</a>

			<!-- Mobile hamburger -->
			<button
				id="nav-toggle"
				class="nav__burger"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="nav-mobile"
			>
				<svg id="burger-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
					<path d="M2 5h14M2 9h14M2 13h14"/>
				</svg>
				<svg id="close-icon" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
					<path d="M4 4l10 10M14 4L4 14"/>
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile menu -->
	<div id="nav-mobile" class="nav__mobile" aria-hidden="true">
		<div class="nav__mobile-inner">
			<a href="#anatomy" class="nav__mlink" data-closes-menu>How It Works</a>
			<a href="#files" class="nav__mlink" data-closes-menu>Features</a>
			<a href="#pricing" class="nav__mlink" data-closes-menu>Pricing</a>
			<a href="/scoreboard" class="nav__mlink">Scoreboard</a>
			<a href="https://docs.aeorank.dev" class="nav__mlink" target="_blank" rel="noopener">Docs</a>
			<hr class="hr-hair my-2" />
			<div class="flex gap-2">
				<a href="https://github.com/vinpatel/aeorank" class="btn btn-outline flex-1 justify-center" target="_blank" rel="noopener">
					<svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
					Star on GitHub
				</a>
				<a href="https://app.aeorank.dev/sign-up" class="btn btn-ink flex-1 justify-center">
					Get AEO Score
				</a>
			</div>
		</div>
	</div>
</nav>

<!-- Spacer so content isn't hidden under fixed nav -->
<div style="height: 64px" aria-hidden="true"></div>

<style>
	.nav {
		position: fixed;
		top: 0; left: 0; right: 0;
		z-index: 60;
		transition: background 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
		background: transparent;
		border-bottom: 1px solid transparent;
	}
	.nav.is-scrolled {
		background: rgba(246,244,238,0.88);
		backdrop-filter: saturate(140%) blur(14px);
		-webkit-backdrop-filter: saturate(140%) blur(14px);
		border-bottom-color: var(--color-rule);
	}

	.nav__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		height: 64px;
		max-width: 1240px;
		margin: 0 auto;
		padding: 0 clamp(1rem, 3vw, 2rem);
	}

	/* Brand */
	.nav__brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
		color: var(--color-ink);
		flex-shrink: 0;
	}
	.nav__word {
		font-size: 15px;
		font-weight: 700;
		letter-spacing: -0.018em;
	}

	/* Desktop links */
	.nav__links {
		display: none;
		align-items: center;
		gap: 2px;
	}
	.nav__link {
		display: inline-flex;
		align-items: center;
		padding: 6px 11px;
		font-size: 14px;
		font-weight: 450;
		color: var(--color-ink-2);
		text-decoration: none;
		border-radius: 6px;
		transition: color 140ms ease, background 140ms ease;
	}
	.nav__link:hover { color: var(--color-ink); background: rgba(17,17,17,0.045); }
	.nav__link.is-active {
		color: var(--color-ink);
		background: rgba(232,89,12,0.09);
	}

	/* Right cluster */
	.nav__actions {
		display: flex;
		align-items: center;
		gap: 6px;
	}
	.nav__link--subtle { padding: 6px 8px; color: var(--color-ink-3); }
	.nav__link--subtle:hover { color: var(--color-ink); background: transparent; }

	/* Star pill */
	.nav__star {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		height: 32px;
		padding: 0 11px;
		font-size: 13px;
		font-weight: 500;
		color: var(--color-ink);
		background: var(--color-page);
		border: 1px solid var(--color-rule-2);
		border-radius: 7px;
		text-decoration: none;
		transition: border-color 140ms ease, background 140ms ease, transform 140ms ease;
	}
	.nav__star:hover {
		border-color: var(--color-ink);
		background: #FCFBF8;
		transform: translateY(-1px);
	}
	.nav__star-count {
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--color-ink-2);
		padding-left: 7px;
		margin-left: 1px;
		border-left: 1px solid var(--color-rule-2);
		/* No content until fetched */
		min-width: 0;
	}
	.nav__star-count:empty::before { content: none; }
	.nav__star-count:not(:empty) { min-width: 22px; text-align: center; }

	/* Primary CTA */
	.nav__cta {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		height: 32px;
		padding: 0 13px;
		font-size: 13px;
		font-weight: 600;
		color: var(--color-paper);
		background: var(--color-ink);
		border: 1px solid var(--color-ink);
		border-radius: 7px;
		text-decoration: none;
		transition: background 140ms ease, border-color 140ms ease, transform 140ms ease, box-shadow 140ms ease;
	}
	.nav__cta:hover {
		background: #2A2A2A;
		transform: translateY(-1px);
		box-shadow: 0 6px 18px rgba(17,17,17,0.18);
	}
	.nav__cta:active { transform: translateY(0); }

	/* Mobile burger */
	.nav__burger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px; height: 32px;
		border: 1px solid var(--color-rule-2);
		background: var(--color-page);
		border-radius: 6px;
		color: var(--color-ink);
		cursor: pointer;
	}

	/* Mobile sheet */
	.nav__mobile {
		overflow: hidden;
		max-height: 0;
		transition: max-height 300ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.nav__mobile.is-open {
		max-height: 420px;
		background: rgba(246,244,238,0.98);
		backdrop-filter: blur(14px);
		border-top: 1px solid var(--color-rule);
	}
	.nav__mobile-inner {
		padding: 14px clamp(1rem, 3vw, 2rem) 18px;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.nav__mlink {
		font-size: 15px;
		color: var(--color-ink-2);
		text-decoration: none;
		padding: 10px 0;
	}
	.nav__mlink:hover { color: var(--color-ink); }

	.hidden { display: none; }

	@media (min-width: 900px) {
		.nav__links { display: inline-flex; }
		.nav__burger { display: none; }
	}
	@media (max-width: 899px) {
		.nav__link--subtle { display: none; }
		.nav__star { display: none; }
		.nav__cta { display: none; }
	}
</style>

<script>
	const nav = document.getElementById('site-nav');
	const onScroll = () => nav?.classList.toggle('is-scrolled', window.scrollY > 12);
	window.addEventListener('scroll', onScroll, { passive: true });
	onScroll();

	// Active section highlight
	const links = document.querySelectorAll<HTMLAnchorElement>('.nav__link[data-section]');
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(e => {
			if (e.isIntersecting) {
				const id = (e.target as HTMLElement).id;
				links.forEach(l => l.classList.toggle('is-active', l.dataset.section === id));
			}
		});
	}, { rootMargin: '-32% 0px -60% 0px', threshold: 0 });
	links.forEach(l => {
		const el = document.getElementById(l.dataset.section!);
		if (el) observer.observe(el);
	});

	// Mobile toggle
	const toggle = document.getElementById('nav-toggle');
	const mobile = document.getElementById('nav-mobile');
	const burger = document.getElementById('burger-icon');
	const close  = document.getElementById('close-icon');

	const setMenu = (open: boolean) => {
		mobile?.classList.toggle('is-open', open);
		mobile?.setAttribute('aria-hidden', open ? 'false' : 'true');
		toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
		burger?.classList.toggle('hidden', open);
		close?.classList.toggle('hidden', !open);
	};
	toggle?.addEventListener('click', () => setMenu(!mobile?.classList.contains('is-open')));
	document.querySelectorAll('[data-closes-menu]').forEach(el => el.addEventListener('click', () => setMenu(false)));
	window.addEventListener('resize', () => { if (window.innerWidth >= 900) setMenu(false); });

	// Live GitHub star count — fetched, no fallback number.
	// If the fetch fails, the slot stays empty; no false claim is made.
	const starEls = document.querySelectorAll<HTMLElement>('[data-gh-stars]');
	if (starEls.length) {
		fetch('https://api.github.com/repos/vinpatel/aeorank')
			.then(r => r.ok ? r.json() : null)
			.then(d => {
				if (d && typeof d.stargazers_count === 'number') {
					const n = d.stargazers_count.toLocaleString();
					starEls.forEach(el => { el.textContent = n; });
				}
			})
			.catch(() => { /* silent */ });
	}
</script>
