---
interface Props {
	route?: string;
}
const { route = "/ inspector / home" } = Astro.props;
---

<nav id="site-nav" class="nav" aria-label="Primary">
	<div class="wrap nav__inner">

		<!-- Left: wordmark + route breadcrumb -->
		<div class="nav__left">
			<a href="/" class="nav__mark" aria-label="AEOrank home">
				<span class="nav__logo" aria-hidden="true">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<!-- Abstract "AEO" in a grid — bespoke mark, not a stock logo -->
						<rect x="1" y="1" width="22" height="22" rx="2" fill="none" stroke="#111" stroke-width="1.4"/>
						<path d="M5 17 L8 7 L11 17" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
						<path d="M6 14 H10" stroke="#111" stroke-width="1.6" stroke-linecap="round"/>
						<circle cx="17" cy="12" r="3" stroke="#111" stroke-width="1.6" fill="none"/>
						<path d="M17 12 L20 15" stroke="#E8590C" stroke-width="1.8" stroke-linecap="round"/>
					</svg>
				</span>
				<span class="nav__word">AEOrank</span>
				<span class="nav__ver" aria-label="version">v2</span>
			</a>

			<span class="nav__sep" aria-hidden="true"></span>

			<span class="nav__crumb" aria-hidden="true">{route}</span>
		</div>

		<!-- Center: inline links -->
		<div class="nav__center">
			<a href="#hero"         class="nav__link" data-sec="hero">hero</a>
			<a href="#scan"         class="nav__link" data-sec="scan">scan</a>
			<a href="#anatomy"      class="nav__link" data-sec="anatomy">anatomy</a>
			<a href="#files"        class="nav__link" data-sec="files">files</a>
			<a href="#open-source"  class="nav__link" data-sec="open-source">open-source</a>
			<a href="#install"      class="nav__link" data-sec="install">install</a>
			<a href="#pricing"      class="nav__link" data-sec="pricing">pricing</a>
		</div>

		<!-- Right: actions -->
		<div class="nav__right">
			<a href="https://docs.aeorank.dev" class="btn btn-ghost btn-sm" target="_blank" rel="noopener">docs&#8599;</a>
			<a href="https://app.aeorank.dev/sign-in" class="btn btn-ghost btn-sm">sign in</a>

			<a href="https://github.com/vinpatel/aeorank" class="star-pill" target="_blank" rel="noopener" aria-label="Star AEOrank on GitHub">
				<span class="star-pill__label">
					<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M8 .25l2.39 4.84L15.75 6l-3.88 3.78.92 5.34L8 12.6l-4.79 2.52.92-5.34L.25 6l5.36-.91L8 .25z"/>
					</svg>
					<span>star</span>
				</span>
				<span class="star-pill__count" data-gh-stars>·&nbsp;2,847</span>
			</a>

			<a href="https://app.aeorank.dev/sign-up" class="btn btn-ink btn-sm">get score&nbsp;→</a>

			<!-- Mobile hamburger -->
			<button id="nav-toggle" class="nav__toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-mobile">
				<svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#111" stroke-width="1.4" aria-hidden="true">
					<path d="M2 5h14M2 9h14M2 13h14"/>
				</svg>
			</button>
		</div>
	</div>

	<!-- Hair-rule + scan indicator -->
	<div class="nav__scanbar" aria-hidden="true">
		<div class="wrap nav__scanbar-inner">
			<span class="font-mono ink-3 tracking-[0.05em] text-[10px]">SCANNING</span>
			<span class="nav__scanbar-track"><span class="nav__scanbar-dot"></span></span>
			<span class="font-mono ink-3 tracking-[0.05em] text-[10px]" data-live-score>LIVE · 76/100</span>
		</div>
	</div>

	<!-- Mobile menu -->
	<div id="nav-mobile" class="nav__mobile" aria-hidden="true">
		<div class="wrap nav__mobile-inner">
			<a href="#scan" class="nav__mlink">scan</a>
			<a href="#anatomy" class="nav__mlink">anatomy</a>
			<a href="#files" class="nav__mlink">files</a>
			<a href="#open-source" class="nav__mlink">open-source</a>
			<a href="#install" class="nav__mlink">install</a>
			<a href="#pricing" class="nav__mlink">pricing</a>
			<a href="https://docs.aeorank.dev" class="nav__mlink">docs ↗</a>
			<hr class="hr-hair" />
			<div class="flex gap-2 pt-3">
				<a href="https://github.com/vinpatel/aeorank" class="btn btn-outline w-full justify-center">star on github</a>
				<a href="https://app.aeorank.dev/sign-up" class="btn btn-ink w-full justify-center">get score →</a>
			</div>
		</div>
	</div>
</nav>

<!-- Spacer -->
<div style="height: 64px" aria-hidden="true"></div>

<style>
	.nav {
		position: fixed;
		top: 0; left: 0; right: 0;
		z-index: 60;
		background: rgba(246,244,238,0.86);
		backdrop-filter: saturate(140%) blur(10px);
		-webkit-backdrop-filter: saturate(140%) blur(10px);
		border-bottom: 1px solid var(--color-rule);
	}

	.nav__inner {
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		height: 48px;
		gap: 1rem;
	}

	/* Left cluster */
	.nav__left {
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.nav__mark {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		text-decoration: none;
		color: var(--color-ink);
	}
	.nav__logo {
		display: inline-flex;
		width: 24px;
		height: 24px;
		align-items: center;
		justify-content: center;
	}
	.nav__word {
		font-size: 14px;
		font-weight: 620;
		letter-spacing: -0.018em;
	}
	.nav__ver {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--color-ink-3);
		border: 1px solid var(--color-rule-2);
		border-radius: 3px;
		padding: 1px 5px 0;
		letter-spacing: 0.02em;
	}
	.nav__sep {
		width: 1px;
		height: 18px;
		background: var(--color-rule-2);
	}
	.nav__crumb {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--color-ink-3);
		letter-spacing: 0.02em;
	}

	/* Center */
	.nav__center {
		display: none;
		justify-content: center;
		gap: 2px;
	}
	.nav__link {
		display: inline-flex;
		align-items: center;
		height: 28px;
		padding: 0 9px;
		font-family: var(--font-mono);
		font-size: 12px;
		color: var(--color-ink-3);
		text-decoration: none;
		border-radius: 4px;
		transition: color 120ms ease, background 120ms ease;
		letter-spacing: 0.01em;
	}
	.nav__link:hover { color: var(--color-ink); background: rgba(17,17,17,0.045); }
	.nav__link.is-active {
		color: var(--color-ink);
		background: var(--color-paper-2);
		box-shadow: inset 0 -1px 0 var(--color-mark);
	}

	/* Right cluster */
	.nav__right {
		display: flex;
		align-items: center;
		gap: 6px;
		justify-self: end;
	}
	.nav__right .btn-sm { height: 30px; }

	.nav__toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 30px;
		border: 1px solid var(--color-rule-2);
		background: var(--color-page);
		border-radius: 4px;
		cursor: pointer;
	}

	/* Scanbar */
	.nav__scanbar {
		display: none;
		border-top: 1px solid var(--color-rule);
		background: rgba(239,236,228,0.55);
	}
	.nav__scanbar-inner {
		display: flex;
		align-items: center;
		gap: 12px;
		height: 22px;
	}
	.nav__scanbar-track {
		flex: 1;
		height: 2px;
		background:
			repeating-linear-gradient(to right, var(--color-rule) 0, var(--color-rule) 3px, transparent 3px, transparent 7px);
		position: relative;
		border-radius: 1px;
	}
	.nav__scanbar-dot {
		position: absolute;
		top: -2px;
		left: 0;
		width: 8px;
		height: 6px;
		background: var(--color-mark);
		box-shadow: 0 0 0 3px rgba(232,89,12,0.14);
		border-radius: 1px;
		animation: scan-travel 9s ease-in-out infinite;
	}
	@keyframes scan-travel {
		0%, 100% { left: 0; }
		50%      { left: calc(100% - 8px); }
	}

	/* Mobile menu */
	.nav__mobile {
		display: none;
		border-top: 1px solid var(--color-rule);
		background: var(--color-paper);
	}
	.nav__mobile.is-open { display: block; }
	.nav__mobile-inner {
		display: flex;
		flex-direction: column;
		gap: 2px;
		padding: 14px 0 18px;
	}
	.nav__mlink {
		font-family: var(--font-mono);
		font-size: 14px;
		color: var(--color-ink-2);
		text-decoration: none;
		padding: 10px 0;
	}
	.nav__mlink:hover { color: var(--color-ink); }

	@media (min-width: 900px) {
		.nav__center { display: inline-flex; }
		.nav__toggle { display: none; }
		.nav__scanbar { display: block; }
	}
	@media (max-width: 899px) {
		.nav__right .btn:not(.btn-ink),
		.nav__right .star-pill { display: none; }
		.nav__crumb { display: none; }
	}
</style>

<script>
	// Active section highlight — monospace route switches as sections cross viewport
	const links = document.querySelectorAll<HTMLAnchorElement>('.nav__link[data-sec]');
	const ids = Array.from(links).map(l => l.dataset.sec!);
	const setActive = (id: string) => {
		links.forEach(l => l.classList.toggle('is-active', l.dataset.sec === id));
	};
	const secObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach(e => {
				if (e.isIntersecting) setActive((e.target as HTMLElement).id);
			});
		},
		{ rootMargin: '-32% 0px -60% 0px', threshold: 0 }
	);
	ids.forEach(id => {
		const el = document.getElementById(id);
		if (el) secObserver.observe(el);
	});

	// Mobile toggle
	const toggle = document.getElementById('nav-toggle');
	const mobile = document.getElementById('nav-mobile');
	toggle?.addEventListener('click', () => {
		const open = mobile?.classList.toggle('is-open');
		toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
		mobile?.setAttribute('aria-hidden', open ? 'false' : 'true');
	});

	// Live score ticker — tiny micro-interaction in the scanbar
	const live = document.querySelector<HTMLElement>('[data-live-score]');
	if (live) {
		const scores = [76, 77, 76, 78, 77, 79, 78, 80, 79, 81];
		let i = 0;
		setInterval(() => {
			live.textContent = `LIVE · ${scores[i % scores.length]}/100`;
			i++;
		}, 2400);
	}

	// GitHub stars — try fetching real count, else keep placeholder
	const starsEl = document.querySelector<HTMLElement>('[data-gh-stars]');
	if (starsEl) {
		fetch('https://api.github.com/repos/vinpatel/aeorank')
			.then(r => r.ok ? r.json() : null)
			.then(d => {
				if (d && typeof d.stargazers_count === 'number') {
					starsEl.textContent = `· ${d.stargazers_count.toLocaleString()}`;
				}
			})
			.catch(() => { /* silent */ });
	}
</script>
