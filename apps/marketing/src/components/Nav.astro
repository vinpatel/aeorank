---
---
<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" aria-label="Main navigation">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 h-16">

		<!-- Wordmark -->
		<a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="AEOrank home">
			<svg width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true">
				<rect width="32" height="32" rx="7" fill="#E8590C"/>
				<path d="M8 22L13.5 10H18.5L24 22" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
				<path d="M10.5 18H21.5" stroke="#fff" stroke-width="2.5" stroke-linecap="round"/>
			</svg>
			<span class="text-[15px] font-bold tracking-tight text-[var(--color-text)]">AEOrank</span>
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-0.5">
			<a href="#how-it-works" class="nav-link" data-section="how-it-works">How It Works</a>
			<a href="#who-its-for"  class="nav-link" data-section="who-its-for">Who It's For</a>
			<a href="#pricing"      class="nav-link" data-section="pricing">Pricing</a>
			<a href="/scoreboard"   class="nav-link">Scoreboard</a>
			<a href="https://docs.aeorank.dev" class="nav-link" target="_blank" rel="noopener">Docs</a>
		</div>

		<!-- Desktop actions -->
		<div class="hidden md:flex items-center gap-2">
			<!-- GitHub icon-only -->
			<a
				href="https://github.com/vinpatel/aeorank"
				class="nav-icon-btn"
				target="_blank"
				rel="noopener"
				aria-label="GitHub repository"
			>
				<svg width="17" height="17" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
			<a href="https://app.aeorank.dev/sign-in" class="nav-link">Sign In</a>
			<a href="https://app.aeorank.dev/sign-up" class="nav-cta">
				Get AEO Score
				<svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M2 6h8M6.5 2.5L10 6l-3.5 3.5"/>
				</svg>
			</a>
		</div>

		<!-- Mobile hamburger -->
		<button
			id="mobile-menu-btn"
			class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-white/5 transition-colors"
			aria-label="Open menu"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<svg id="hamburger-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
				<path d="M2 4h14M2 9h14M2 14h14"/>
			</svg>
			<svg id="close-icon" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
				<path d="M4 4l10 10M14 4L4 14"/>
			</svg>
		</button>
	</div>

	<!-- Mobile menu — slide down -->
	<div
		id="mobile-menu"
		class="md:hidden overflow-hidden"
		style="max-height: 0; transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1);"
		aria-hidden="true"
	>
		<div class="border-t px-6 py-5 flex flex-col gap-0.5" style="border-color: var(--color-border); background: rgba(6,6,10,0.97); backdrop-filter: blur(20px);">
			<a href="#how-it-works" class="mobile-nav-link" data-closes-menu>How It Works</a>
			<a href="#who-its-for"  class="mobile-nav-link" data-closes-menu>Who It's For</a>
			<a href="#pricing"      class="mobile-nav-link" data-closes-menu>Pricing</a>
			<a href="/scoreboard"   class="mobile-nav-link">Scoreboard</a>
			<a href="https://docs.aeorank.dev" class="mobile-nav-link" target="_blank" rel="noopener">Docs</a>
			<hr style="border-color: var(--color-border); margin: 10px 0;" />
			<div class="flex items-center gap-4 py-1 mb-2">
				<a href="https://github.com/vinpatel/aeorank" class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors" target="_blank" rel="noopener">
					<svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
					</svg>
					GitHub
				</a>
				<a href="https://app.aeorank.dev/sign-in" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">Sign In</a>
			</div>
			<a href="https://app.aeorank.dev/sign-up" class="btn-primary w-full justify-center !text-sm !py-3">
				Get AEO Score
			</a>
		</div>
	</div>
</nav>

<!-- Spacer so content isn't hidden under fixed nav -->
<div class="h-16" aria-hidden="true"></div>

<style>
	/* ── Scrolled state ──────────────────────────────────────────── */
	#site-nav.is-scrolled {
		background: rgba(6, 6, 10, 0.88);
		backdrop-filter: blur(18px);
		-webkit-backdrop-filter: blur(18px);
		border-bottom: 1px solid rgba(255,255,255,0.07);
		box-shadow:
			0 1px 0 rgba(255,255,255,0.035),
			0 4px 20px rgba(0,0,0,0.45);
	}

	/* ── Nav link ────────────────────────────────────────────────── */
	.nav-link {
		display: inline-flex;
		align-items: center;
		padding: 0.375rem 0.6875rem;
		font-size: 0.875rem;
		font-weight: 450;
		color: var(--color-text-muted);
		border-radius: 6px;
		transition: color 0.14s ease, background 0.14s ease;
		text-decoration: none;
	}
	.nav-link:hover {
		color: var(--color-text);
		background: rgba(255,255,255,0.05);
	}
	.nav-link.is-active {
		color: var(--color-text);
		background: rgba(232,89,12,0.09);
	}

	/* ── Icon button (GitHub) ────────────────────────────────────── */
	.nav-icon-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 7px;
		color: var(--color-text-muted);
		transition: color 0.14s ease, background 0.14s ease;
		text-decoration: none;
	}
	.nav-icon-btn:hover {
		color: var(--color-text);
		background: rgba(255,255,255,0.06);
	}

	/* ── CTA button ──────────────────────────────────────────────── */
	.nav-cta {
		display: inline-flex;
		align-items: center;
		gap: 0.3125rem;
		padding: 0.4375rem 0.9375rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: #fff;
		background: #E8590C;
		border-radius: 7px;
		text-decoration: none;
		transition: background 0.14s ease, box-shadow 0.14s ease, transform 0.14s ease;
		box-shadow: 0 1px 0 rgba(255,255,255,0.1) inset;
	}
	.nav-cta:hover {
		background: #F97316;
		box-shadow:
			0 1px 0 rgba(255,255,255,0.1) inset,
			0 0 0 2px rgba(232,89,12,0.25),
			0 4px 14px rgba(232,89,12,0.3);
		transform: translateY(-1px);
	}
	.nav-cta:active { transform: translateY(0); }

	/* ── Mobile nav link ─────────────────────────────────────────── */
	.mobile-nav-link {
		display: block;
		padding: 0.625rem 0.25rem;
		font-size: 0.9375rem;
		color: var(--color-text-muted);
		border-radius: 6px;
		text-decoration: none;
		transition: color 0.14s ease;
	}
	.mobile-nav-link:hover {
		color: var(--color-text);
	}
</style>

<script>
	// ── Scroll: apply frosted bg ────────────────────────────────────────────────
	const nav = document.getElementById('site-nav') as HTMLElement | null;
	const update = () => nav?.classList.toggle('is-scrolled', window.scrollY > 12);
	window.addEventListener('scroll', update, { passive: true });
	update();

	// ── Active section via IntersectionObserver ─────────────────────────────────
	const sections = ['how-it-works', 'who-its-for', 'pricing'];
	const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link[data-section]');

	const sectionObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach(entry => {
				if (entry.isIntersecting) {
					navLinks.forEach(link => {
						link.classList.toggle('is-active', link.dataset.section === entry.target.id);
					});
				}
			});
		},
		{ rootMargin: '-28% 0px -68% 0px', threshold: 0 }
	);

	sections.forEach(id => {
		const el = document.getElementById(id);
		if (el) sectionObserver.observe(el);
	});

	// ── Mobile menu toggle ──────────────────────────────────────────────────────
	const btn      = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
	const menu     = document.getElementById('mobile-menu') as HTMLElement | null;
	const hIcon    = document.getElementById('hamburger-icon') as SVGElement | null;
	const xIcon    = document.getElementById('close-icon') as SVGElement | null;

	let menuOpen = false;

	const openMenu = () => {
		menuOpen = true;
		if (menu) {
			menu.style.maxHeight = menu.scrollHeight + 'px';
			menu.setAttribute('aria-hidden', 'false');
		}
		hIcon?.classList.add('hidden');
		xIcon?.classList.remove('hidden');
		btn?.setAttribute('aria-expanded', 'true');
	};

	const closeMenu = () => {
		menuOpen = false;
		if (menu) {
			menu.style.maxHeight = '0';
			menu.setAttribute('aria-hidden', 'true');
		}
		hIcon?.classList.remove('hidden');
		xIcon?.classList.add('hidden');
		btn?.setAttribute('aria-expanded', 'false');
	};

	btn?.addEventListener('click', () => menuOpen ? closeMenu() : openMenu());

	// Close menu when an anchor link inside it is clicked
	document.querySelectorAll('[data-closes-menu]').forEach(link => {
		link.addEventListener('click', closeMenu);
	});

	// Close menu on resize to desktop
	window.addEventListener('resize', () => {
		if (window.innerWidth >= 768 && menuOpen) closeMenu();
	});
</script>
