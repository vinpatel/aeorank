---
const dimensions = {
	high: [
		{ name: "llms.txt Presence", desc: "Does your site have an llms.txt file?" },
		{ name: "Schema.org Markup", desc: "Structured data for AI understanding" },
		{ name: "Content Structure", desc: "Clean heading hierarchy and organization" },
	],
	medium: [
		{ name: "AI Crawler Access", desc: "Are AI crawlers allowed in robots.txt?" },
		{ name: "Answer-First Formatting", desc: "Content that leads with direct answers" },
		{ name: "FAQ & Speakable", desc: "FAQ markup with speakable schema" },
		{ name: "E-E-A-T Signals", desc: "Author, dates, expertise indicators" },
		{ name: "Meta Descriptions", desc: "Quality descriptions on every page" },
		{ name: "Citation Anchors", desc: "Stable heading IDs for AI citations" },
	],
	low: [
		{ name: "Sitemap Presence", desc: "Valid sitemap.xml for crawlers" },
		{ name: "HTTPS & Redirects", desc: "Secure site with clean URLs" },
		{ name: "Page Freshness", desc: "Recent publication and modification dates" },
	],
};

const grades = [
	{ grade: "A+", range: "95-100" },
	{ grade: "A", range: "85-94" },
	{ grade: "B", range: "70-84" },
	{ grade: "C", range: "55-69" },
	{ grade: "D", range: "40-54" },
	{ grade: "F", range: "0-39" },
];
---

<section id="scoring" class="border-t border-border px-6 py-24">
	<div class="mx-auto max-w-6xl">
		<h2 class="text-4xl font-bold md:text-5xl">12 Dimensions. One Score.</h2>
		<p class="mt-4 text-lg text-text-muted">
			AEOrank measures what actually matters for AI engine visibility.
		</p>

		<div class="mt-12 space-y-8">
			<div>
				<h3 class="text-sm font-semibold uppercase tracking-wide text-text-muted">
					High Weight (1.5x)
				</h3>
				<div class="mt-3 space-y-2">
					{
						dimensions.high.map((d) => (
							<div class="flex items-baseline gap-3 border-b border-border py-3">
								<span class="font-medium">{d.name}</span>
								<span class="text-sm text-text-muted">{d.desc}</span>
							</div>
						))
					}
				</div>
			</div>

			<div>
				<h3 class="text-sm font-semibold uppercase tracking-wide text-text-muted">
					Medium Weight (1.0x)
				</h3>
				<div class="mt-3 space-y-2">
					{
						dimensions.medium.map((d) => (
							<div class="flex items-baseline gap-3 border-b border-border py-3">
								<span class="font-medium">{d.name}</span>
								<span class="text-sm text-text-muted">{d.desc}</span>
							</div>
						))
					}
				</div>
			</div>

			<div>
				<h3 class="text-sm font-semibold uppercase tracking-wide text-text-muted">
					Low Weight (0.5x)
				</h3>
				<div class="mt-3 space-y-2">
					{
						dimensions.low.map((d) => (
							<div class="flex items-baseline gap-3 border-b border-border py-3">
								<span class="font-medium">{d.name}</span>
								<span class="text-sm text-text-muted">{d.desc}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>

		<div class="mt-12">
			<h3 class="text-lg font-semibold">Grade Scale</h3>
			<div class="mt-4 flex flex-wrap gap-4">
				{
					grades.map((g) => (
						<div class="border border-border px-4 py-2 text-center">
							<div class="text-lg font-bold">{g.grade}</div>
							<div class="text-xs text-text-muted">{g.range}</div>
						</div>
					))
				}
			</div>
		</div>

		<a
			href="https://docs.aeorank.dev/scoring/dimensions/"
			class="mt-8 inline-block text-text-muted hover:text-text"
		>
			Read the full scoring methodology &rarr;
		</a>
	</div>
</section>
