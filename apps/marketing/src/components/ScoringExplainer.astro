---
const pillars = [
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/><path d="M3.05 11a9 9 0 0 1 .5-2.3"/></svg>`,
		color: "#E8590C",
		colorRgb: "232,89,12",
		glow: "rgba(232,89,12,0.14)",
		border: "rgba(232,89,12,0.22)",
		weight: "30%",
		label: "Answer Readiness",
		desc: "Topical authority, fact density, citation-ready writing, original research, evidence packaging, duplicate content detection.",
	},
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h10M4 18h14"/></svg>`,
		color: "#6366F1",
		colorRgb: "99,102,241",
		glow: "rgba(99,102,241,0.14)",
		border: "rgba(99,102,241,0.22)",
		weight: "21%",
		label: "Content Structure",
		desc: "Q&A format, direct answer density, tables and lists, definition patterns, entity disambiguation, heading hierarchy.",
	},
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
		color: "#22C55E",
		colorRgb: "34,197,94",
		glow: "rgba(34,197,94,0.14)",
		border: "rgba(34,197,94,0.22)",
		weight: "16%",
		label: "Trust & Authority",
		desc: "E-E-A-T signals, internal linking, author schema, meta descriptions, answer-first formatting.",
	},
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
		color: "#06B6D4",
		colorRgb: "6,182,212",
		glow: "rgba(6,182,212,0.14)",
		border: "rgba(6,182,212,0.22)",
		weight: "14%",
		label: "Technical Foundation",
		desc: "Schema.org coverage, semantic HTML, speakable markup, image context for AI, extraction friction analysis.",
	},
	{
		icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>`,
		color: "#EC4899",
		colorRgb: "236,72,153",
		glow: "rgba(236,72,153,0.14)",
		border: "rgba(236,72,153,0.22)",
		weight: "19%",
		label: "AI Discovery",
		desc: "llms.txt, ai.txt, AI crawler access (GPTBot, ClaudeBot, PerplexityBot), content licensing, RSS feeds, sitemap freshness.",
	},
];
---

<section id="scoring" class="px-6 py-20 md:py-28 border-t border-[rgba(255,255,255,0.06)]">
	<div class="mx-auto max-w-5xl">
		<p class="text-[#22C55E] text-xs font-bold uppercase tracking-[0.12em] text-center">36 criteria · 5 pillars</p>
		<h2 class="text-3xl md:text-4xl font-bold text-white text-center mt-3 tracking-tight leading-tight">
			Five pillars of AI visibility
		</h2>
		<p class="text-[#A1A1AA] text-base md:text-lg text-center max-w-2xl mx-auto mt-4 leading-relaxed">
			Every check is deterministic. No LLM calls. No AI scoring AI. Same score every time you run it.
		</p>

		<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-14">
			{pillars.map((p, i) => (
				<div
					class="sc-card animate-on-scroll"
					style={`--cc: ${p.color}; --cc-rgb: ${p.colorRgb}; --cc-glow: ${p.glow}; --cc-border: ${p.border}; animation-delay: ${i * 60}ms;`}
				>
					<!-- Top accent line -->
					<div class="sc-card__accent" style={`background: linear-gradient(90deg, ${p.color}, transparent);`}></div>

					<div class="sc-card__body">
						<!-- Icon + weight row -->
						<div class="flex items-start justify-between mb-5">
							<div class="sc-icon" style={`background: ${p.glow}; border-color: ${p.border}; color: ${p.color};`}>
								<Fragment set:html={p.icon} />
							</div>
							<span class="sc-badge" style={`background: ${p.glow}; color: ${p.color}; border-color: ${p.border};`}>
								{p.weight}
							</span>
						</div>

						<h3 class="text-white font-semibold text-[1rem] mb-2 leading-snug">{p.label}</h3>
						<p class="text-[#A1A1AA] text-sm leading-relaxed">{p.desc}</p>
					</div>

					<!-- Hover glow sweep -->
					<div class="sc-card__glow" style={`background: radial-gradient(ellipse at 100% 0%, ${p.glow} 0%, transparent 65%);`}></div>
				</div>
			))}

			<!-- Stats card -->
			<div class="sc-stats animate-on-scroll">
				<div class="sc-stats__inner">
					<div class="text-center">
						<div class="sc-stat-num" style="color: #E8590C; text-shadow: 0 0 30px rgba(232,89,12,0.5);">411</div>
						<p class="text-[#6B6B76] text-xs font-medium mt-2 leading-snug">tests verify<br/>scoring accuracy</p>
					</div>

					<div class="sc-stats__rule"></div>

					<div class="text-center">
						<div class="sc-stat-num" style="color: #22C55E; text-shadow: 0 0 30px rgba(34,197,94,0.5);">&lt;30s</div>
						<p class="text-[#6B6B76] text-xs font-medium mt-2 leading-snug">scan time for<br/>a 50-page site</p>
					</div>
				</div>
				<!-- Corner glow -->
				<div class="sc-stats__glow"></div>
			</div>
		</div>

		<!-- Deterministic callout -->
		<div class="mt-10 flex items-center justify-center gap-2.5 text-[#6B6B76] text-sm">
			<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
			<span>No LLM scoring. Pure deterministic checks — reproducible, auditable, trustworthy.</span>
		</div>
	</div>
</section>

<style>
	/* ── Pillar card ── */
	.sc-card {
		position: relative;
		border-radius: 14px;
		border: 1px solid rgba(255,255,255,0.07);
		background: rgba(255,255,255,0.03);
		overflow: hidden;
		transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
	}
	.sc-card:hover {
		transform: translateY(-3px);
		border-color: var(--cc-border);
		box-shadow:
			0 16px 40px rgba(0,0,0,0.4),
			0 0 0 1px rgba(var(--cc-rgb), 0.12),
			0 0 50px -12px rgba(var(--cc-rgb), 0.3);
	}

	/* 2px colored top accent */
	.sc-card__accent {
		height: 2px;
		width: 60%;
		border-radius: 0 0 4px 4px;
		margin-left: 1.5rem;
		margin-top: 0;
		opacity: 0.8;
		transition: width 0.3s ease, opacity 0.3s ease;
	}
	.sc-card:hover .sc-card__accent {
		width: 80%;
		opacity: 1;
	}

	.sc-card__body {
		position: relative;
		z-index: 1;
		padding: 1.375rem 1.5rem 1.5rem;
	}

	/* Hover glow overlay */
	.sc-card__glow {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 0.3s ease;
		pointer-events: none;
	}
	.sc-card:hover .sc-card__glow { opacity: 1; }

	/* Icon */
	.sc-icon {
		width: 46px;
		height: 46px;
		border-radius: 11px;
		border: 1px solid;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		transition: box-shadow 0.22s ease;
	}
	.sc-card:hover .sc-icon {
		box-shadow: 0 0 18px rgba(var(--cc-rgb), 0.35);
	}

	/* Weight badge */
	.sc-badge {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		padding: 0.25rem 0.65rem;
		border-radius: 9999px;
		border: 1px solid;
	}

	/* ── Stats card ── */
	.sc-stats {
		position: relative;
		border-radius: 14px;
		border: 1px solid rgba(255,255,255,0.1);
		background: linear-gradient(145deg, rgba(255,255,255,0.045) 0%, rgba(255,255,255,0.018) 100%);
		overflow: hidden;
		transition: transform 0.22s ease, box-shadow 0.22s ease;
	}
	.sc-stats:hover {
		transform: translateY(-3px);
		box-shadow: 0 16px 40px rgba(0,0,0,0.4);
	}
	.sc-stats__inner {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		padding: 2.25rem 1.5rem;
		height: 100%;
		min-height: 200px;
	}
	.sc-stat-num {
		font-size: clamp(2.25rem, 4vw, 3rem);
		font-weight: 800;
		letter-spacing: -0.05em;
		line-height: 1;
	}
	.sc-stats__rule {
		width: 36px;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
	}
	.sc-stats__glow {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at 20% 100%, rgba(232,89,12,0.07) 0%, transparent 55%),
			radial-gradient(ellipse at 80% 0%, rgba(34,197,94,0.07) 0%, transparent 55%);
		pointer-events: none;
	}
</style>
