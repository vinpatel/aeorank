---
const tiers = [
	{
		name: "Free",
		price: "$0",
		period: "forever",
		description: "Try the dashboard with basic limits.",
		features: ["1 site", "3 scans per month", "All 8 generated files", "Community support"],
		cta: "Get Started Free",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: false,
	},
	{
		name: "Pro",
		price: "$29",
		period: "/mo",
		description: "Dashboard with history and insights.",
		features: ["Up to 5 sites", "50 scans per month", "Score history charts", "Priority support"],
		cta: "Start Free Trial",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: true,
	},
	{
		name: "API",
		price: "$99",
		period: "/mo",
		description: "Programmatic access and webhooks.",
		features: ["Up to 50 sites", "500 scans per month", "REST API access", "Webhook notifications"],
		cta: "Start Free Trial",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: false,
	},
	{
		name: "Agency",
		price: "$499",
		period: "/mo",
		description: "White-label reports for your clients.",
		features: ["Unlimited sites", "Unlimited scans", "White-label PDF reports", "Priority support"],
		cta: "Start Free Trial",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: false,
	},
];
---

<section id="pricing" class="py-24 sm:py-32 border-t border-[--color-border] px-6">
	<div class="mx-auto max-w-5xl">
		<h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-[--color-text] font-[family-name:var(--font-display)]">Simple, Honest Pricing</h2>
		<p class="mt-4 text-lg text-[--color-text-muted] max-w-2xl leading-relaxed">
			The CLI is free forever. Pay when you need the dashboard.
		</p>
		<div class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
			{
				tiers.map((tier) => (
					<div
						class:list={[
							"relative flex flex-col rounded-2xl p-7 transition-all duration-200",
							tier.highlighted
								? "border-2 border-[--color-accent-warm] bg-[--color-bg-card] shadow-[0_0_40px_-8px_rgba(232,89,12,0.3)] scale-[1.02]"
								: "border border-[--color-border] bg-[--color-bg-card] hover:border-[--color-border]/80 hover:shadow-lg hover:shadow-black/20",
						]}
					>
						{tier.highlighted && (
							<span class="absolute -top-3.5 left-1/2 -translate-x-1/2 bg-[--color-accent-warm] text-white text-xs font-semibold px-4 py-1 rounded-full shadow-lg shadow-[--color-accent-warm]/25">
								Recommended
							</span>
						)}
						<h3 class="text-lg font-bold text-[--color-text] font-[family-name:var(--font-display)]">{tier.name}</h3>
						<div class="mt-3 flex items-baseline gap-1">
							<span class="text-4xl font-bold tracking-tight text-[--color-text] font-[family-name:var(--font-display)]">{tier.price}</span>
							<span class="text-sm text-[--color-text-muted]">{tier.period}</span>
						</div>
						<p class="mt-3 text-sm text-[--color-text-muted]">{tier.description}</p>
						<ul class="mt-6 flex-1 space-y-3">
							{tier.features.map((f) => (
								<li class="flex items-start gap-2.5 text-sm text-[--color-text]">
									<svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 shrink-0">
										<circle cx="8" cy="8" r="7" fill="rgba(22, 163, 74, 0.12)"/>
										<path d="M5.5 8L7.2 9.7L10.5 6.3" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
									{f}
								</li>
							))}
						</ul>
						<a
							href={tier.ctaLink}
							class:list={[
								"mt-7 block text-center rounded-lg px-4 py-2.5 text-sm font-semibold transition-all duration-200",
								tier.highlighted
									? "bg-[--color-accent-warm] text-white hover:brightness-110 shadow-lg shadow-[--color-accent-warm]/20"
									: "bg-[--color-bg-elevated] text-[--color-text] border border-[--color-border] hover:bg-[--color-border] hover:border-[--color-border]",
							]}
						>
							{tier.cta}
						</a>
					</div>
				))
			}
		</div>
	</div>
</section>
