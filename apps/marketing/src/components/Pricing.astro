---
---
<section id="pricing" class="px-6 py-20 md:py-28 border-t border-border scroll-mt-20">
	<div class="mx-auto max-w-5xl">
		<p class="eyebrow text-center">Pricing</p>
		<h2 class="heading-lg text-center mt-3">They charge $399/mo to monitor.<br/>We charge $29/mo to <span class="gradient-text-accent">fix it</span>.</h2>
		<p class="body-lg text-center max-w-2xl mx-auto mt-4">Every plan includes full scoring, file generation, and CI integration. No feature gates on the stuff that matters.</p>

		<div class="grid md:grid-cols-3 gap-6 mt-14 stagger-children">

			<!-- Starter -->
			<div class="pricing-card animate-on-scroll">
				<div class="pricing-card__inner p-8 flex flex-col">
					<p class="text-[0.6875rem] font-700 text-text-muted uppercase tracking-[0.1em]">Starter</p>
					<div class="mt-4 flex items-baseline gap-1">
						<span class="text-5xl font-bold tracking-tight text-text">$0</span>
						<span class="text-text-muted text-sm">/month</span>
					</div>
					<p class="text-text-muted text-sm mt-3 leading-relaxed">Try everything. No credit card.</p>

					<ul class="mt-8 space-y-3 flex-1">
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>1 site</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>3 dashboard scans / month</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>Full 36-criteria scoring</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>All 9 generated files</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>CLI — unlimited local usage</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>GitHub App + Action</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check">✓</span>
							<span>13 framework plugins</span>
						</li>
						<li class="pricing-feature pricing-feature--muted">
							<span class="pricing-dash">—</span>
							<span>No history or trends</span>
						</li>
						<li class="pricing-feature pricing-feature--muted">
							<span class="pricing-dash">—</span>
							<span>No auto-rescan</span>
						</li>
					</ul>

					<a href="https://app.aeorank.dev/sign-up" class="btn-secondary justify-center mt-8 !text-sm !py-3">Start Free</a>
				</div>
			</div>

			<!-- Pro — highlighted -->
			<div class="pricing-card pricing-card--pro animate-on-scroll">
				<div class="pricing-card__inner p-8 flex flex-col relative">
					<!-- Best Value badge -->
					<div class="absolute -top-3.5 left-1/2 -translate-x-1/2 z-10">
						<span class="inline-flex items-center gap-1 text-[0.6875rem] font-700 text-white bg-accent px-4 py-1.5 rounded-full shadow-lg shadow-accent/30 tracking-wide">
							<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
							Best Value
						</span>
					</div>
					<!-- Accent top bar -->
					<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent to-transparent rounded-t-[16px]"></div>

					<p class="text-[0.6875rem] font-700 text-accent uppercase tracking-[0.1em]">Pro</p>
					<div class="mt-4 flex items-baseline gap-1">
						<span class="text-5xl font-bold tracking-tight text-text">$29</span>
						<span class="text-text-muted text-sm">/month</span>
					</div>
					<p class="text-text-muted text-sm mt-3 leading-relaxed">Full monitoring + fix generation. <span class="text-accent font-medium">14× cheaper than Profound.</span></p>

					<ul class="mt-8 space-y-3 flex-1">
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span><strong class="text-text">5 sites</strong></span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span><strong class="text-text">50 scans / month</strong></span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span>30-day score history + trends</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span>Per-page scoring breakdown</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span>Auto-rescan (daily / weekly / monthly)</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span>PDF export + comparison view</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span>Dimension trend charts</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--pro">✓</span>
							<span>Everything in Starter</span>
						</li>
					</ul>

					<a href="https://app.aeorank.dev/sign-up" class="btn-primary justify-center mt-8 !text-sm !py-3">Start Pro — $29/mo</a>
					<p class="text-text-muted text-[11px] text-center mt-2.5">Otterly charges $99/mo for this. Scrunch charges $500.</p>
				</div>
			</div>

			<!-- Agency -->
			<div class="pricing-card pricing-card--agency animate-on-scroll">
				<div class="pricing-card__inner p-8 flex flex-col">
					<!-- Accent top bar -->
					<div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo to-transparent rounded-t-[16px]"></div>

					<p class="text-[0.6875rem] font-700 text-indigo uppercase tracking-[0.1em]">Agency</p>
					<div class="mt-4 flex items-baseline gap-1">
						<span class="text-5xl font-bold tracking-tight text-text">$99</span>
						<span class="text-text-muted text-sm">/month</span>
					</div>
					<p class="text-text-muted text-sm mt-3 leading-relaxed">For agencies managing client portfolios at scale.</p>

					<ul class="mt-8 space-y-3 flex-1">
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span><strong class="text-text">50 sites</strong></span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span><strong class="text-text">500 scans / month</strong></span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span>REST API access</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span>Bulk scan endpoints</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span>Webhook notifications</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span>Client-ready PDF reports</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span>Priority support</span>
						</li>
						<li class="pricing-feature">
							<span class="pricing-check pricing-check--agency">✓</span>
							<span>Everything in Pro</span>
						</li>
					</ul>

					<a href="https://app.aeorank.dev/sign-up" class="btn-agency justify-center mt-8 !text-sm !py-3">Start Agency — $99/mo</a>
					<p class="text-text-muted text-[11px] text-center mt-2.5">Scrunch charges $500/mo. Semrush charges $129+.</p>
				</div>
			</div>

		</div>

		<!-- Competitor price comparison strip -->
		<div class="mt-14 rounded-2xl border border-border bg-white/[0.02] overflow-hidden">
			<div class="px-6 py-5 border-b border-border">
				<p class="text-xs font-semibold text-text-muted uppercase tracking-[0.1em] text-center">Price comparison — what others charge for monitoring only</p>
			</div>
			<div class="grid grid-cols-2 md:grid-cols-5 gap-px bg-border">
				<!-- AEOrank -->
				<div class="bg-[#06060A] px-5 py-6 text-center bg-[rgba(232,89,12,0.05)]">
					<p class="text-accent font-bold text-sm tracking-tight">AEOrank Pro</p>
					<div class="flex items-baseline justify-center gap-0.5 mt-2">
						<span class="text-3xl font-bold text-text tracking-tight">$29</span>
						<span class="text-text-muted text-xs">/mo</span>
					</div>
					<p class="text-green text-[11px] mt-1.5 font-semibold">Score + Fix + Monitor</p>
				</div>
				<!-- Profound -->
				<div class="bg-[#06060A] px-5 py-6 text-center">
					<p class="text-text-muted font-medium text-sm">Profound</p>
					<div class="flex items-baseline justify-center gap-0.5 mt-2 opacity-50">
						<span class="text-3xl font-bold text-text-muted tracking-tight">$399</span>
						<span class="text-text-muted text-xs">/mo</span>
					</div>
					<p class="text-text-muted text-[11px] mt-1.5 opacity-50">Monitor + content</p>
				</div>
				<!-- Otterly -->
				<div class="bg-[#06060A] px-5 py-6 text-center">
					<p class="text-text-muted font-medium text-sm">Otterly.ai</p>
					<div class="flex items-baseline justify-center gap-0.5 mt-2 opacity-50">
						<span class="text-3xl font-bold text-text-muted tracking-tight">$99</span>
						<span class="text-text-muted text-xs">/mo</span>
					</div>
					<p class="text-text-muted text-[11px] mt-1.5 opacity-50">Monitor only</p>
				</div>
				<!-- Scrunch -->
				<div class="bg-[#06060A] px-5 py-6 text-center">
					<p class="text-text-muted font-medium text-sm">Scrunch AI</p>
					<div class="flex items-baseline justify-center gap-0.5 mt-2 opacity-50">
						<span class="text-3xl font-bold text-text-muted tracking-tight">$500</span>
						<span class="text-text-muted text-xs">/mo</span>
					</div>
					<p class="text-text-muted text-[11px] mt-1.5 opacity-50">Monitor only</p>
				</div>
				<!-- Semrush -->
				<div class="bg-[#06060A] px-5 py-6 text-center">
					<p class="text-text-muted font-medium text-sm">Semrush</p>
					<div class="flex items-baseline justify-center gap-0.5 mt-2 opacity-50">
						<span class="text-3xl font-bold text-text-muted tracking-tight">$129</span>
						<span class="text-text-muted text-xs">/mo</span>
					</div>
					<p class="text-text-muted text-[11px] mt-1.5 opacity-50">Monitor only</p>
				</div>
			</div>
			<div class="px-6 py-4 border-t border-border text-center">
				<p class="text-text-muted text-xs">Profound raised $58M from Sequoia. We built a better tool for 14&times; less.</p>
			</div>
		</div>

		<!-- Bottom note -->
		<div class="mt-10 text-center space-y-2">
			<p class="text-text-muted text-sm">The CLI, GitHub App, GitHub Action, and all 13 framework plugins are <strong class="text-text font-semibold">free on every plan</strong> — including Starter.</p>
			<p class="text-text-muted text-xs">Cancel anytime &middot; No contracts &middot; 14-day money-back guarantee &middot; Prices in USD</p>
		</div>
	</div>
</section>

<style>
	.pricing-card {
		border-radius: 16px;
		position: relative;
	}

	.pricing-card__inner {
		border-radius: 16px;
		border: 1px solid rgba(255,255,255,0.07);
		background: rgba(255,255,255,0.025);
		height: 100%;
		transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
		position: relative;
		overflow: hidden;
	}

	.pricing-card__inner::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 80px;
		background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 100%);
		pointer-events: none;
		border-radius: 16px 16px 0 0;
	}

	.pricing-card:hover .pricing-card__inner {
		transform: translateY(-3px);
		border-color: rgba(255,255,255,0.13);
		box-shadow: 0 16px 48px rgba(0,0,0,0.35);
	}

	/* Pro card */
	.pricing-card--pro .pricing-card__inner {
		border-color: rgba(232,89,12,0.3);
		background: linear-gradient(160deg, rgba(232,89,12,0.09) 0%, rgba(255,255,255,0.02) 45%);
		box-shadow: 0 0 0 1px rgba(232,89,12,0.1), 0 8px 32px rgba(0,0,0,0.2);
	}

	.pricing-card--pro:hover .pricing-card__inner {
		border-color: rgba(232,89,12,0.5);
		box-shadow: 0 0 0 1px rgba(232,89,12,0.2), 0 16px 48px rgba(232,89,12,0.16), 0 4px 12px rgba(0,0,0,0.4);
	}

	/* Agency card */
	.pricing-card--agency .pricing-card__inner {
		border-color: rgba(99,102,241,0.2);
		background: linear-gradient(160deg, rgba(99,102,241,0.07) 0%, rgba(255,255,255,0.02) 45%);
	}

	.pricing-card--agency:hover .pricing-card__inner {
		border-color: rgba(99,102,241,0.4);
		box-shadow: 0 16px 48px rgba(99,102,241,0.14), 0 4px 12px rgba(0,0,0,0.4);
	}

	/* Feature list */
	.pricing-feature {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.875rem;
		color: var(--color-text-secondary);
		line-height: 1.45;
	}

	.pricing-feature--muted {
		color: var(--color-text-muted);
		opacity: 0.65;
	}

	/* Check circles */
	.pricing-check {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.25rem;
		height: 1.25rem;
		border-radius: 50%;
		font-size: 0.5625rem;
		font-weight: 800;
		background: rgba(34,197,94,0.12);
		color: #22C55E;
		border: 1px solid rgba(34,197,94,0.2);
	}

	.pricing-check--pro {
		background: rgba(232,89,12,0.12);
		color: #E8590C;
		border-color: rgba(232,89,12,0.25);
	}

	.pricing-check--agency {
		background: rgba(99,102,241,0.12);
		color: #818CF8;
		border-color: rgba(99,102,241,0.22);
	}

	.pricing-dash {
		flex-shrink: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.25rem;
		height: 1.25rem;
		font-size: 0.75rem;
		color: var(--color-text-muted);
		opacity: 0.45;
	}

	/* Agency button */
	.btn-agency {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.8125rem 1.75rem;
		background: rgba(99,102,241,0.1);
		border: 1px solid rgba(99,102,241,0.3);
		color: #818CF8;
		font-weight: 600;
		font-size: 0.9375rem;
		border-radius: 8px;
		transition: background 0.16s ease, border-color 0.16s ease, transform 0.16s ease, box-shadow 0.16s ease;
		cursor: pointer;
		text-decoration: none;
		white-space: nowrap;
	}

	.btn-agency:hover {
		background: rgba(99,102,241,0.18);
		border-color: rgba(99,102,241,0.5);
		transform: translateY(-1px);
		box-shadow: 0 8px 24px rgba(99,102,241,0.2);
	}
</style>
