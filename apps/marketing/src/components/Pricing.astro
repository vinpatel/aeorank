---
const tiers = [
	{
		name: "Free",
		price: "$0",
		period: "forever",
		description: "Try the dashboard with basic limits.",
		features: ["1 site", "3 scans per month", "All 8 generated files", "Community support"],
		cta: "Get Started Free",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: true,
		available: true,
	},
	{
		name: "Pro",
		price: "$29",
		period: "/mo",
		description: "Dashboard with history and insights.",
		features: ["Up to 5 sites", "50 scans per month", "Score history charts", "Priority support"],
		cta: "Start Free Trial",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: false,
		available: true,
	},
	{
		name: "API",
		price: "$99",
		period: "/mo",
		description: "Programmatic access and webhooks.",
		features: ["Up to 50 sites", "500 scans per month", "REST API access", "Webhook notifications"],
		cta: "Start Free Trial",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: false,
		available: true,
	},
	{
		name: "Agency",
		price: "$499",
		period: "/mo",
		description: "White-label reports for your clients.",
		features: ["Everything in API", "Unlimited sites", "White-label PDF reports", "Priority support"],
		cta: "Start Free Trial",
		ctaLink: "https://app.aeorank.dev/sign-up",
		highlighted: false,
		available: true,
	},
];
---

<section id="pricing" class="section-spacing border-t border-border px-6">
	<div class="mx-auto max-w-5xl">
		<h2 class="heading-lg">Simple, Honest Pricing</h2>
		<p class="body-lg mt-4 text-text-muted max-w-2xl">
			The CLI is free forever. Pay when you need the dashboard.
		</p>
		<div class="mt-14 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
			{
				tiers.map((tier) => (
					<div
						class:list={[
							"relative flex flex-col rounded-xl p-7 card-hover",
							tier.highlighted
								? "border-2 border-accent-warm bg-accent-warm-light"
								: "border border-border bg-bg",
							!tier.available && "opacity-60",
						]}
					>
						{tier.highlighted && (
							<span class="absolute -top-3 left-6 bg-accent-warm text-white text-xs font-semibold px-3 py-1 rounded-full">
								Available now
							</span>
						)}
						<h3 class="text-lg font-bold text-text font-display">{tier.name}</h3>
						<div class="mt-3 flex items-baseline gap-1">
							<span class="text-4xl font-bold tracking-tight font-display">{tier.price}</span>
							<span class="text-sm text-text-muted">{tier.period}</span>
						</div>
						<p class="mt-3 text-sm text-text-muted">{tier.description}</p>
						<ul class="mt-6 flex-1 space-y-3">
							{tier.features.map((f) => (
								<li class="flex items-start gap-2.5 text-sm text-text">
									<svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="mt-0.5 shrink-0">
										<circle cx="8" cy="8" r="7" fill={tier.available ? "#F0FDF4" : "#f5f5f4"}/>
										<path d="M5.5 8L7.2 9.7L10.5 6.3" stroke={tier.available ? "#16a34a" : "#aaa"} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
									</svg>
									{f}
								</li>
							))}
						</ul>
						{tier.available ? (
							<a href={tier.ctaLink} class:list={[
								"mt-7 text-center",
								tier.highlighted ? "btn-primary" : "btn-secondary"
							]}>
								{tier.cta}
							</a>
						) : (
							<span class="btn-secondary mt-7 text-center cursor-not-allowed opacity-50">
								{tier.cta}
							</span>
						)}
					</div>
				))
			}
		</div>
	</div>
</section>
