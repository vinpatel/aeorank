<section id="pricing" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-5xl">
		<p class="eyebrow text-center">Integrations</p>
		<h2 class="heading-lg text-center mt-3">Works with your stack</h2>
		<p class="body-lg text-center max-w-2xl mx-auto mt-4">Drop-in plugins for 13 frameworks. One config, 9 files, zero maintenance.</p>

		<div class="flex flex-wrap justify-center gap-3 mt-12">
			<a href="https://docs.aeorank.dev/frameworks/next/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Next.js</a>
			<a href="https://docs.aeorank.dev/frameworks/astro/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Astro</a>
			<a href="https://docs.aeorank.dev/frameworks/nuxt/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Nuxt</a>
			<a href="https://docs.aeorank.dev/frameworks/remix/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Remix</a>
			<a href="https://docs.aeorank.dev/frameworks/sveltekit/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">SvelteKit</a>
			<a href="https://docs.aeorank.dev/frameworks/gatsby/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Gatsby</a>
			<a href="https://docs.aeorank.dev/frameworks/shopify/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Shopify</a>
			<a href="https://docs.aeorank.dev/frameworks/11ty/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">11ty</a>
			<a href="https://docs.aeorank.dev/frameworks/vitepress/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">VitePress</a>
			<a href="https://docs.aeorank.dev/frameworks/docusaurus/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">Docusaurus</a>
			<a href="https://docs.aeorank.dev/frameworks/wordpress/" class="card px-5 py-3 text-sm text-text-muted hover:text-text flex items-center gap-2">WordPress</a>
		</div>

		<div class="mt-10 max-w-lg mx-auto rounded-xl bg-[#0A0A0C] border border-border overflow-hidden">
			<div class="px-4 py-2.5 border-b border-border text-xs text-text-muted font-mono">next.config.ts</div>
			<div class="p-5 font-mono text-sm leading-relaxed text-text-muted">
				<span class="text-accent">import</span> {'{'} withAeorank {'}'} <span class="text-accent">from</span> <span class="text-green">"@aeorank/next"</span>;<br/><br/>
				<span class="text-accent">export default</span> withAeorank({'{'}<br/>
				&nbsp;&nbsp;siteName: <span class="text-green">"My Site"</span>,<br/>
				&nbsp;&nbsp;siteUrl: <span class="text-green">"https://example.com"</span>,<br/>
				&nbsp;&nbsp;description: <span class="text-green">"What my site does."</span>,<br/>
				{'}'});<br/>
				<span class="text-text-muted">// → All 9 AEO files served at your site root</span>
			</div>
		</div>
	</div>
</section>
