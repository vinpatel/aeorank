---
// Pricing — each tier rendered as an AEO report card, not a generic tier card
// Letter grade, criteria scored, scorer's note.

const tiers = [
	{
		id: "starter",
		name: "Starter",
		grade: "B",
		price: "$0",
		unit: "/mo",
		hook: "Try everything. No credit card.",
		note: "Good starting posture. Scans are capped, but every generated file is fully usable.",
		scored: [
			{ k: "sites",              v: "1",          on: true  },
			{ k: "dashboard scans",    v: "3/mo",       on: true  },
			{ k: "36-criteria scorer", v: "full",       on: true  },
			{ k: "9 generated files",  v: "all",        on: true  },
			{ k: "CLI (local)",        v: "unlimited",  on: true  },
			{ k: "GitHub App",         v: "included",   on: true  },
			{ k: "11 framework plugins", v: "included", on: true  },
			{ k: "score history",      v: "—",          on: false },
			{ k: "auto-rescan",        v: "—",          on: false },
			{ k: "PDF export",         v: "—",          on: false },
			{ k: "REST API",           v: "—",          on: false },
		],
		cta: { label: "Start free", href: "https://app.aeorank.dev/sign-up", kind: "outline" },
	},
	{
		id: "pro",
		name: "Pro",
		grade: "A",
		price: "$29",
		unit: "/mo",
		hook: "Full monitoring + fix generation.",
		note: "The pragmatic choice for teams shipping a real site. 14× cheaper than the closest competitor.",
		featured: true,
		scored: [
			{ k: "sites",              v: "5",          on: true  },
			{ k: "dashboard scans",    v: "50/mo",      on: true  },
			{ k: "36-criteria scorer", v: "full",       on: true  },
			{ k: "9 generated files",  v: "all",        on: true  },
			{ k: "score history",      v: "30 days",    on: true  },
			{ k: "auto-rescan",        v: "daily/wk/mo",on: true  },
			{ k: "PDF export",         v: "included",   on: true  },
			{ k: "dimension trends",   v: "included",   on: true  },
			{ k: "priority support",   v: "—",          on: false },
			{ k: "REST API",           v: "—",          on: false },
		],
		cta: { label: "Start Pro — $29", href: "https://app.aeorank.dev/sign-up", kind: "ink" },
	},
	{
		id: "agency",
		name: "Agency",
		grade: "A+",
		price: "$99",
		unit: "/mo",
		hook: "Manage 50 client sites at scale.",
		note: "Built for teams delivering AEO as a service. Bulk endpoints, webhooks, client-ready exports.",
		scored: [
			{ k: "sites",              v: "50",         on: true  },
			{ k: "dashboard scans",    v: "500/mo",     on: true  },
			{ k: "REST API",           v: "included",   on: true  },
			{ k: "bulk scan endpoints",v: "included",   on: true  },
			{ k: "webhooks",           v: "included",   on: true  },
			{ k: "client-ready PDFs",  v: "included",   on: true  },
			{ k: "priority support",   v: "included",   on: true  },
			{ k: "everything in Pro",  v: "included",   on: true  },
		],
		cta: { label: "Start Agency — $99", href: "https://app.aeorank.dev/sign-up", kind: "outline" },
	},
];

const competitors = [
	{ name: "Profound",  price: "$399", note: "monitor only" },
	{ name: "Otterly",   price: "$99",  note: "monitor only" },
	{ name: "Scrunch",   price: "$500", note: "monitor only" },
	{ name: "Semrush",   price: "$129", note: "SEO-first" },
];
---

<section id="pricing" class="section">
	<div class="wrap rail">
		<span class="rail-tick" style="top:0"></span>
		<span class="rail-coord" style="top:0">$</span>

		<div class="section-head">
			<div>
				<p class="t-label">// pricing</p>
				<h2 class="t-h1 mt-2">Pricing, rendered as a report card.</h2>
				<p class="t-body mt-3 max-w-[58ch]">
					Same scoring engine on every plan. We don't gate the 36 criteria, the 9 generated files, or the CLI. You pay for convenience (history, auto-rescan, APIs), never the product's real work.
				</p>
			</div>
			<div class="section-meta">
				<span>3&nbsp;<b>plans</b></span>
				<span>$29&nbsp;<b>median</b></span>
				<span>cancel&nbsp;<b>any time</b></span>
			</div>
		</div>

		<div class="tiers" data-reveal>
			{tiers.map(t => (
				<article class={`tier ${t.featured ? "tier--featured" : ""} cropped`} data-tier={t.id}>
					<span class="cr-tl" aria-hidden="true"></span>
					<span class="cr-br" aria-hidden="true"></span>

					{/* Report-card header */}
					<header class="tier__hd">
						<div>
							<p class="t-label">{t.id === "pro" ? "most teams" : t.name.toLowerCase()} plan</p>
							<h3 class="tier__name">{t.name}</h3>
						</div>
						<div class={`tier__grade tier__grade--${t.grade.replace("+","plus").toLowerCase()}`} aria-label={`grade ${t.grade}`}>
							<span class="font-serif">{t.grade}</span>
						</div>
					</header>

					<div class="tier__price">
						<span class="tier__price-num">{t.price}</span>
						<span class="tier__price-unit font-mono">{t.unit}</span>
					</div>
					<p class="t-body tier__hook">{t.hook}</p>

					<hr class="hr-hair my-5" />

					<dl class="tier__rubric">
						{t.scored.map(s => (
							<div class={`tier__rubric-row ${s.on ? "" : "is-off"}`}>
								<dt class="font-mono text-[11px]">
									<span class={`sig ${s.on ? "sig-ok" : "ink-3"}`}>
										{s.on ? "✓" : "—"}
									</span>
									<span class="ml-2">{s.k}</span>
								</dt>
								<dd class="font-mono text-[11px] ink-3">{s.v}</dd>
							</div>
						))}
					</dl>

					<footer class="tier__ft">
						<p class="tier__note t-caption font-serif">
							{t.note}
						</p>
						<a
							href={t.cta.href}
							class={`btn btn-${t.cta.kind === "ink" ? "ink" : "outline"} w-full justify-center mt-4`}
						>{t.cta.label}</a>
					</footer>
				</article>
			))}
		</div>

		<!-- Competitor strip -->
		<div class="pricing-cmp mt-8" data-reveal>
			<header class="pricing-cmp__hd">
				<span class="t-label">// what the others charge</span>
				<span class="font-mono text-[10.5px] ink-3 ml-auto">monitoring only · none generate the 9 files</span>
			</header>
			<div class="pricing-cmp__grid">
				<div class="pricing-cmp__cell pricing-cmp__cell--us">
					<span class="t-label" style="color:var(--color-mark-ink)">aeorank pro</span>
					<p class="pricing-cmp__num font-mono">$29<span class="ink-3 text-[11px] font-mono">/mo</span></p>
					<p class="sig sig-ok">score · fix · monitor</p>
				</div>
				{competitors.map(c => (
					<div class="pricing-cmp__cell">
						<span class="t-label">{c.name}</span>
						<p class="pricing-cmp__num font-mono ink-3">{c.price}<span class="text-[11px]">/mo</span></p>
						<p class="t-caption">{c.note}</p>
					</div>
				))}
			</div>
			<footer class="pricing-cmp__ft">
				<span class="font-mono text-[10.5px] ink-3">Profound raised $58M. We're 14× cheaper, MIT licensed, and self-hostable.</span>
			</footer>
		</div>
	</div>
</section>

<style>
	.tiers {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
		align-items: stretch;
	}

	.tier {
		background: var(--color-page);
		border: 1px solid var(--color-ink);
		border-radius: 4px;
		padding: 22px 22px 18px;
		display: flex;
		flex-direction: column;
		min-height: 560px;
	}
	.tier--featured {
		background:
			linear-gradient(180deg, rgba(232,89,12,0.06) 0%, transparent 30%),
			var(--color-page);
		outline: 1px solid var(--color-mark);
		outline-offset: -1px;
	}

	.tier__hd {
		display: flex;
		align-items: start;
		justify-content: space-between;
		gap: 12px;
		margin-bottom: 14px;
	}
	.tier__name {
		font-size: 20px;
		font-weight: 620;
		letter-spacing: -0.018em;
		margin-top: 3px;
	}
	.tier__grade {
		font-size: 44px;
		line-height: 0.85;
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-ink);
		border-radius: 3px;
		background: var(--color-paper-2);
	}
	.tier__grade--b  { color: var(--color-ink); }
	.tier__grade--a  { color: var(--color-ok); border-color: var(--color-ok); background: rgba(15,125,75,0.06); }
	.tier__grade--aplus {
		color: var(--color-ok);
		border-color: var(--color-ok);
		background: rgba(15,125,75,0.09);
	}
	.tier__grade--aplus span::after {
		content: "+";
		display: inline-block;
		margin-left: -4px;
	}

	.tier__price {
		display: flex;
		align-items: baseline;
		gap: 4px;
		margin-bottom: 6px;
	}
	.tier__price-num {
		font-size: 40px;
		font-weight: 640;
		letter-spacing: -0.035em;
		line-height: 1;
	}
	.tier__price-unit { color: var(--color-ink-3); font-size: 13px; }

	.tier__hook { color: var(--color-ink-2); font-size: 14px; }

	.tier__rubric {
		display: flex;
		flex-direction: column;
		margin: 0;
		border-top: 1px dashed var(--color-rule-2);
	}
	.tier__rubric-row {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 10px;
		padding: 7px 0;
		border-bottom: 1px dashed var(--color-rule);
		align-items: baseline;
	}
	.tier__rubric-row:last-child { border-bottom: none; }
	.tier__rubric-row.is-off dt,
	.tier__rubric-row.is-off dd { color: var(--color-ink-3); opacity: 0.7; }

	.tier__ft {
		margin-top: auto;
		padding-top: 14px;
	}
	.tier__note {
		font-size: 14px;
		color: var(--color-ink-2);
		line-height: 1.45;
		font-style: italic;
		padding-left: 10px;
		border-left: 2px solid var(--color-rule-2);
	}

	/* Competitor strip */
	.pricing-cmp {
		border: 1px solid var(--color-rule);
		border-radius: 4px;
		background: var(--color-page);
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
		overflow: hidden;
	}
	.pricing-cmp__hd {
		display: flex;
		align-items: center;
		padding: 10px 16px;
		border-bottom: 1px solid var(--color-rule);
		background: var(--color-paper-2);
	}
	.pricing-cmp__grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
	}
	.pricing-cmp__cell {
		padding: 18px 16px 16px;
		border-right: 1px solid var(--color-rule);
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.pricing-cmp__cell:last-child { border-right: none; }
	.pricing-cmp__cell--us { background: rgba(232,89,12,0.04); }
	.pricing-cmp__num {
		font-size: 24px;
		font-weight: 620;
		letter-spacing: -0.03em;
		color: var(--color-ink);
		line-height: 1.1;
		margin: 4px 0 4px;
	}
	.pricing-cmp__ft {
		padding: 10px 16px;
		border-top: 1px solid var(--color-rule);
		background: var(--color-paper-2);
	}

	@media (max-width: 980px) {
		.tiers { grid-template-columns: 1fr; }
	}
	@media (max-width: 720px) {
		.pricing-cmp__grid { grid-template-columns: repeat(2, 1fr); }
		.pricing-cmp__cell:nth-child(2n) { border-right: none; }
		.pricing-cmp__cell:nth-child(-n+4) { border-bottom: 1px solid var(--color-rule); }
	}
</style>
