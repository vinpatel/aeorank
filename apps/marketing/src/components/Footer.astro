---
// Footer — treated as the "session end" of an inspector run
// Final score card → final CTA → site map.

const nowIso = new Date().toISOString();
---

<footer id="footer" class="footer">

	<!-- CTA block — the capstone star push -->
	<div class="footer-cta">
		<div class="wrap rail">
			<span class="rail-tick" style="top:0"></span>
			<span class="rail-coord" style="top:0">END</span>

			<div class="footer-cta__grid">
				<div>
					<p class="t-label">// scan complete</p>
					<h2 class="t-h1 mt-2">
						Score your site.<br/>
						<span class="font-serif">Star the project.</span>
					</h2>
					<p class="t-body mt-3 max-w-[54ch]">
						Thirty seconds to find the 9 broken signals. An afternoon to fix all 9. One click to help the next team find an open-source AEO toolkit instead of a $299/mo dashboard.
					</p>

					<div class="footer-cta__btns">
						<a href="https://github.com/vinpatel/aeorank" class="btn btn-ink btn-lg" target="_blank" rel="noopener">
							<svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25l2.39 4.84L15.75 6l-3.88 3.78.92 5.34L8 12.6l-4.79 2.52.92-5.34L.25 6l5.36-.91L8 .25z"/></svg>
							Star on GitHub
							<span class="font-mono text-[11px] opacity-70 ml-1" data-gh-stars-prefix>
								<span class="gh-dot">·</span>&nbsp;<span data-gh-stars></span>
							</span>
						</a>
						<a href="https://app.aeorank.dev/sign-up" class="btn btn-outline btn-lg">
							Scan my site &nbsp;→
						</a>
					</div>
				</div>

				<!-- Receipt card -->
				<aside class="footer-receipt cropped">
					<span class="cr-tl" aria-hidden="true"></span>
					<span class="cr-br" aria-hidden="true"></span>
					<header class="footer-receipt__hd">
						<span class="font-mono text-[10.5px] ink-3">AEORANK · SESSION RECEIPT</span>
						<span class="t-label ink-3">#0000047</span>
					</header>
					<div class="footer-receipt__body">
						<div class="footer-receipt__row">
							<span class="font-mono text-[11px] ink-3">host</span>
							<span class="font-mono text-[11px] ink">your-site.com</span>
						</div>
						<div class="footer-receipt__row">
							<span class="font-mono text-[11px] ink-3">checks</span>
							<span class="font-mono text-[11px] ink">36 run · 9 fail · 11 warn · 16 pass</span>
						</div>
						<div class="footer-receipt__row">
							<span class="font-mono text-[11px] ink-3">files</span>
							<span class="font-mono text-[11px] ink">9 generated</span>
						</div>
						<div class="footer-receipt__row">
							<span class="font-mono text-[11px] ink-3">runtime</span>
							<span class="font-mono text-[11px] ink">0.93s</span>
						</div>
						<div class="footer-receipt__row">
							<span class="font-mono text-[11px] ink-3">at</span>
							<span class="font-mono text-[11px] ink">{nowIso.slice(0,19).replace("T", " ")}Z</span>
						</div>

						<hr class="hr-tick mt-3 mb-3" />

						<div class="footer-receipt__total">
							<span class="t-label">score</span>
							<span class="footer-receipt__total-num font-mono">31<span class="ink-3 text-[14px]">/100</span></span>
							<span class="footer-receipt__grade font-serif">F</span>
						</div>
					</div>
					<footer class="footer-receipt__ft">
						<span class="font-mono text-[10.5px] ink-3">thank you · thin paper · keep for your records</span>
					</footer>
				</aside>
			</div>
		</div>
	</div>

	<!-- Sitemap + legal -->
	<div class="footer-meta">
		<div class="wrap footer-meta__inner">

			<!-- Wordmark -->
			<div class="footer-meta__brand">
				<a href="/" class="footer-brand" aria-label="AEOrank home">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
						<rect x="1" y="1" width="22" height="22" rx="2" fill="none" stroke="#111" stroke-width="1.4"/>
						<path d="M5 17 L8 7 L11 17" stroke="#111" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
						<path d="M6 14 H10" stroke="#111" stroke-width="1.6" stroke-linecap="round"/>
						<circle cx="17" cy="12" r="3" stroke="#111" stroke-width="1.6" fill="none"/>
						<path d="M17 12 L20 15" stroke="#E8590C" stroke-width="1.8" stroke-linecap="round"/>
					</svg>
					<span class="footer-brand__word">AEOrank</span>
					<span class="footer-brand__ver">v2</span>
				</a>
				<p class="t-caption mt-3 max-w-[32ch]">
					AI-visibility scoring, file generation, and CI for teams that need to be cited by ChatGPT, Perplexity, Claude, and Gemini.
				</p>
				<div class="footer-meta__pills">
					<span class="sig sig-ok"><span class="dot dot-ok"></span>MIT</span>
					<span class="font-mono text-[11px] ink-3">·</span>
					<span class="sig sig-ok"><span class="dot dot-ok"></span>self-hostable</span>
					<span class="font-mono text-[11px] ink-3">·</span>
					<span class="sig sig-ok"><span class="dot dot-ok"></span>zero lock-in</span>
				</div>
			</div>

			<!-- Link cols -->
			<nav class="footer-meta__cols" aria-label="Footer">
				<div>
					<p class="t-label">product</p>
					<ul>
						<li><a href="#hero" class="ilink">Overview</a></li>
						<li><a href="#scan" class="ilink">Scanner</a></li>
						<li><a href="#files" class="ilink">Generated files</a></li>
						<li><a href="#pricing" class="ilink">Pricing</a></li>
						<li><a href="/scoreboard" class="ilink">Scoreboard</a></li>
					</ul>
				</div>
				<div>
					<p class="t-label">developers</p>
					<ul>
						<li><a href="https://docs.aeorank.dev" class="ilink" target="_blank" rel="noopener">Docs</a></li>
						<li><a href="https://github.com/vinpatel/aeorank" class="ilink" target="_blank" rel="noopener">GitHub</a></li>
						<li><a href="https://github.com/apps/aeorank" class="ilink" target="_blank" rel="noopener">GitHub App</a></li>
						<li><a href="https://github.com/marketplace/actions/aeorank-aeo-scanner" class="ilink" target="_blank" rel="noopener">GitHub Action</a></li>
						<li><a href="https://github.com/vinpatel/aeorank/releases" class="ilink" target="_blank" rel="noopener">Releases</a></li>
					</ul>
				</div>
				<div>
					<p class="t-label">company</p>
					<ul>
						<li><a href="mailto:hello@aeorank.dev" class="ilink">hello@aeorank.dev</a></li>
						<li><a href="/privacy" class="ilink">Privacy</a></li>
						<li><a href="https://github.com/vinpatel/aeorank/blob/main/LICENSE" class="ilink" target="_blank" rel="noopener">License</a></li>
						<li><a href="https://github.com/vinpatel/aeorank/security" class="ilink" target="_blank" rel="noopener">Security</a></li>
					</ul>
				</div>
			</nav>
		</div>

		<!-- Sponsored by -->
		<div class="wrap footer-powered">
			<span class="font-mono text-[10.5px] ink-3 footer-powered__label">// sponsored by</span>
			<a href="https://linx.agency" class="footer-powered__link" target="_blank" rel="noopener" aria-label="Linx Agency">
				<img src="/partners/linx.png" alt="Linx Agency" width="257" height="57" loading="lazy" />
			</a>
			<span class="font-mono text-[10.5px] ink-3 footer-powered__amp">&amp;</span>
			<a href="https://mindtrades.com" class="footer-powered__link" target="_blank" rel="noopener" aria-label="Mindtrades">
				<img src="/partners/mindtrades.png" alt="Mindtrades" width="1196" height="196" loading="lazy" />
			</a>
		</div>

		<!-- End bar -->
		<div class="wrap footer-endbar">
			<span class="font-mono text-[10.5px] ink-3">// © {new Date().getFullYear()} AEOrank · MIT</span>
			<span class="font-mono text-[10.5px] ink-3">SCAN COMPLETE · build {nowIso.slice(0,10)}</span>
			<span class="font-mono text-[10.5px] ink-3 ml-auto">
				<a href="https://github.com/vinpatel/aeorank" class="ilink">source on github&nbsp;→</a>
			</span>
		</div>
	</div>
</footer>

<style>
	.footer { border-top: 1px solid var(--color-rule); }

	.footer-brand {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--color-ink);
		text-decoration: none;
	}
	.footer-brand__word { font-size: 14px; font-weight: 620; letter-spacing: -0.018em; }
	.footer-brand__ver {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--color-ink-3);
		border: 1px solid var(--color-rule-2);
		border-radius: 3px;
		padding: 1px 5px 0;
	}

	/* ── Capstone CTA ── */
	.footer-cta {
		padding: clamp(3.5rem, 6vw, 5rem) 0 clamp(3rem, 5vw, 4rem);
		background:
			radial-gradient(ellipse at 20% 0%, rgba(232,89,12,0.05) 0%, transparent 60%),
			var(--color-paper-2);
	}
	.footer-cta__grid {
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 48px;
		align-items: start;
		padding-right: clamp(1.25rem, 4vw, 3.25rem);
	}
	.footer-cta__btns {
		display: flex;
		gap: 10px;
		margin-top: 22px;
		flex-wrap: wrap;
	}

	/* ── Receipt card ── */
	.footer-receipt {
		background: var(--color-page);
		border: 1px solid var(--color-ink);
		border-radius: 4px;
		padding: 14px 16px 12px;
		position: relative;
	}
	.footer-receipt__hd {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 8px;
		padding-bottom: 10px;
		border-bottom: 1px dashed var(--color-rule-2);
		margin-bottom: 10px;
	}
	.footer-receipt__row {
		display: grid;
		grid-template-columns: 64px 1fr;
		gap: 10px;
		padding: 3px 0;
	}
	.footer-receipt__total {
		display: flex;
		align-items: baseline;
		gap: 10px;
	}
	.footer-receipt__total-num {
		font-size: 36px;
		font-weight: 620;
		letter-spacing: -0.035em;
		line-height: 1;
		color: var(--color-ink);
	}
	.footer-receipt__grade {
		margin-left: auto;
		font-size: 44px;
		line-height: 1;
		color: var(--color-fail);
	}
	.footer-receipt__ft {
		margin-top: 12px;
		padding-top: 10px;
		border-top: 1px dashed var(--color-rule-2);
	}

	/* ── Sitemap ── */
	.footer-meta {
		padding: 40px 0 24px;
		background: var(--color-paper);
	}
	.footer-meta__inner {
		display: grid;
		grid-template-columns: 1.2fr 2fr;
		gap: 48px;
		padding-right: clamp(1.25rem, 4vw, 3.25rem);
	}

	.footer-meta__pills {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-top: 14px;
	}

	.footer-meta__cols {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
	}
	.footer-meta__cols ul {
		list-style: none;
		margin: 12px 0 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.footer-meta__cols li a { font-size: 13px; }

	.footer-powered {
		display: flex;
		align-items: center;
		gap: 18px;
		margin-top: 32px;
		padding-top: 16px;
		border-top: 1px dashed var(--color-rule);
		flex-wrap: wrap;
	}
	.footer-powered__label { letter-spacing: 0.02em; }
	.footer-powered__amp { opacity: 0.6; }
	.footer-powered__link {
		display: inline-flex;
		align-items: center;
		opacity: 0.72;
		transition: opacity 180ms ease;
	}
	.footer-powered__link:hover { opacity: 1; }
	.footer-powered__link img {
		height: 22px;
		width: auto;
		display: block;
		filter: grayscale(1) contrast(1.05);
	}
	.footer-powered__link:hover img { filter: none; }

	.footer-endbar {
		display: flex;
		align-items: center;
		gap: 16px;
		margin-top: 20px;
		padding-top: 16px;
		border-top: 1px dashed var(--color-rule);
		flex-wrap: wrap;
	}

	[data-gh-stars-prefix] .gh-dot { opacity: 0; transition: opacity 200ms ease; }
	[data-gh-stars-prefix]:has([data-gh-stars]:not(:empty)) .gh-dot { opacity: 1; }

	@media (max-width: 980px) {
		.footer-cta__grid { grid-template-columns: 1fr; }
		.footer-meta__inner { grid-template-columns: 1fr; gap: 24px; }
	}
	@media (max-width: 640px) {
		.footer-meta__cols { grid-template-columns: repeat(2, 1fr); }
	}
</style>
