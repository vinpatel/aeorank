---
---
<section id="who-its-for" class="px-6 py-20 md:py-28 border-t border-[rgba(255,255,255,0.06)]">
	<div class="mx-auto max-w-5xl">
		<p class="text-[#06B6D4] text-xs font-bold uppercase tracking-[0.12em] text-center">Who it's for</p>
		<h2 class="text-3xl md:text-4xl font-bold text-white text-center mt-3 tracking-tight leading-tight">
			Built for how you work
		</h2>
		<p class="text-[#A1A1AA] text-base md:text-lg text-center max-w-2xl mx-auto mt-4 leading-relaxed">
			Whether you ship code, manage clients, or run a company — AEOrank fits your workflow.
		</p>

		<div class="space-y-5 mt-14">

			<!-- ─── Developer Panel ─── -->
			<div class="ap-card animate-on-scroll" style="--pc: #E8590C; --pc-rgb: 232,89,12; --pc-glow: rgba(232,89,12,0.07); --pc-border: rgba(232,89,12,0.32);">
				<div class="ap-left-rule" style="background: linear-gradient(180deg, #E8590C 0%, rgba(232,89,12,0.15) 100%);"></div>
				<div class="ap-inner grid md:grid-cols-[1fr_320px] gap-10">

					<!-- Left: value props -->
					<div>
						<p class="ap-eyebrow" style="color: #E8590C;">For Developers</p>
						<h3 class="text-white text-xl md:text-2xl font-bold mt-2 tracking-tight leading-snug">
							AEO in your pipeline. Not your browser.
						</h3>
						<p class="text-[#A1A1AA] text-sm leading-relaxed mt-3">
							The only AEO tool that lives in your terminal, your CI, and your framework — not a SaaS dashboard you forget to check.
						</p>
						<ul class="mt-7 space-y-5">
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(232,89,12,0.1); color: #E8590C; border-color: rgba(232,89,12,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 17l6-5-6-5"/><path d="M12 19h8"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">CLI-first, zero magic</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed"><code class="text-[10px] bg-white/5 px-1.5 py-0.5 rounded font-mono">npx aeorank-cli scan &lt;url&gt;</code> — runs anywhere, no account, no API key. Colored output with per-criterion scores.</p>
								</div>
							</li>
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(232,89,12,0.1); color: #E8590C; border-color: rgba(232,89,12,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">Block AEO regressions in CI</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">GitHub App: one-click, zero YAML. GitHub Action: <code class="text-[10px] bg-white/5 px-1.5 py-0.5 rounded font-mono">fail-below</code> thresholds. Both post Check Runs with full breakdowns.</p>
								</div>
							</li>
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(232,89,12,0.1); color: #E8590C; border-color: rgba(232,89,12,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">13 framework plugins, 3 lines of config</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">Next.js, Astro, Nuxt, and 10 more. Serves all 9 generated files at your site root on build. MIT licensed, self-hostable.</p>
								</div>
							</li>
						</ul>
					</div>

					<!-- Right: quote + CTA -->
					<div class="flex flex-col gap-5">
						<div class="ap-quote-card" style="--qc: rgba(232,89,12,0.06); --qb: rgba(232,89,12,0.18);">
							<div class="ap-quote-mark" style="color: #E8590C;">&ldquo;</div>
							<p class="text-[#D4D4D8] text-sm italic leading-relaxed relative z-10">
								"Dropped it in next.config.ts, ran the CI check, and caught a robots.txt regression before it shipped."
							</p>
							<footer class="text-[#6B6B76] text-xs mt-3 relative z-10">— Senior engineer, DevTools startup</footer>
							<div class="ap-metric mt-4 pt-4 border-t border-white/5" style="color: #E8590C;">
								<span class="ap-metric-num" style="filter: drop-shadow(0 0 10px rgba(232,89,12,0.6));">411</span>
								<span class="text-[#6B6B76] text-xs font-medium">tests. Same score every run.</span>
							</div>
						</div>
						<div class="flex flex-col gap-2.5">
							<a href="https://github.com/apps/aeorank" class="ap-btn ap-btn--primary" style="--ab: #E8590C; --ab-rgb: 232,89,12;">Install GitHub App</a>
							<a href="https://docs.aeorank.dev/getting-started" class="ap-btn ap-btn--ghost" style="--ab: #E8590C; --ab-rgb: 232,89,12;">Read the Docs</a>
						</div>
					</div>
				</div>
			</div>

			<!-- ─── Agency Panel ─── -->
			<div class="ap-card animate-on-scroll" style="--pc: #6366F1; --pc-rgb: 99,102,241; --pc-glow: rgba(99,102,241,0.07); --pc-border: rgba(99,102,241,0.32);">
				<div class="ap-left-rule" style="background: linear-gradient(180deg, #6366F1 0%, rgba(99,102,241,0.15) 100%);"></div>
				<div class="ap-inner grid md:grid-cols-[1fr_320px] gap-10">

					<!-- Left: value props -->
					<div>
						<p class="ap-eyebrow" style="color: #818CF8;">For Agencies</p>
						<h3 class="text-white text-xl md:text-2xl font-bold mt-2 tracking-tight leading-snug">
							Client AI visibility reports. In 30 seconds per site.
						</h3>
						<p class="text-[#A1A1AA] text-sm leading-relaxed mt-3">
							Scan any client URL, get a scored report across 36 criteria, and deliver AI optimization as a service — using a free tool you can self-host.
						</p>
						<ul class="mt-7 space-y-5">
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(99,102,241,0.1); color: #818CF8; border-color: rgba(99,102,241,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">Benchmark clients against competitors</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">Our Scoreboard shows 100 funded startups averaging 42/100. Your clients are probably invisible to AI. Now you have the data to prove it.</p>
								</div>
							</li>
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(99,102,241,0.1); color: #818CF8; border-color: rgba(99,102,241,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">Deliverable files, not dashboard links</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">Every scan generates 9 production files — llms.txt, schema.json, ai.txt, robots patch. Hand them to the client. They deploy. You look like a wizard.</p>
								</div>
							</li>
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(99,102,241,0.1); color: #818CF8; border-color: rgba(99,102,241,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">Agency plan: 50 sites, 500 scans, $99/mo</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">No per-seat pricing. CLI is MIT licensed and always free. API access included. Competitors charge $500/mo for less.</p>
								</div>
							</li>
						</ul>
					</div>

					<!-- Right: quote + CTA -->
					<div class="flex flex-col gap-5">
						<div class="ap-quote-card" style="--qc: rgba(99,102,241,0.06); --qb: rgba(99,102,241,0.18);">
							<div class="ap-quote-mark" style="color: #818CF8;">&ldquo;</div>
							<p class="text-[#D4D4D8] text-sm italic leading-relaxed relative z-10">
								"We added AEO audits to our SEO retainer. Clients love the score — they understand 67/100 immediately."
							</p>
							<footer class="text-[#6B6B76] text-xs mt-3 relative z-10">— Founder, boutique digital agency</footer>
							<div class="ap-metric mt-4 pt-4 border-t border-white/5" style="color: #818CF8;">
								<span class="ap-metric-num" style="filter: drop-shadow(0 0 10px rgba(99,102,241,0.6));">42</span>
								<span class="text-[#6B6B76] text-xs font-medium">/100 avg industry score</span>
							</div>
						</div>
						<div class="flex flex-col gap-2.5">
							<a href="https://docs.aeorank.dev/getting-started" class="ap-btn ap-btn--primary" style="--ab: #6366F1; --ab-rgb: 99,102,241;">Scan a Client Site Free</a>
							<a href="/scoreboard" class="ap-btn ap-btn--ghost" style="--ab: #6366F1; --ab-rgb: 99,102,241;">See Industry Benchmarks</a>
						</div>
					</div>
				</div>
			</div>

			<!-- ─── Founder Panel ─── -->
			<div class="ap-card animate-on-scroll" style="--pc: #F59E0B; --pc-rgb: 245,158,11; --pc-glow: rgba(245,158,11,0.07); --pc-border: rgba(245,158,11,0.32);">
				<div class="ap-left-rule" style="background: linear-gradient(180deg, #F59E0B 0%, rgba(245,158,11,0.15) 100%);"></div>
				<div class="ap-inner grid md:grid-cols-[1fr_320px] gap-10">

					<!-- Left: value props -->
					<div>
						<p class="ap-eyebrow" style="color: #F59E0B;">For Founders</p>
						<h3 class="text-white text-xl md:text-2xl font-bold mt-2 tracking-tight leading-snug">
							ChatGPT recommends your competitors. Not you.
						</h3>
						<p class="text-[#A1A1AA] text-sm leading-relaxed mt-3">
							AI search drives 40% of web discovery and converts at 15.9% — higher than Google. Your score tells you how visible you are. The generated files start fixing it immediately.
						</p>
						<ul class="mt-7 space-y-5">
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(245,158,11,0.1); color: #F59E0B; border-color: rgba(245,158,11,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">A number you can actually act on</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">Your AEO score is 0–100, graded A+ through F. You see exactly which criteria you're failing and why. No vague advice — specific gaps, ranked by impact.</p>
								</div>
							</li>
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(245,158,11,0.1); color: #F59E0B; border-color: rgba(245,158,11,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">Your competitors score 42/100 on average</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">We scanned 100 funded startups. Stripe scores 57. OpenAI scores 16. If billion-dollar companies are invisible to AI, your site probably is too — and it's fixable in an afternoon.</p>
								</div>
							</li>
							<li class="ap-item">
								<div class="ap-item-icon" style="background: rgba(245,158,11,0.1); color: #F59E0B; border-color: rgba(245,158,11,0.2);">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
								</div>
								<div>
									<p class="text-white text-sm font-semibold">30 seconds to your first score</p>
									<p class="text-[#A1A1AA] text-xs mt-1 leading-relaxed">No account, no credit card, no sales call. Gartner predicts 50% decline in organic search traffic by 2028. This is the fix.</p>
								</div>
							</li>
						</ul>
					</div>

					<!-- Right: quote + CTA -->
					<div class="flex flex-col gap-5">
						<div class="ap-quote-card" style="--qc: rgba(245,158,11,0.06); --qb: rgba(245,158,11,0.18);">
							<div class="ap-quote-mark" style="color: #F59E0B;">&ldquo;</div>
							<p class="text-[#D4D4D8] text-sm italic leading-relaxed relative z-10">
								"Had no idea AI couldn't see my site. Scored 31/100, fixed the llms.txt and schema, rescanned at 68 in one afternoon. Now we show up in Perplexity answers."
							</p>
							<footer class="text-[#6B6B76] text-xs mt-3 relative z-10">— Founder, B2B SaaS (pre-Series A)</footer>
							<div class="ap-metric mt-4 pt-4 border-t border-white/5" style="color: #F59E0B;">
								<span class="ap-metric-num" style="filter: drop-shadow(0 0 10px rgba(245,158,11,0.6));">31&rarr;68</span>
								<span class="text-[#6B6B76] text-xs font-medium">in one afternoon</span>
							</div>
						</div>
						<div class="flex flex-col gap-2.5">
							<a href="https://github.com/apps/aeorank" class="ap-btn ap-btn--primary" style="--ab: #D97706; --ab-rgb: 217,119,6;">Check My Score — Free</a>
							<a href="/scoreboard" class="ap-btn ap-btn--ghost" style="--ab: #F59E0B; --ab-rgb: 245,158,11;">See How Others Score</a>
						</div>
					</div>
				</div>
			</div>

		</div>
	</div>
</section>

<style>
	/* ── Card shell ── */
	.ap-card {
		position: relative;
		border-radius: 16px;
		border: 1px solid rgba(255,255,255,0.07);
		background: rgba(255,255,255,0.03);
		overflow: hidden;
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
	}
	.ap-card:hover {
		transform: translateY(-2px);
		border-color: var(--pc-border);
		box-shadow:
			0 24px 56px rgba(0,0,0,0.42),
			0 0 0 1px rgba(var(--pc-rgb), 0.1),
			0 0 80px -20px rgba(var(--pc-rgb), 0.25);
	}

	/* Ambient left glow */
	.ap-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 360px;
		height: 100%;
		background: radial-gradient(ellipse at 0% 40%, var(--pc-glow) 0%, transparent 70%);
		pointer-events: none;
		transition: opacity 0.3s ease;
		opacity: 0.6;
	}
	.ap-card:hover::before { opacity: 1; }

	/* Left accent rule */
	.ap-left-rule {
		position: absolute;
		top: 0;
		left: 0;
		width: 3px;
		height: 100%;
	}

	/* Inner padding */
	.ap-inner {
		position: relative;
		z-index: 1;
		padding: 2rem 2rem 2rem 2.5rem;
	}

	/* Eyebrow */
	.ap-eyebrow {
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	/* List item */
	.ap-item {
		display: flex;
		gap: 0.875rem;
		align-items: flex-start;
	}
	.ap-item-icon {
		width: 30px;
		height: 30px;
		border-radius: 7px;
		border: 1px solid;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		margin-top: 1px;
	}

	/* Quote card */
	.ap-quote-card {
		position: relative;
		background: var(--qc);
		border: 1px solid var(--qb);
		border-radius: 12px;
		padding: 1.25rem 1.25rem 1rem;
		overflow: hidden;
		flex: 1;
	}
	.ap-quote-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(255,255,255,0.025) 0%, transparent 60%);
		pointer-events: none;
	}

	/* Decorative quote mark */
	.ap-quote-mark {
		font-size: 3.5rem;
		line-height: 0.7;
		font-family: Georgia, 'Times New Roman', serif;
		opacity: 0.2;
		display: block;
		margin-bottom: 0.75rem;
	}

	/* Metric */
	.ap-metric {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
	}
	.ap-metric-num {
		font-size: 1.625rem;
		font-weight: 800;
		letter-spacing: -0.04em;
		line-height: 1;
	}

	/* Buttons */
	.ap-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.6rem 1rem;
		border-radius: 9px;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.18s ease;
	}
	.ap-btn--primary {
		background: var(--ab);
		color: white;
		border: 1px solid transparent;
	}
	.ap-btn--primary:hover {
		opacity: 0.87;
		box-shadow: 0 4px 18px rgba(var(--ab-rgb), 0.45);
	}
	.ap-btn--ghost {
		background: rgba(var(--ab-rgb), 0.08);
		color: var(--ab);
		border: 1px solid rgba(var(--ab-rgb), 0.2);
	}
	.ap-btn--ghost:hover {
		background: rgba(var(--ab-rgb), 0.13);
		border-color: rgba(var(--ab-rgb), 0.35);
	}
</style>
