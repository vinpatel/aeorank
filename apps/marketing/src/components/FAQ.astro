---
const faqs = [
	{
		q: "Can I use this to report AI visibility to clients?",
		a: "Yes. The dashboard at app.aeorank.dev lets you scan multiple sites, compare scores across your client portfolio, and export reports. You can show clients exactly where they score against industry benchmarks and which competitors are outranking them in AI answers."
	},
	{
		q: "My customers use ChatGPT and Perplexity. Why isn't my brand showing up?",
		a: "AI engines don't index sites the way Google does. They look for specific signals: structured files (llms.txt, ai.txt), AI-readable content formatting, proper schema markup, and correctly configured crawler access. Most sites fail at multiple points — which is why even well-known brands score 40/100 or below. AEOrank identifies exactly which signals you're missing and generates the files to fix them."
	},
	{
		q: "What is AEO and why should I care?",
		a: "Answer Engine Optimization. AI search engines (ChatGPT, Perplexity, Claude, Gemini) now drive 40% of web discovery and convert visitors at 15.9% — higher than Google organic. AEO is how you get into those AI-generated answers. If you're not optimized for AI extraction, your competitors are getting cited instead of you."
	},
	{
		q: "How is this different from SEO tools like Ahrefs or Semrush?",
		a: "SEO tools check Google rankings. AEOrank checks what AI engines look for: llms.txt, ai.txt, schema markup, AI crawler access, content structure for extraction, and 30 more criteria that SEO tools don't touch. Then it generates the 9 files AI engines need — no other tool does that."
	},
	{
		q: "How is this different from Profound, Otterly, or Scrunch?",
		a: "Profound ($99–399/mo, backed by Sequoia) is an excellent monitoring platform — it tracks prompt volume, brand mentions, and generates content briefs. Otterly and Scrunch do similar monitoring. AEOrank does something none of them do: it scores your site's technical AI readiness across 36 criteria and generates the 9 actual files AI engines look for (llms.txt, ai.txt, schema.json, etc.). Profound monitors what AI says about you. AEOrank fixes why AI can't read you. Both are useful — we're just 14× cheaper and open source."
	},
	{
		q: "Is it really free? What's the catch?",
		a: "The CLI, GitHub App, GitHub Action, and all 13 framework plugins are MIT licensed and always free. The Starter plan gives you 1 site and 3 scans/month at no cost. Pro ($29/mo) adds 5 sites, 50 scans, score history, auto-rescan, and PDF exports. Agency ($99/mo) scales to 50 sites with API access. Every plan includes full 36-criteria scoring and all 9 generated files — we don't gate the features that matter."
	},
	{
		q: "Does llms.txt actually work?",
		a: "Studies show llms.txt alone doesn't guarantee AI citations yet — which is exactly why AEOrank scores 36 criteria, not just one file. Your content structure, schema markup, AI crawler access, answer formatting, and entity disambiguation all matter. AEOrank checks every factor and generates all 9 files, not just llms.txt."
	},
	{
		q: "Can I use this in CI/CD?",
		a: "Yes — two ways. Install the GitHub App for zero-config PR checks (one click, no YAML). Or use the GitHub Action (vinpatel/aeorank-action@v1) for full pipeline control with fail-below thresholds. Both post Check Runs and score breakdowns directly on your PRs."
	},
	{
		q: "What AI engines does it optimize for?",
		a: "All of them. AEOrank checks your visibility across ChatGPT (GPTBot), Claude (ClaudeBot), Perplexity (PerplexityBot), Gemini (Google-Extended), and Google AI Overviews. All 36 criteria are tuned for what these engines actually evaluate when deciding what to cite."
	},
	{
		q: "How long does a scan take?",
		a: "Under 30 seconds for a typical site. AEOrank crawls up to 50 pages, analyzes structure across all 36 criteria, and generates your score and files. Fully deterministic — no LLM calls, same score every time."
	},
];
---
<section id="faq" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-3xl">
		<p class="eyebrow text-center">FAQ</p>
		<h2 class="heading-lg text-center mt-3">Common questions</h2>

		<div class="mt-14 faq-list">
			{faqs.map((faq, i) => (
				<div class="faq-item" data-index={i}>
					<button
						class="faq-trigger"
						aria-expanded="false"
						aria-controls={`faq-answer-${i}`}
						id={`faq-btn-${i}`}
					>
						<span class="faq-question">{faq.q}</span>
						<span class="faq-chevron" aria-hidden="true">
							<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M4 6l4 4 4-4"/>
							</svg>
						</span>
					</button>
					<div
						class="faq-body"
						id={`faq-answer-${i}`}
						role="region"
						aria-labelledby={`faq-btn-${i}`}
					>
						<p class="faq-answer">{faq.a}</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-border);
		transition: background 0.25s ease;
		border-radius: 0;
	}

	.faq-item:first-child {
		border-top: 1px solid var(--color-border);
	}

	.faq-item.is-open {
		background: rgba(232, 89, 12, 0.04);
		border-color: rgba(232, 89, 12, 0.15);
	}

	.faq-trigger {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding: 1.25rem 0;
		background: none;
		border: none;
		cursor: pointer;
		text-align: left;
		color: var(--color-text);
		transition: color 0.15s ease;
	}

	.faq-trigger:hover {
		color: var(--color-accent);
	}

	.faq-question {
		font-size: 0.9375rem;
		font-weight: 500;
		line-height: 1.4;
		flex: 1;
	}

	.faq-chevron {
		flex-shrink: 0;
		color: var(--color-text-muted);
		transition: color 0.2s ease, transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		display: flex;
		align-items: center;
	}

	.faq-item.is-open .faq-chevron {
		transform: rotate(180deg);
		color: var(--color-accent);
	}

	/* Smooth height animation via grid trick */
	.faq-body {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		overflow: hidden;
	}

	.faq-body > p {
		overflow: hidden;
	}

	.faq-item.is-open .faq-body {
		grid-template-rows: 1fr;
	}

	.faq-answer {
		font-size: 0.875rem;
		line-height: 1.75;
		color: var(--color-text-secondary);
		padding-bottom: 1.25rem;
		margin: 0;
	}
</style>

<script>
	const items = document.querySelectorAll<HTMLElement>('.faq-item');

	items.forEach((item) => {
		const trigger = item.querySelector<HTMLButtonElement>('.faq-trigger');
		if (!trigger) return;

		trigger.addEventListener('click', () => {
			const isOpen = item.classList.contains('is-open');

			// Close all others
			items.forEach((other) => {
				if (other !== item) {
					other.classList.remove('is-open');
					other.querySelector('.faq-trigger')?.setAttribute('aria-expanded', 'false');
				}
			});

			// Toggle current
			item.classList.toggle('is-open', !isOpen);
			trigger.setAttribute('aria-expanded', String(!isOpen));
		});
	});
</script>
