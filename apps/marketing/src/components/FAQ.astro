---
const faqs = [
	{
		q: "What is AEO?",
		a: "Answer Engine Optimization. It's how you make your site visible to ChatGPT, Perplexity, Claude, Gemini, and Google AI Overviews. AI search converts 5× better than Google organic — AEO is how you get into those answers."
	},
	{
		q: "How is this different from SEO tools?",
		a: "SEO tools check Google rankings. AEOrank checks what AI engines look for: llms.txt, ai.txt, schema markup, AI crawler access, content structure for extraction, and 30 more criteria. No overlap."
	},
	{
		q: "Is it really free?",
		a: "Yes. The CLI, core engine, GitHub App, GitHub Action, and all 13 framework plugins are MIT licensed. The GitHub App gives you 10 free scans per day. The SaaS dashboard at app.aeorank.dev has a free tier with paid plans for monitoring."
	},
	{
		q: "How is this different from Scrunch, Profound, or Peec AI?",
		a: "Those are $89–$500/month SaaS tools that track brand mentions in AI answers. AEOrank is free, open source, and does something they can't: it scores your site's technical AI readiness AND generates the 9 files AI engines need. Different tool, different job."
	},
	{
		q: "Does llms.txt actually work?",
		a: "Studies show llms.txt alone doesn't impact AI citations yet. That's exactly why AEOrank scores 36 criteria, not just llms.txt. Your overall content structure, schema markup, and AI crawler access matter far more. AEOrank checks all of it."
	},
	{
		q: "Can I use this in CI?",
		a: "Yes. Install the GitHub App for zero-config PR checks, or use the GitHub Action (vinpatel/aeorank-action@v1) for full CI control with fail-below thresholds. Both post Check Runs and PR comments."
	},
	{
		q: "What AI engines does it check for?",
		a: "AEOrank checks your visibility across ChatGPT (GPTBot), Claude (ClaudeBot), Perplexity (PerplexityBot), Gemini (Google-Extended), and Google AI Overviews. All 36 criteria are tuned for what these engines actually evaluate."
	},
	{
		q: "How long does a scan take?",
		a: "Under 30 seconds for a typical site. AEOrank crawls up to 50 pages, analyzes structure, and scores all 36 criteria. Deterministic — same score every time, no LLM calls."
	},
];
---
<section id="faq" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-3xl">
		<p class="eyebrow text-center">FAQ</p>
		<h2 class="heading-lg text-center mt-3">Common questions</h2>

		<div class="mt-14 space-y-0">
			{faqs.map((faq) => (
				<details class="group border-b border-border">
					<summary class="flex items-center justify-between py-5 cursor-pointer text-text hover:text-accent transition-colors">
						<span class="text-[0.9375rem] font-medium pr-4">{faq.q}</span>
						<span class="text-text-muted group-open:rotate-45 transition-transform text-lg shrink-0">+</span>
					</summary>
					<p class="pb-5 text-sm text-text-secondary leading-relaxed">{faq.a}</p>
				</details>
			))}
		</div>
	</div>
</section>
