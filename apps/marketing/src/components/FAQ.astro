---
// FAQ rendered as paired structured-data / prose panes.
// Left: the actual JSON-LD an AI crawler would ingest.
// Right: the human-readable Q&A with a lock-free details/summary pattern.

const faqs = [
	{
		q: "Will this actually help me rank in ChatGPT answers?",
		a: "Alone, no single file is a silver bullet. AEOrank scores 36 things at once — technical signals like llms.txt, content signals like answer density, trust signals like schema.Author, and access signals like crawler permissions. Fix the 9 failing checks and a typical site goes from 31→70+ on the next scan. Citations in Perplexity and ChatGPT tend to follow within 2–4 weeks."
	},
	{
		q: "What does deterministic scoring actually mean?",
		a: "Every check is a pure function of HTML, headers, and file presence — no LLM calls, no randomness. Scan the same site twice and you get the same score. That's what lets us run in CI and fail a PR confidently."
	},
	{
		q: "Is it really MIT?",
		a: "Yes. The scanner core, all 13 framework plugins, the GitHub App, the GitHub Action, and the file generators are under the MIT license. You can self-host the lot. The hosted app exists to make things convenient — never because the tool requires it."
	},
	{
		q: "How is this different from Ahrefs or Semrush?",
		a: "Classical SEO tools check ranking signals for Google. AEOrank checks answer-extraction signals for AI engines: llms.txt, ai.txt, schema.org coverage, speakable markup, AI crawler access, content structure for extraction, and 30 more criteria that SEO tools don't touch. Then it generates the 9 actual files — no SEO tool does that."
	},
	{
		q: "What's the difference vs Profound, Otterly, or Scrunch?",
		a: "They monitor (what AI says about your brand). AEOrank scores (whether AI can read you) and fixes (by generating the 9 files). Complementary, but AEOrank solves the upstream problem. Also 14× cheaper and open source."
	},
	{
		q: "Can I use this in CI?",
		a: "Two ways. Install the GitHub App for zero-YAML PR checks, or pin aeorank-action@v1 in a workflow with a fail-below threshold. Both post a check run with the score and the diff of generated files."
	},
	{
		q: "Does AEOrank send my site to an LLM?",
		a: "No. The scanner is deterministic and never calls an external model. The CLI runs fully locally; the hosted app fetches your public URL over HTTPS exactly like any other crawler."
	},
	{
		q: "What AI engines is it tuned for?",
		a: "GPTBot (ChatGPT), ClaudeBot (Claude), PerplexityBot (Perplexity), Google-Extended (Gemini + AI Overviews), and Cohere. If a significant engine ships a new crawler or signal, we add a check — usually within a week."
	},
];

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faqs.map(f => ({
		"@type": "Question",
		"name": f.q,
		"acceptedAnswer": { "@type": "Answer", "text": f.a }
	}))
};
---

<section id="faq" class="section">
	<div class="wrap rail">
		<span class="rail-tick" style="top:0"></span>
		<span class="rail-coord" style="top:0">FAQ</span>

		<div class="section-head">
			<div>
				<p class="t-label">// what an AI crawler sees vs. what you read</p>
				<h2 class="t-h1 mt-2">FAQ, rendered twice.</h2>
				<p class="t-body mt-3 max-w-[58ch]">
					Left: the JSON-LD we emit on this page, verbatim — exactly what an AI crawler extracts. Right: the same answers for human eyes. We practice what we score.
				</p>
			</div>
			<div class="section-meta">
				<span>{faqs.length}&nbsp;<b>questions</b></span>
				<span>1&nbsp;<b>schema.FAQPage</b></span>
			</div>
		</div>

		<div class="faq-split" data-reveal>
			<!-- Machine pane -->
			<aside class="faq-machine cropped">
				<span class="cr-tl" aria-hidden="true"></span>
				<span class="cr-br" aria-hidden="true"></span>

				<header class="faq-machine__hd">
					<span class="t-label">/faq &middot; <span class="ink-2">application/ld+json</span></span>
					<span class="sig sig-ok ml-auto"><span class="dot dot-ok ping"></span>emitted</span>
				</header>

				<pre class="codeblock codeblock-dark faq-machine__pre">
<span class="tok-p">&#123;</span>
  <span class="tok-k">"@context"</span><span class="tok-p">:</span> <span class="tok-s">"https://schema.org"</span><span class="tok-p">,</span>
  <span class="tok-k">"@type"</span><span class="tok-p">:</span> <span class="tok-s">"FAQPage"</span><span class="tok-p">,</span>
  <span class="tok-k">"mainEntity"</span><span class="tok-p">:</span> <span class="tok-p">[</span>
{faqs.map((f, i) => `    { "@type": "Question",\n      "name": ${JSON.stringify(f.q)},\n      "acceptedAnswer": {\n        "@type": "Answer",\n        "text": ${JSON.stringify(f.a).slice(0, 90)}…"\n      }\n    }${i < faqs.length - 1 ? "," : ""}\n`).join("")}
  <span class="tok-p">]</span>
<span class="tok-p">&#125;</span></pre>

				<footer class="faq-machine__ft">
					<span class="font-mono text-[10.5px] ink-3">valid schema · parsed by GPTBot, ClaudeBot, PerplexityBot</span>
				</footer>
			</aside>

			<!-- Human pane -->
			<div class="faq-human">
				{faqs.map((f, i) => (
					<details class="faq-item" open={i === 0}>
						<summary class="faq-sum">
							<span class="faq-sum__num font-mono">0{i + 1}</span>
							<span class="faq-sum__q">{f.q}</span>
							<span class="faq-sum__caret" aria-hidden="true">
								<svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
									<path d="M4 6l4 4 4-4"/>
								</svg>
							</span>
						</summary>
						<p class="faq-a">{f.a}</p>
					</details>
				))}
			</div>
		</div>

		<div class="faq-contact mt-8" data-reveal>
			<span class="font-mono text-[11px] ink-3">still curious?</span>
			<a href="mailto:hello@aeorank.dev" class="ilink font-mono text-[11px]">hello@aeorank.dev</a>
			<span class="font-mono text-[11px] ink-3">·</span>
			<a href="https://github.com/vinpatel/aeorank/discussions" class="ilink font-mono text-[11px]" target="_blank" rel="noopener">open a discussion on github&nbsp;→</a>
		</div>
	</div>

	<!-- Emit the actual JSON-LD so the claim above is literally true -->
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
</section>

<style>
	.faq-split {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0;
		border: 1px solid var(--color-ink);
		border-radius: 4px;
		background: var(--color-page);
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
		overflow: hidden;
	}

	.faq-machine {
		background: #141416;
		border-right: 1px solid var(--color-ink);
		display: flex;
		flex-direction: column;
	}
	.faq-machine__hd {
		display: flex;
		align-items: center;
		padding: 10px 14px;
		border-bottom: 1px solid #2A2A2C;
		color: #A0A0A8;
	}
	.faq-machine__hd .t-label { color: #A0A0A8; }
	.faq-machine__hd .ink-2 { color: #D0D0D4; }
	.faq-machine__pre {
		margin: 0;
		border-radius: 0;
		border: none;
		flex: 1;
		font-size: 11.5px;
		line-height: 1.7;
	}
	.faq-machine__ft {
		padding: 8px 14px;
		border-top: 1px solid #2A2A2C;
		background: #1A1A1C;
		color: #6E6E74;
	}

	.faq-human {
		background: var(--color-page);
		display: flex;
		flex-direction: column;
	}

	.faq-item {
		border-bottom: 1px solid var(--color-rule);
		padding: 0;
	}
	.faq-item[open] { background: var(--color-paper-2); }
	.faq-item:last-child { border-bottom: none; }

	.faq-sum {
		list-style: none;
		cursor: pointer;
		display: grid;
		grid-template-columns: 36px 1fr 20px;
		gap: 12px;
		align-items: baseline;
		padding: 16px 18px 16px 14px;
		transition: background 140ms ease;
	}
	.faq-sum::-webkit-details-marker { display: none; }

	.faq-sum__num {
		font-size: 10.5px;
		color: var(--color-ink-3);
		letter-spacing: 0.04em;
	}
	.faq-sum__q {
		font-size: 14px;
		font-weight: 540;
		color: var(--color-ink);
		line-height: 1.4;
	}
	.faq-sum__caret {
		color: var(--color-ink-3);
		transition: transform 200ms ease, color 140ms ease;
	}
	.faq-item[open] .faq-sum__caret { transform: rotate(180deg); color: var(--color-ink); }
	.faq-sum:hover .faq-sum__q { color: var(--color-ink); }

	.faq-a {
		padding: 0 18px 18px 62px;
		font-size: 13.5px;
		line-height: 1.7;
		color: var(--color-ink-2);
		margin: 0;
	}

	.faq-contact {
		display: flex;
		gap: 10px;
		align-items: center;
		padding: 14px 16px;
		border: 1px dashed var(--color-rule-2);
		border-radius: 4px;
		margin-right: clamp(1.25rem, 4vw, 3.25rem);
		flex-wrap: wrap;
	}

	@media (max-width: 880px) {
		.faq-split { grid-template-columns: 1fr; }
		.faq-machine { border-right: none; border-bottom: 1px solid var(--color-ink); }
	}
</style>
