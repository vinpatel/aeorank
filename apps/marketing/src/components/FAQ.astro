---
const faqs = [
	{
		question: "What is AEO?",
		answer: "Answer Engine Optimization. The practice of making your website visible and citable by AI engines like ChatGPT, Perplexity, and Claude. As AI-powered search grows, optimized sites get cited — the rest get ignored.",
	},
	{
		question: "Is AEOrank free?",
		answer: "The CLI is free and MIT-licensed. Run unlimited scans, generate all 8 files, pipe JSON to CI — no account needed. The web dashboard has paid tiers starting at $29/month for score history, charts, and file downloads.",
	},
	{
		question: "What are the 8 generated files?",
		answer: "llms.txt, llms-full.txt, CLAUDE.md, schema.json, robots-patch.txt, faq-blocks.html, citation-anchors.html, and sitemap-ai.xml. Each one targets a different aspect of AI visibility.",
	},
	{
		question: "How is the AEO score calculated?",
		answer: "36 criteria across 5 pillars, each scored 0–10 with percentage weights summing to 100%. Pillars: Answer Readiness, Content Structure, Trust & Authority, Technical Foundation, AI Discovery. Grades from A+ (95+) to F (below 40).",
	},
	{
		question: "Does this replace SEO?",
		answer: "No. AEO complements SEO. Traditional search engines still matter. AEOrank focuses on the signals that AI engines use to find and cite your content — a different surface entirely.",
	},
	{
		question: "Can I use this in CI?",
		answer: "Yes. Run npx aeorank-cli scan --format json in any CI pipeline. You can also use the official GitHub Action (aeorank/action@v1) to post scores as Check Runs and PR comments automatically.",
	},
	{
		question: "How long does a scan take?",
		answer: "Under 30 seconds for most sites. AEOrank crawls up to 50 pages with 3 concurrent requests by default. Adjustable with --max-pages and --concurrency flags.",
	},
];
---

<section id="faq" class="py-24 sm:py-32 border-t border-[--color-border] px-6">
	<div class="mx-auto max-w-3xl">
		<h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-[--color-text] font-[family-name:var(--font-display)]">Frequently Asked Questions</h2>
		<div class="mt-12 space-y-0 divide-y divide-[--color-border]">
			{
				faqs.map((faq) => (
					<details class="group">
						<summary class="flex cursor-pointer items-center justify-between py-6 text-lg font-medium text-[--color-text] select-none list-none [&::-webkit-details-marker]:hidden">
							{faq.question}
							<svg
								width="20"
								height="20"
								viewBox="0 0 20 20"
								fill="none"
								class="ml-4 shrink-0 text-[--color-text-muted] transition-transform duration-300 ease-out group-open:rotate-45"
							>
								<path d="M10 4v12m-6-6h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
							</svg>
						</summary>
						<div class="overflow-hidden">
							<p class="pb-6 text-[--color-text-muted] text-base leading-relaxed -mt-1">{faq.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>

<style>
	details summary {
		list-style: none;
	}

	details[open] > div {
		animation: faq-slide-down 0.25s ease-out;
	}

	@keyframes faq-slide-down {
		from {
			opacity: 0;
			max-height: 0;
			transform: translateY(-4px);
		}
		to {
			opacity: 1;
			max-height: 200px;
			transform: translateY(0);
		}
	}
</style>
