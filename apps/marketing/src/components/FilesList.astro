---
const files = [
	{
		name: "llms.txt",
		description: "The new robots.txt for AI. Tells language models what your site is about, in their language.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
	},
	{
		name: "llms-full.txt",
		description: "Extended version with complete content for models that want the full picture.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
	},
	{
		name: "CLAUDE.md",
		description: "Repository context file. Helps AI coding assistants understand your codebase instantly.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
	},
	{
		name: "schema.json",
		description: "Organization, WebSite, and FAQ structured data in JSON-LD format.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
	},
	{
		name: "robots-patch.txt",
		description: "Allow directives for GPTBot, ClaudeBot, PerplexityBot, and Google-Extended.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="3"/><path d="M12 8v3"/><circle cx="8" cy="16" r="1" fill="#E8590C"/><circle cx="16" cy="16" r="1" fill="#E8590C"/></svg>`,
	},
	{
		name: "faq-blocks.html",
		description: "Speakable FAQ markup that AI engines love to quote and cite directly.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><circle cx="12" cy="17" r=".5" fill="#E8590C"/></svg>`,
	},
	{
		name: "citation-anchors.html",
		description: "Heading anchors that make your content directly linkable by AI responses.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
	},
	{
		name: "sitemap-ai.xml",
		description: "AI-optimized sitemap with content type hints and freshness signals.",
		icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#E8590C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
	},
];
---

<section id="files" class="section-spacing border-t border-border px-6">
	<div class="mx-auto max-w-5xl">
		<h2 class="heading-lg">8 Files That Get You Cited</h2>
		<p class="body-lg mt-4 text-text-muted max-w-2xl">
			Every file AI engines look for, generated and tailored to your site.
		</p>
		<div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2">
			{
				files.map((file) => (
					<div class="rounded-xl border border-border-light bg-bg px-7 py-6 card-hover">
						<div class="flex items-start gap-4">
							<div class="inline-flex items-center justify-center w-10 h-10 rounded-lg bg-accent-warm-light shrink-0 mt-0.5">
								<Fragment set:html={file.icon} />
							</div>
							<div>
								<code class="font-mono text-base font-medium text-text">{file.name}</code>
								<p class="mt-1.5 text-sm text-text-muted leading-relaxed">{file.description}</p>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>
