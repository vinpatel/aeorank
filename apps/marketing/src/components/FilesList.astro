---
const files = [
	{
		name: "llms.txt",
		description: "The new robots.txt for AI. Tells language models what your site is about.",
	},
	{
		name: "llms-full.txt",
		description: "Full-text version for models that want the complete picture.",
	},
	{
		name: "CLAUDE.md",
		description: "Repository context file. Helps AI assistants understand your codebase.",
	},
	{
		name: "schema.json",
		description: "Organization + WebSite + FAQ structured data in JSON-LD.",
	},
	{
		name: "robots-patch.txt",
		description: "Directives for GPTBot, ClaudeBot, PerplexityBot, and Google-Extended.",
	},
	{
		name: "faq-blocks.html",
		description: "Speakable FAQ markup that AI engines love to cite.",
	},
	{
		name: "citation-anchors.html",
		description: "Heading anchors that make your content directly linkable by AI.",
	},
	{
		name: "sitemap-ai.xml",
		description: "AI-optimized sitemap with content type hints.",
	},
];
---

<section id="files" class="border-t border-border px-6 py-24">
	<div class="mx-auto max-w-6xl">
		<h2 class="text-4xl font-bold md:text-5xl">8 Files. Every One Matters.</h2>
		<p class="mt-4 text-lg text-text-muted">
			AEOrank generates the complete set of files AI engines look for.
		</p>
		<div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{
				files.map((file) => (
					<div class="border border-border p-6">
						<code class="font-mono text-sm font-medium">{file.name}</code>
						<p class="mt-2 text-sm text-text-muted">{file.description}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
