---
const files = [
	{ name: "llms.txt", desc: "Site summary for ChatGPT, Claude, Perplexity, and Gemini crawlers. The llmstxt.org standard." },
	{ name: "llms-full.txt", desc: "Extended version with Q&A pairs, entity disambiguation, and key definitions." },
	{ name: "ai.txt", desc: "AI usage permissions and content licensing for responsible crawling." },
	{ name: "CLAUDE.md", desc: "Markdown context file that helps AI coding assistants understand your codebase." },
	{ name: "schema.json", desc: "Organization, WebSite, and FAQPage JSON-LD structured data for AI citation." },
	{ name: "robots-patch.txt", desc: "AI-specific crawler directives — allow GPTBot, ClaudeBot, PerplexityBot." },
	{ name: "faq-blocks.html", desc: "FAQ markup with schema.org and speakable annotations for voice and AI." },
	{ name: "citation-anchors.html", desc: "Heading anchors that make your content directly linkable by AI responses." },
	{ name: "sitemap-ai.xml", desc: "AI-optimized sitemap with content type hints and freshness signals." },
];
---
<section id="files" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-5xl">
		<p class="eyebrow text-center">Output</p>
		<h2 class="heading-lg text-center mt-3">9 files that get you cited</h2>
		<p class="body-lg text-center max-w-2xl mx-auto mt-4">Every file AI engines look for — generated automatically, tailored to your site.</p>

		<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-14">
			{files.map((f) => (
				<div class="card p-6 group">
					<code class="text-sm !bg-accent-muted !text-accent !border-accent/20">{f.name}</code>
					<p class="text-sm text-text-muted mt-3 leading-relaxed">{f.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>
