---
import TerminalDemo from "./TerminalDemo.tsx";
---
<section class="relative px-6 pt-24 pb-20 md:pt-32 md:pb-28">
	<div class="mx-auto max-w-5xl">
		<!-- Social proof banner -->
		<div class="flex justify-center mb-8 animate-fade-in-up">
			<a href="https://github.com/vinpatel/aeorank" target="_blank" class="inline-flex items-center gap-3 rounded-full border border-border px-5 py-2 text-sm text-text-muted hover:text-text hover:border-border-strong transition-all">
				<span class="flex h-2 w-2"><span class="absolute inline-flex h-2 w-2 animate-ping rounded-full bg-green opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-green"></span></span>
				Open source · MIT licensed · Star us on GitHub
			</a>
		</div>

		<!-- Headline -->
		<h1 class="heading-xl text-center max-w-4xl mx-auto animate-fade-in-up" style="animation-delay:0.1s">
			ChatGPT, Perplexity, Claude, and Gemini<br/>
			<span class="text-accent">can't find your site.</span>
		</h1>

		<!-- Sub -->
		<p class="body-lg text-center max-w-2xl mx-auto mt-6 animate-fade-in-up" style="animation-delay:0.15s">
			AI search converts 5× better than Google. AEOrank scores your visibility 0–100 across 36 criteria and generates the 9 files every AI engine looks for.
		</p>

		<!-- CTAs -->
		<div class="flex flex-wrap justify-center gap-3 mt-8 animate-fade-in-up" style="animation-delay:0.2s">
			<a href="https://github.com/apps/aeorank" class="btn-primary">Install GitHub App <span class="text-white/50 text-xs ml-1">— zero config</span></a>
			<a href="#how-it-works" class="btn-secondary">See How It Works ↓</a>
		</div>

		<!-- Stats -->
		<div class="flex flex-wrap justify-center gap-8 mt-12 text-sm animate-fade-in-up" style="animation-delay:0.25s">
			<div class="flex items-center gap-2"><span class="text-accent font-bold text-lg">36</span><span class="text-text-muted">AI criteria</span></div>
			<div class="h-5 w-px bg-border hidden sm:block"></div>
			<div class="flex items-center gap-2"><span class="text-accent font-bold text-lg">5</span><span class="text-text-muted">pillars</span></div>
			<div class="h-5 w-px bg-border hidden sm:block"></div>
			<div class="flex items-center gap-2"><span class="text-accent font-bold text-lg">9</span><span class="text-text-muted">files generated</span></div>
			<div class="h-5 w-px bg-border hidden sm:block"></div>
			<div class="flex items-center gap-2"><span class="text-green font-bold text-lg">$0</span><span class="text-text-muted">open source</span></div>
			<div class="h-5 w-px bg-border hidden sm:block"></div>
			<div class="flex items-center gap-2"><span class="text-accent font-bold text-lg">13</span><span class="text-text-muted">framework plugins</span></div>
		</div>

		<!-- Terminal -->
		<div class="mt-16 mx-auto max-w-3xl animate-fade-in-up" style="animation-delay:0.3s">
			<div class="rounded-xl border border-border bg-[#0A0A0C] overflow-hidden shadow-2xl shadow-black/50">
				<div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-white/[0.02]">
					<div class="w-2.5 h-2.5 rounded-full bg-red"></div>
					<div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
					<div class="w-2.5 h-2.5 rounded-full bg-green"></div>
					<span class="text-xs text-text-muted ml-2 font-mono">aeorank</span>
				</div>
				<TerminalDemo client:visible />
			</div>
		</div>

		<!-- Used by -->
		<p class="text-center text-text-muted text-sm mt-10 animate-fade-in-up" style="animation-delay:0.35s">
			Works with every site. Checks visibility across <strong class="text-text">ChatGPT</strong>, <strong class="text-text">Perplexity</strong>, <strong class="text-text">Claude</strong>, <strong class="text-text">Gemini</strong>, and <strong class="text-text">Google AI Overviews</strong>.
		</p>
	</div>
</section>
