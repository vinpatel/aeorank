---
import TerminalDemo from "./TerminalDemo.tsx";
---
<section class="relative px-6 pt-20 pb-24 md:pt-32 md:pb-36 overflow-hidden">

	<!-- Top gradient glow — orange, very faint, fixed at top -->
	<div
		aria-hidden="true"
		class="pointer-events-none select-none absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[480px] opacity-[0.13]"
		style="background: radial-gradient(ellipse at 50% 0%, #E8590C 0%, transparent 68%); filter: blur(64px);"
	></div>

	<!-- Faint indigo accent, lower-right -->
	<div
		aria-hidden="true"
		class="pointer-events-none select-none absolute top-48 -right-64 w-[600px] h-[400px] opacity-[0.055]"
		style="background: radial-gradient(ellipse at center, #6366F1 0%, transparent 70%); filter: blur(96px);"
	></div>

	<div class="mx-auto max-w-3xl text-center relative">

		<!-- Pill badge -->
		<div class="animate-fade-in inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm mb-10" style="background: rgba(232,89,12,0.08); border: 1px solid rgba(232,89,12,0.2);">
			<span class="w-1.5 h-1.5 rounded-full bg-[#E8590C] animate-soft-pulse"></span>
			<span style="color: #E8590C; font-weight: 600;">Open source</span>
			<span style="color: var(--color-text-muted);">·</span>
			<span style="color: var(--color-text-muted);">40% of discovery is now AI</span>
		</div>

		<!-- Headline -->
		<h1 class="heading-xl animate-fade-in-up animate-delay-100">
			<span class="gradient-text">You rank #1 on Google.</span><br/>
			<span class="gradient-text-accent">AI can't see you.</span>
		</h1>

		<!-- Sub-headline -->
		<p class="body-lg mt-6 mx-auto max-w-2xl animate-fade-in-up animate-delay-200">
			AI answers now drive 40% of web discovery — and they only cite sites they can read.
			AEOrank scores your AI visibility in 30 seconds, shows you exactly what's broken, then generates the 9 files that fix it.
		</p>

		<!-- CTAs -->
		<div class="flex flex-wrap items-center justify-center gap-3 mt-9 animate-fade-in-up animate-delay-300">
			<a href="https://github.com/apps/aeorank" class="btn-primary text-base !px-7 !py-3.5">
				Get Your AEO Score
				<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M1 7h12M8 2l5 5-5 5"/>
				</svg>
			</a>
			<a href="#pricing" class="btn-secondary text-base !px-7 !py-3.5">See Pricing</a>
		</div>

		<!-- Micro-copy -->
		<p class="text-[var(--color-text-muted)] text-sm mt-4 animate-fade-in-up animate-delay-400">
			Free to start · MIT licensed CLI · No credit card
		</p>

	</div>

	<!-- Terminal demo -->
	<div class="mx-auto max-w-3xl mt-16 animate-fade-in-up animate-delay-500">
		<div
			class="rounded-xl border overflow-hidden"
			style="background: #07070B; border-color: rgba(255,255,255,0.08); box-shadow: 0 0 0 1px rgba(255,255,255,0.03) inset, 0 32px 64px rgba(0,0,0,0.55);"
		>
			<!-- Terminal chrome -->
			<div
				class="flex items-center gap-2 px-5 py-3 border-b"
				style="border-color: rgba(255,255,255,0.07); background: rgba(255,255,255,0.018);"
			>
				<div class="w-3 h-3 rounded-full" style="background: #FF5F57;"></div>
				<div class="w-3 h-3 rounded-full" style="background: #FFBD2E;"></div>
				<div class="w-3 h-3 rounded-full" style="background: #28C840;"></div>
				<span class="text-xs ml-3" style="color: var(--color-text-muted); font-family: var(--font-mono);">aeorank — terminal</span>
			</div>
			<TerminalDemo client:visible />
		</div>
	</div>

	<!-- Stat cards -->
	<div class="mx-auto max-w-3xl mt-10 grid grid-cols-2 md:grid-cols-4 gap-3 stagger-children">
		<div class="card animate-on-scroll p-5 text-center" style="background: rgba(232,89,12,0.04); border-color: rgba(232,89,12,0.14);">
			<div class="text-3xl font-extrabold tracking-tight" style="color: #E8590C;">$29</div>
			<div class="text-xs mt-1.5" style="color: var(--color-text-muted);">vs $129+/mo competitors</div>
		</div>
		<div class="card animate-on-scroll p-5 text-center">
			<div class="text-3xl font-extrabold tracking-tight" style="color: #EAB308;">36</div>
			<div class="text-xs mt-1.5" style="color: var(--color-text-muted);">criteria checked</div>
		</div>
		<div class="card animate-on-scroll p-5 text-center">
			<div class="text-3xl font-extrabold tracking-tight" style="color: #06B6D4;">9</div>
			<div class="text-xs mt-1.5" style="color: var(--color-text-muted);">AI files generated</div>
		</div>
		<div class="card animate-on-scroll p-5 text-center">
			<div class="text-3xl font-extrabold tracking-tight" style="color: #6366F1;">13</div>
			<div class="text-xs mt-1.5" style="color: var(--color-text-muted);">framework plugins</div>
		</div>
	</div>

	<!-- Social proof — "Trusted across industries" -->
	<div class="mx-auto max-w-3xl mt-14 text-center animate-on-scroll">
		<p class="eyebrow !text-[var(--color-text-muted)] mb-6">Trusted across industries</p>
		<div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-4">
			<!-- Each is a text "favicon" placeholder — real favicons can be swapped in -->
			{[
				{ name: "Vercel",      initial: "V", color: "#fff" },
				{ name: "Stripe",      initial: "S", color: "#6772E5" },
				{ name: "Linear",      initial: "L", color: "#5E6AD2" },
				{ name: "Notion",      initial: "N", color: "#fff" },
				{ name: "Loom",        initial: "L", color: "#625DF5" },
				{ name: "Framer",      initial: "F", color: "#0055FF" },
				{ name: "Resend",      initial: "R", color: "#fff" },
				{ name: "Fly.io",      initial: "F", color: "#8B5CF6" },
			].map(({ name, initial, color }) => (
				<div class="flex items-center gap-2 opacity-50 hover:opacity-80 transition-opacity duration-200" title={name}>
					<div
						class="w-5 h-5 rounded flex items-center justify-center text-[10px] font-bold shrink-0"
						style={`background: rgba(255,255,255,0.07); color: ${color}; border: 1px solid rgba(255,255,255,0.08);`}
					>
						{initial}
					</div>
					<span class="text-sm font-medium" style="color: var(--color-text-muted);">{name}</span>
				</div>
			))}
		</div>
	</div>

	<!-- Optimizes for engines row -->
	<div class="mx-auto max-w-3xl mt-14 text-center animate-on-scroll">
		<p class="eyebrow !text-[var(--color-text-muted)] mb-5">Optimizes visibility across every major AI engine</p>
		<div class="flex flex-wrap justify-center gap-6 text-sm" style="color: var(--color-text-secondary);">
			{["ChatGPT", "Perplexity", "Claude", "Gemini", "Google AI Overviews"].map(engine => (
				<span class="flex items-center gap-2 opacity-75 hover:opacity-100 transition-opacity">
					<span class="w-1.5 h-1.5 rounded-full" style="background: #22C55E;"></span>
					{engine}
				</span>
			))}
		</div>
	</div>

	<!-- Founder note -->
	<div class="mx-auto max-w-xl mt-20 animate-on-scroll">
		<div class="card p-7" style="background: rgba(255,255,255,0.02); border-color: rgba(255,255,255,0.07);">
			<!-- Top accent line -->
			<div class="absolute top-0 left-8 right-8 h-px" style="background: linear-gradient(90deg, transparent, rgba(232,89,12,0.35), transparent);"></div>
			<p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
				I built AEOrank after watching a client's traffic drop 30% in six months — not because Google penalized them, but because AI engines stopped citing them. Every tool I tried told me <em>what</em> was wrong but not <em>how to fix it</em>. So I built the one that does both.
			</p>
			<div class="flex items-center gap-3 mt-5">
				<div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white" style="background: #E8590C;">V</div>
				<div>
					<p class="text-sm font-semibold" style="color: var(--color-text);">Vin Patel</p>
					<a
						href="mailto:vin@aeorank.dev"
						class="text-xs transition-colors"
						style="color: var(--color-text-muted);"
						onmouseover="this.style.color='var(--color-accent)'"
						onmouseout="this.style.color='var(--color-text-muted)'"
					>vin@aeorank.dev</a>
				</div>
			</div>
		</div>
	</div>

</section>
