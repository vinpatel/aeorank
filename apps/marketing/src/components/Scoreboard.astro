function gradeColor(grade: string): string {
	if (grade === "A" || grade === "A+") return "text-green";
	if (grade === "B") return "text-green";
	if (grade === "C") return "text-[#FFD700]";
	if (grade === "D") return "text-accent";
	return "text-red";
}

function barWidth(score: number): string {
	return `${Math.max(score, 3)}%`;
}

function barColor(score: number): string {
	if (score >= 80) return "bg-green";
	if (score >= 60) return "bg-[#FFD700]";
	if (score >= 40) return "bg-accent";
	return "bg-red";
}

const totalCompanies = industries.reduce((sum, i) => sum + i.companies.length, 0);
const globalAvg = Math.round(industries.reduce((sum, i) => sum + i.avg, 0) / industries.length);
---
<section id="scoreboard" class="px-6 py-20 md:py-28 border-t border-border">
	<div class="mx-auto max-w-6xl">
		<p class="eyebrow text-center">Industry scoreboard</p>
		<h2 class="heading-lg text-center mt-3">How does your industry score on AI visibility?</h2>
		<p class="body-lg text-center max-w-3xl mx-auto mt-4">We scanned {totalCompanies} of the world's top-funded startups across {industries.length} industries. The average AEO score? <strong class="text-accent">{globalAvg}/100</strong>. Even billion-dollar companies are invisible to AI.</p>

		<!-- Industry average cards -->
		<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3 mt-14">
			{industries.map((ind) => (
				<a href={`#industry-${ind.name.toLowerCase().replace(/[\s\/]/g, '-')}`} class="card p-4 text-center hover:border-accent/30 transition-all">
					<span class="text-2xl">{ind.emoji}</span>
					<p class="text-xs font-semibold mt-2 text-text-muted">{ind.name}</p>
					<p class="text-2xl font-bold mt-1"><span class={ind.avg >= 50 ? 'text-[#FFD700]' : 'text-accent'}>{ind.avg}</span><span class="text-text-muted text-sm">/100</span></p>
				</a>
			))}
		</div>

		<!-- Industry detail tables -->
		<div class="mt-16 space-y-16">
			{industries.map((ind) => (
				<div id={`industry-${ind.name.toLowerCase().replace(/[\s\/]/g, '-')}`}>
					<div class="flex items-center gap-3 mb-6">
						<span class="text-2xl">{ind.emoji}</span>
						<div>
							<h3 class="heading-sm">{ind.name}</h3>
							<p class="text-sm text-text-muted">Industry avg: <span class={ind.avg >= 50 ? 'text-[#FFD700] font-bold' : 'text-accent font-bold'}>{ind.avg}/100</span></p>
						</div>
					</div>
					<div class="space-y-2">
						{ind.companies.map((co, idx) => (
							<div class="flex items-center gap-3 py-2.5 px-4 rounded-lg bg-bg-card border border-border hover:border-border-strong transition-colors group">
								<span class="text-text-muted text-xs w-5 text-right shrink-0">{idx + 1}</span>
								<span class="font-medium text-sm min-w-[120px] sm:min-w-[160px]">{co.name}</span>
								<span class="text-xs text-text-muted hidden sm:inline min-w-[140px]">{co.url}</span>
								<div class="flex-1 mx-3 hidden sm:block">
									<div class="h-2 rounded-full bg-white/5 overflow-hidden">
										<div class={`h-full rounded-full ${barColor(co.score)} transition-all`} style={`width: ${barWidth(co.score)}`}></div>
									</div>
								</div>
								<span class="text-sm font-bold tabular-nums w-8 text-right">{co.score}</span>
								<span class={`text-sm font-bold w-6 text-center ${gradeColor(co.grade)}`}>{co.grade}</span>
							</div>
						))}
					</div>
				</div>
			))}
		</div>

		<!-- CTA -->
		<div class="mt-20 text-center">
			<div class="card p-10 max-w-2xl mx-auto border-accent/20">
				<h3 class="heading-md">Where does <em>your</em> site rank?</h3>
				<p class="text-text-muted mt-3">These companies raised billions. Their average AEO score is {globalAvg}. Yours might be higher — or much lower. Find out in 30 seconds.</p>
				<div class="flex flex-wrap justify-center gap-3 mt-6">
					<a href="https://github.com/apps/aeorank" class="btn-primary">Scan My Site Free</a>
				</div>
				<p class="text-text-muted text-xs mt-4">Free forever · No credit card · Results in 30 seconds</p>
			</div>
		</div>

		<p class="text-center text-text-muted text-xs mt-8">Scores generated by <code class="!text-[10px]">aeorank-cli scan</code> on April 9, 2026. Scores may change as sites update.</p>
	</div>
</section>
